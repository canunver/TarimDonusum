@model List<TarimDonusum.Models.Basvuru>
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["Basvuru.Index.Title"];
}

<div class="basvuru-page">
    <div class="basvuru-titlebar">
        <div>
            <h1>@L["Basvuru.Index.Heading"]</h1>
            <p>@L["Basvuru.Index.Description"]</p>
        </div>
        <a class="btn btn-primary" asp-controller="Basvuru" asp-action="Yeni">@L["Basvuru.Index.New"]</a>
    </div>

    <div id="ajaxMesaj"
         class="alert alert-info alert-dismissible floating-message"
         style="display:@(TempData["Mesaj"] != null ? "block" : "none")">
        <span id="ajaxMesajMetin">@TempData["Mesaj"]</span>
        <button type="button" id="ajaxMesajKapat" class="close" aria-label="@L["Basvuru.Common.Close"]">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    <div class="table-responsive basvuru-card">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Basvuru.Common.No"]</th>
                    <th>@L["Basvuru.Field.TicaretUnvani"]</th>
                    <th>@L["Basvuru.Field.VergiKimlikNo"]</th>
                    <th>@L["Basvuru.Field.YatirimAdi"]</th>
                    <th>@L["Basvuru.Field.Durum"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-muted">@L["Basvuru.Index.Empty"]</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.basvuruFirma.firma.ticaretUnvani</td>
                        <td>@item.basvuruFirma.firma.vergiKimlikNo</td>
                        <td>@(string.IsNullOrWhiteSpace(item.yatirim.yatirimAdi) ? "-" : item.yatirim.yatirimAdi)</td>
                        <td><span class="badge bg-secondary">@item.durum</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Basvuru" asp-action="Duzenle" asp-route-id="@item.Id">@L["Basvuru.Common.Edit"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        if (typeof PopupMesajIlklendir === 'function') {
            PopupMesajIlklendir();
        }
    });
</script>
}
