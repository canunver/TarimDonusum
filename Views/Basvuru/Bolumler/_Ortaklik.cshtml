@using System.Text.Json
@model TarimDonusum.ViewModels.Basvuru.BasvuruFormViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    var b = Model.Basvuru;
    bool ro = Model.SaltOkunur;
    string T(string key) => L[key].Value;
    var ortaklik = b.ortaklik ?? new BasvuruOrtaklik { basvuruId = b.Id };
    ortaklik.basvuruId = b.Id;
    if (ortaklik.bagliOrtakDosyalari.Count == 0)
    {
        ortaklik.bagliOrtakDosyalari =
        [
            new BasvuruOrtaklikDosya { dosyaNo = 1, dosyaTuru = T("Basvuru.Documents.Required.1") },
            new BasvuruOrtaklikDosya { dosyaNo = 2, dosyaTuru = T("Basvuru.Documents.Required.2") },
            new BasvuruOrtaklikDosya { dosyaNo = 3, dosyaTuru = T("Basvuru.Documents.Required.3") },
            new BasvuruOrtaklikDosya { dosyaNo = 4, dosyaTuru = T("Basvuru.Documents.Required.4") },
            new BasvuruOrtaklikDosya { dosyaNo = 5, dosyaTuru = T("Basvuru.Documents.Required.5") },
            new BasvuruOrtaklikDosya { dosyaNo = 6, dosyaTuru = T("Basvuru.Documents.Required.6") },
            new BasvuruOrtaklikDosya { dosyaNo = 7, dosyaTuru = T("Basvuru.Documents.Required.7") }
        ];
    }
    string relatedClass = ortaklik.bagliOrtakIsletmeVarMi == true ? "" : "d-none";
    string initialJson = JsonSerializer.Serialize(ortaklik);
    string dosyaYok = L["Basvuru.Documents.NoFileSelected"].Value;
    int donemYil = b.basvuruFirma.donem?.yil ?? 0;
    if (donemYil <= 0 && b.basvuruFirma.donemId > 0)
    {
        donemYil = Model.Donemler?.FirstOrDefault(x => x.id == b.basvuruFirma.donemId)?.yil ?? 0;
    }
    string oncekiMaliYil = donemYil > 0 ? (donemYil - 2).ToString() : T("Basvuru.Mali.PreviousYear");
    string sonMaliYil = donemYil > 0 ? (donemYil - 1).ToString() : T("Basvuru.Mali.LatestYear");
}
<section class="basvuru-panel active" data-panel="9">
    <h2>@L["Basvuru.Ortaklik.Title"]</h2>
    <p class="lead">@L["Basvuru.Ortaklik.Lead"]</p>

    <script type="application/json" id="ortaklikInitialJson">@Html.Raw(initialJson)</script>

    <div class="form-grid">
        <label>
            @L["Basvuru.Field.BagliOrtakIsletmeVarMi"]
            <select id="hasRelatedEnterprise" name="Basvuru.ortaklik.BagliOrtakIsletmeVarMi" disabled="@ro">
                <option value="">@L["Basvuru.Common.Select"]</option>
                <option value="true" selected="@(ortaklik.bagliOrtakIsletmeVarMi == true)">@L["Basvuru.Common.YesAnswer"]</option>
                <option value="false" selected="@(ortaklik.bagliOrtakIsletmeVarMi == false)">@L["Basvuru.Common.NoAnswer"]</option>
            </select>
        </label>
        <label>
            @L["Basvuru.Ortaklik.PrivateShareCalculated"]
            <input id="privateShareCalculated" name="Basvuru.ortaklik.OzelSektorPayi" value="@ortaklik.ozelSektorPayi" readonly />
        </label>
    </div>

    <h3 class="subhead">@L["Basvuru.Ortaklik.PartnersTableTitle"]</h3>
    <div id="partnersTable" class="partners-table-wrap"></div>
    @if (!ro)
    {
        <button type="button" class="btn btn-outline-primary no-print" id="ortakEkleBtn">@L["Basvuru.Ortaklik.AddPartner"]</button>
    }

    <div id="partnerAlerts" class="mt-3"></div>
    <div id="legalPartnerFinancials" class="mt-3"></div>

    <div id="relatedEnterpriseBox" class="box related-enterprise-box @relatedClass">
        <h3 class="subhead mt-0">@L["Basvuru.Ortaklik.RelatedEnterpriseTitle"]</h3>
        <p class="mini">@L["Basvuru.Ortaklik.RelatedEnterpriseNote"]</p>
        <div class="form-grid">
            <label>@L["Basvuru.Ortaklik.RelatedEnterpriseTitleField"]<input id="relatedTitle" name="Basvuru.ortaklik.BagliOrtakUnvani" value="@ortaklik.bagliOrtakUnvani" disabled="@ro" /></label>
            <label>@L["Basvuru.Ortaklik.RelatedEnterpriseIdentityField"]<input id="relatedId" name="Basvuru.ortaklik.BagliOrtakKimlikNo" value="@ortaklik.bagliOrtakKimlikNo" disabled="@ro" /></label>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered mali-table">
                <thead>
                    <tr>
                        <th>@L["Basvuru.Mali.FinancialDataItem"]</th>
                        <th>@oncekiMaliYil</th>
                        <th>@sonMaliYil</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@L["Basvuru.Mali.YillikNetSatisHasilati"]</td>
                        <td><input id="relPrevNetSales" class="money-integer" name="Basvuru.ortaklik.BagliOrtakOncekiYilNetSatis" value="@ortaklik.bagliOrtakOncekiYilNetSatis" disabled="@ro" /></td>
                        <td><input id="relLastNetSales" class="money-integer" name="Basvuru.ortaklik.BagliOrtakSonYilNetSatis" value="@ortaklik.bagliOrtakSonYilNetSatis" disabled="@ro" /></td>
                    </tr>
                    <tr>
                        <td>@L["Basvuru.Mali.AktifToplami"]</td>
                        <td><input id="relPrevAssets" class="money-integer" name="Basvuru.ortaklik.BagliOrtakOncekiYilAktifToplami" value="@ortaklik.bagliOrtakOncekiYilAktifToplami" disabled="@ro" /></td>
                        <td><input id="relLastAssets" class="money-integer" name="Basvuru.ortaklik.BagliOrtakSonYilAktifToplami" value="@ortaklik.bagliOrtakSonYilAktifToplami" disabled="@ro" /></td>
                    </tr>
                </tbody>
            </table>
        </div>
        <h4>@L["Basvuru.Ortaklik.RelatedDocumentsTitle"]</h4>
        <div id="relatedDocs" class="table-responsive">
            <table class="table table-bordered ortak-doc-table">
                <thead>
                    <tr>
                        <th>@L["Basvuru.Documents.FileType"]</th>
                        <th>@L["Basvuru.Documents.FileName"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (BasvuruOrtaklikDosya belge in ortaklik.bagliOrtakDosyalari)
                    {
                        string inputId = $"bagliOrtakDosya_{belge.dosyaNo}";
                        string fileNameId = $"bagliOrtakDosyaAdi_{belge.dosyaNo}";
                        string downloadId = $"bagliOrtakIndir_{belge.dosyaNo}";
                        <tr>
                            <td>@belge.dosyaTuru</td>
                            <td id="@fileNameId">@(string.IsNullOrWhiteSpace(belge.dosyaAdi) ? dosyaYok : belge.dosyaAdi)</td>
                            <td class="text-nowrap">
                                @if (!ro)
                                {
                                    <label class="btn btn-sm btn-primary mb-0" for="@inputId">@L["Basvuru.Documents.Upload"]</label>
                                    <input id="@inputId" type="file" class="document-file-input ortaklik-dosya-input" data-form-ad="Basvuru_BagliBelge" data-dosya-no="@belge.dosyaNo" data-name-target="@fileNameId" data-download-target="@downloadId" />
                                }
                                <a class="btn btn-sm btn-outline-primary @(belge.dosyaId.HasValue ? "" : "d-none")"
                                   id="@downloadId"
                                   href="@(belge.dosyaId.HasValue ? Url.Action("DosyaIndir", "Basvuru", new { id = belge.dosyaId.Value }) : "#")"
                                   target="_blank"
                                   rel="noopener">@L["Basvuru.Common.Download"]</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
