            belgeYuklemeSonucGoster(sonuc, 'Basvuru.TaahhutDosyaId', 'Basvuru.TaahhutDosyaAdi', 'taahhutIndirBtn');
            if (sonuc && sonuc.basarili) {
                const nesne = sonuc.nesne || sonuc.Nesne || {};
                const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
                if (dosyaAdi) $('#taahhutDosyaSecim').text(dosyaAdi);
                dirty = false;
            }
        });
