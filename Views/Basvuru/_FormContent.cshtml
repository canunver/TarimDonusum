            { group: 'Genel Yönetim Giderleri', item: 'Personel Giderleri', qty: '', unit: 'Kişi/Yıl', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Genel Yönetim Giderleri', item: 'Haberleşme Giderleri', qty: '', unit: 'Yıl', unitPrice: '', fixedPct: '0', variablePct: '100' },
