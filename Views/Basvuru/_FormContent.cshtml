<script>
    var active=1;
    const adresBosMesaj = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.Empty")));
    const adresSilOnay = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.DeleteConfirm")));
    function modalValue(id) {
        return document.getElementById(id)?.value || '';
    }

    var uygulamaAdresModal;
    var firmaModal;
    document.addEventListener('DOMContentLoaded', () => {
        active = 1;
        const lastStep = @sonBolum;
        let locked = @(kilitli ? "true" : "false");
        const lockedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.LockedMessage")));
        const unsavedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.UnsavedMessage")));
        const stepSelect = document.getElementById('basvuruStepSelect');
        stepSelect?.addEventListener('change', () => show(Number(stepSelect.value)));
        document.querySelectorAll('.nav-prev').forEach(btn => btn.addEventListener('click', () => show(active - 1)));
        document.querySelectorAll('.nav-next').forEach(btn => btn.addEventListener('click', () => show(active + 1)));
        let dirty = false;
        document.getElementById('adresYeniBtn')?.addEventListener('click', () => adresModalAc(-1));

        uygulamaAdresModal = new bootstrap.Modal(
            document.getElementById('uygulamaAdresModal')
        );

        firmaModal = new bootstrap.Modal(
            document.getElementById('firmaModal')
        );

        document.querySelectorAll('.firma-modal-kapat').forEach(btn => {
            btn.addEventListener('click', () => firmaModal?.hide());
        });

        function setFirma(firma) {
            $("#firmaId").val(firma.id);
            $("#vergiKimlikNo").val(firma.vergiKimlikNo);
            $("#firmaAdi").val(firma.ticaretUnvani);
            dirty = true;
        }

        function modalSet(id, value) {
            const el = document.getElementById(id);
            if (el) el.value = value || '';
        
            if (el.type === "date" && value) {
                el.value = value.substring(0, 10);
            } 
            else {
                el.value = value || '';
            }
        }

        function firmaModalDoldur(firma) {
            modalSet('modalFirmaId',  firma.id);
            modalSet('modalVergiKimlikNo',  firma.vergiKimlikNo);
            modalSet('modalTicaretUnvani', firma.ticaretUnvani);
            modalSet('modalTicaretSicilNo', firma.ticaretSicilNo);
            modalSet('modalKurulusTarihi', firma.kurulusTarihi);
            modalSet('modalMersisNo', firma.mersisNo);
            modalSet('modalNaceKodu', firma.naceKodu);
            modalSet('modalWebSitesi', firma.webSitesi);
            modalSet('modalTelefon', firma.telefon);
            modalSet('modalKepAdresi', firma.kepAdresi);
            modalSet('modalEposta', firma.eposta);
            modalSet('modalFaaliyetKonusu', firma.faaliyetKonusu);
            modalSet('modalAdres', firma.adres);
            document.getElementById('firmaModalHata').textContent = '';
        }

        function FirmaBilgiYaz(result)
        {
            if (!result.basarili) {
                alert(result.hataStr );
                return;
            }
            if(result.nesne)
                setFirma(result.nesne);
            else
            {
                if (confirm(result.mesaj || @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.CreateQuestion"))))) {
                    firmaModalDoldur({ vergiKimlikNo: vergiNo });
                    firmaModal?.show();
                }
            }
        }

        function FirmaBilgiDoldur(result)
        {
            console.log(result);
            if (!result.basarili) {
                alert(result.hataStr );
                return;
            }
            if(result.nesne)
                firmaModalDoldur(result.nesne);


            firmaModal?.show();
        }

        document.getElementById('firmaSorgulaBtn')?.addEventListener('click', async () => {
            AjaxGet("/Basvuru/FirmaSorgula", {vergiKimlikNo: $("#vergiKimlikNo").val(), id: 0}, FirmaBilgiYaz);
        });

        document.getElementById('firmaYeniBtn')?.addEventListener('click', () => {
            firmaModalDoldur({id:0, vergiKimlikNo: $("#vergiKimlikNo").val() || '' });
            firmaModal?.show();
        });

        document.getElementById('firmaDuzenleBtn')?.addEventListener('click', () => {
            const id = firmaId?.value || '';
            if (!id) {
                alert(@Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.SelectFirst"))));
                return;
            }
            AjaxGet("/Basvuru/FirmaSorgula", {vergiKimlikNo:$("#vergiKimlikNo").val(), id:0}, FirmaBilgiDoldur);
        });

        document.getElementById('firmaKaydetBtn')?.addEventListener('click', async () => {
            var firma = {
                'id':  modalValue('hdnFirmaId'),
                'vergiKimlikNo': modalValue('modalVergiKimlikNo'),
                'ticaretUnvani': modalValue('modalTicaretUnvani'),
                'ticaretSicilNo': modalValue('modalTicaretSicilNo'),
                'kurulusTarihi': modalValue('modalKurulusTarihi'),
                'mersisNo': modalValue('modalMersisNo'),
                'naceKodu': modalValue('modalNaceKodu'),
                'webSitesi': modalValue('modalWebSitesi'),
                'telefon': modalValue('modalTelefon'),
                'kepAdresi': modalValue('modalKepAdresi'),
                'eposta': modalValue('modalEposta'),
                'faaliyetKonusu': modalValue('modalFaaliyetKonusu'),
                'adres': modalValue('modalAdres') 
            }
            AjaxPost("/Basvuru/FirmaKaydet", firma, SonucGosterGizle)
        });

        document.getElementById('belgePaketiDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'belgePaketiDosyaSecim', 'Basvuru.BelgePaketiDosyaAdi');
        });

        document.getElementById('taahhutDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'taahhutDosyaSecim', 'Basvuru.TaahhutDosyaAdi');
        });

        document.getElementById('belgePaketiYukleBtn')?.addEventListener('click', BelgePaketiYukle);
        document.getElementById('taahhutYukleBtn')?.addEventListener('click', TaahhutDosyasiYukle);

        //    setFirma(result.firma);
        //    firmaModal?.hide();
        //    basvuruMesajGoster(firmaModalModu === 'duzenle'
        //        ? @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.Updated")))
        //        : @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.Saved"))));

        // $.querySelectorAll('input[name], select[name], textarea[name]').forEach(el => {
        //     if (el.type === 'hidden' || el.name === '__RequestVerificationToken')
        //         return;

        //     el.addEventListener('change', () => dirty = true);
        //     el.addEventListener('input', () => dirty = true);
        // });

        function show(step) {
            if (locked && step > 1) {
                alert(lockedMessage);
                return;
            }
            if (step < 1 || step > lastStep) return;
            if (dirty && !confirm(unsavedMessage)) {
                if (stepSelect) stepSelect.value = String(active);
                return;
            }

            active = step;
            dirty = false;
            if (stepSelect) stepSelect.value = String(active);
            document.querySelectorAll('.basvuru-panel').forEach(x => x.classList.toggle('active', x.dataset.panel == step));
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Seçilen Değer Zincirine göre Tabloyu dolduran fonksiyon
        function degerZinciriAsamalariYukle(zincirId) {
            var formId = degerInt('Basvuru.Id');
            const $tbody = $('#degerZinciriAsamaListesi');
            $tbody.empty(); // Temizle

            if (!zincirId) return;

            // formId'yi de parametre olarak gönderiyoruz
            AjaxGet('/Basvuru/DegerZinciriAsamalariListele', { zincirId: zincirId, basvuruId: formId }, function (response) {
                if (response && response.nesne) {
                    const isReadOnly = $('#degerZinciriSelect').is(':disabled') ? 'disabled' : '';

                    $.each(response.nesne, function (index, item) {
                        // C# tarafı checked dediyse işaretliyoruz
                        const checkedAttr = item.secili ? 'checked="checked"' : '';

                        const row = `
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" name="Basvuru.DegerZinciriAsamalari" value="${item.id}" ${checkedAttr} ${isReadOnly} />
                                </td>
                                <td><strong>${item.ad}</strong></td>
                                <td>${item.aciklama ?? ''}</td>
                            </tr>
                        `;
                        $tbody.append(row);
                    });
                } else {
                    $tbody.append('<tr><td colspan="3" class="text-center text-muted">Bu değer zincirine ait aşama bulunamadı.</td></tr>');
                }
            });
        }

        function degerZinciriYukle() {
            var ilId= $("#basvuruIl").val();
            formId = degerInt('Basvuru.Id')

            const $select = $('#degerZinciriSelect');
            $select.html('<option value="">Seçiniz...</option>'); // Temizle
            $('#degerZinciriAsamaListesi').empty(); // Eski aşamaları sil

            if (!ilId) return;

            // formId'yi de parametre olarak gönderiyoruz
            AjaxGet('/Basvuru/DegerZincirleriListele', { ilId: ilId, basvuruId: formId }, function (response) {
                console.log(response);
                if (response && response.nesne) {
                    let aktifZincirId = null;

                    $.each(response.nesne, function (index, item) {
                        // Eğer C# tarafı bu kayıt için true döndüyse 'selected' özniteliğini ekliyoruz
                        const selectedAttr = item.secili ? 'selected="selected"' : '';
                        $select.append(`<option value="${item.id}" ${selectedAttr}>${item.ad}</option>`);
                
                        if (item.secili) {
                            aktifZincirId = item.id;
                        }
                    });

                    // Eğer veritabanından seçili bir zincir geldiyse, onun aşamalarını da otomatik yükle
                    if (aktifZincirId) {
                        degerZinciriAsamalariYukle(aktifZincirId);
                    }
                }
            });
        }

        $('[name="Basvuru.IlId"]').on('change', function () {
            degerZinciriYukle();
        });

        // 2. Değer Zinciri değiştiğinde Aşamaları yükle
        $('#degerZinciriSelect').on('change', function () {
            degerZinciriAsamalariYukle($(this).val());
        });

        document.getElementById('adresKaydetBtn')?.addEventListener('click', async () => {
            const indexText = modalValue('adresModalIndex');
            const mevcutAdres = indexText === '' ? {} : sonUygulamaAdresleri[Number(indexText)];
            const seciliIlceId = Number(modalValue('adresModalIlce') || 0) || null;
            const adres = {
                id: mevcutAdres?.id || 0,
                basvuruId: degerInt('Basvuru.Id'),
                siraNo: Number(modalValue('adresModalSiraNo') || 0) || 1,
                ilceId: seciliIlceId,
                tamAdres: modalValue('adresModalTamAdres'),
                yatirimYeriStatusu: Number(modalValue('adresModalYatirimYeriStatusu') || 0) || null,
                kiraVeyaTahsisSuresi: Number(modalValue('adresModalKiraVeyaTahsisSuresi') || 0) || null,
                kiraTahsisBitisTarihi: modalValue('adresModalKiraTahsisBitisTarihi'),
                yapiRuhsatiDurumu: Number(modalValue('adresModalYapiRuhsatiDurumu') || 0) || null
            };

            adresKaydet(adres);
        });
        ParaTamsayiAyarla();
        degerZinciriYukle();
        UygulamaAdresleriListele();
    });

    function SonucGoster(sonuc)
    {
        if (sonuc.basarili) {
            PopupMesajGoster(sonuc.mesaj, true);
        } else {
            PopupMesajGoster(sonuc.hataStr, false);
        }
    }

    function SonucGosterGizle(sonuc)
    {
        UygulamaAdresleriListele();
        uygulamaAdresModal.hide();
        SonucGoster(sonuc);
    }

    function adresKaydet(adres) {
        AjaxPost('/Basvuru/UygulamaAdresiKaydet', adres, SonucGosterGizle);
    }

    function adresSil(adresId) {
        if (!adresId) return;
        AjaxPost('/Basvuru/UygulamaAdresiSil', {id: adresId}, SonucGosterGizle);
    }

    function FirmaIrtibatKaydet() {
        const model = {
            "basvuruId": degerInt('Basvuru.Id'),
            "kisi":  degerStr('Basvuru.irtibat.kisi'),
            "unvan": degerStr('Basvuru.irtibat.unvan'),
            "telefon": degerStr('Basvuru.irtibat.telefon'),
            "ePosta": degerStr('Basvuru.irtibat.ePosta'),
            "adres": degerStr('Basvuru.irtibat.adres'),
            "yetkiliKisiler": degerStr('Basvuru.irtibat.yetkiliKisiler'),
        };
        AjaxPost('/Basvuru/KaydetIrtibat', model, SonucGoster);
    }

    function FirmaBasvuruKaydet() {
        const basvuruFirma = {
            "id": degerInt('Basvuru.Id'),
            "firmaId":  degerInt('Basvuru.FirmaId'),
            "donemId": degerInt('Basvuru.DonemId'),
            "ilId": degerInt('Basvuru.IlId'),
            "basvuruKonusu": degerStr('Basvuru.BasvuruKonusu'),
            "sonIkiYildirFaalMi": degerBool('Basvuru.SonIkiYildirFaalMi'),
            "basvuruSahibiTuru": degerInt('Basvuru.BasvuruSahibiTuru'),
            "ozelSektorPayi": degerDec('Basvuru.OzelSektorPayi'),
            "bagliOrtakIsletmeVarMi": degerBool('Basvuru.BagliOrtakIsletmeVarMi'),
            "bagliOrtakAciklama": degerStr('Basvuru.BagliOrtakAciklama')
        };
        AjaxPost('/Basvuru/KaydetFirmaBasvuru', 
            basvuruFirma, 
            SonucGoster
        );
    }

    function YatirimKaydet()
    {
        const yatirim = {
            "basvuruId": degerInt('Basvuru.Id'),
            "yatirimAdi": degerStr('Basvuru.YatirimAdi'),
            "yatirimTuru": degerInt('Basvuru.yatirim.yatirimTuru'),
            "harcamaTurleri": $('input[name="Basvuru.yatirim.harcamaTurleri"]:checked').map(function () { return parseInt(this.value);}).get(),
            "degerZinciriAsamalari":  $('input[name="Basvuru.DegerZinciriAsamalari"]:checked').map(
                function ()  {
                    return {
                        id: parseInt(this.value)
                    };
                }
            ).get()};
        AjaxPost('/Basvuru/KaydetYatirim', 
            yatirim, 
            SonucGoster
        );
    }

    function FinansKaydet()
    {
        const model = {
            "basvuruId": degerInt('Basvuru.Id'),
            "toplamYatirimTutari":  degerDec('Basvuru.finans.ToplamYatirimTutari'),
            "uygunHarcamaTutari": degerDec('Basvuru.finans.UygunHarcamaTutari'),
            "talepEdilenDestekTutari": degerDec('Basvuru.finans.TalepEdilenDestekTutari'),
            "basvuruSahibiKatkisi": degerDec('Basvuru.finans.BasvuruSahibiKatkisi'),
            "destekOrani": degerDec('Basvuru.finans.DestekOrani'),
            "yatiriminAmaci": degerStr('Basvuru.finans.YatiriminAmaci'),
        };
        AjaxPost('/Basvuru/KaydetFinans', model, SonucGoster);
    }

    function MaliKaydet()
    {
        const model = {
            "basvuruId": degerInt('Basvuru.Id'),
            "oncekiYilNetSatis": degerDec('Basvuru.mali.OncekiYilNetSatis'),
            "sonYilNetSatis": degerDec('Basvuru.mali.SonYilNetSatis'),
            "oncekiYilAktifToplami": degerDec('Basvuru.mali.OncekiYilAktifToplami'),
            "sonYilAktifToplami": degerDec('Basvuru.mali.SonYilAktifToplami'),
        };
        AjaxPost('/Basvuru/KaydetMali', model, SonucGoster);
    }

    function antiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    function dosyaSecimYaz(input, hedefId, dosyaAdiInputName) {
        const dosyaAdi = input.files && input.files.length ? input.files[0].name : 'Henüz dosya seçilmedi.';
        const hedef = document.getElementById(hedefId);
        if (hedef) hedef.textContent = dosyaAdi;
        const dosyaAdiInput = document.querySelector(`[name="${dosyaAdiInputName}"]`);
        if (dosyaAdiInput && input.files && input.files.length) dosyaAdiInput.value = dosyaAdi;
    }

    function belgePaketiDogrula() {
        const dosya = document.getElementById('belgePaketiDosya');
        const tumBelgelerSecili = $('.belge-grubu-check').length > 0
            && $('.belge-grubu-check').length === $('.belge-grubu-check:checked').length;
        const beyanEvet = $('#belgeBeyaniSelect').val() === 'Evet';
        const aciklamaDolu = degerStr('Basvuru.BelgePaketiAciklama').length > 0;

        if (!dosya || !dosya.files || dosya.files.length === 0) {
            PopupMesajGoster('Doküman paketi dosyası seçilmelidir.', false);
            return false;
        }
        if (!tumBelgelerSecili) {
            PopupMesajGoster('Zorunlu belge gruplarının tamamı işaretlenmelidir.', false);
            return false;
        }
        if (!beyanEvet) {
            PopupMesajGoster('Belge beyanı Evet olmalıdır.', false);
            return false;
        }
        if (!aciklamaDolu) {
            PopupMesajGoster('Belge açıklaması girilmelidir.', false);
            return false;
        }

        return true;
    }

    function BelgePaketiYukle() {
        if (!belgePaketiDogrula()) return;

        const dosya = document.getElementById('belgePaketiDosya').files[0];
        const data = new FormData();
        data.append('basvuruId', degerInt('Basvuru.Id') || 0);
        data.append('aciklama', degerStr('Basvuru.BelgePaketiAciklama'));
        data.append('belgeBeyani', 'true');
        data.append('dosya', dosya);
        data.append('__RequestVerificationToken', antiForgeryToken());

        DosyaAjaxPost('/Basvuru/BelgePaketiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.BelgePaketiDosyaId', 'Basvuru.BelgePaketiDosyaAdi', 'belgePaketiIndirBtn');
        });
    }

    function TaahhutDosyasiYukle() {
        const dosyaInput = document.getElementById('taahhutDosya');
        if (!dosyaInput || !dosyaInput.files || dosyaInput.files.length === 0) {
            PopupMesajGoster('Taahhüt dosyası seçilmelidir.', false);
            return;
        }
        if (degerStr('Basvuru.TaahhutAciklama').length === 0) {
            PopupMesajGoster('Taahhüt açıklaması girilmelidir.', false);
            return;
        }

        const data = new FormData();
        data.append('basvuruId', degerInt('Basvuru.Id') || 0);
        data.append('aciklama', degerStr('Basvuru.TaahhutAciklama'));
        data.append('dosya', dosyaInput.files[0]);
        data.append('__RequestVerificationToken', antiForgeryToken());

        DosyaAjaxPost('/Basvuru/TaahhutDosyasiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.TaahhutDosyaId', 'Basvuru.TaahhutDosyaAdi', 'taahhutIndirBtn');
        });
    }

    function DosyaAjaxPost(url, data, success) {
        $.ajax({
            url: url,
            type: 'POST',
            data: data,
            processData: false,
            contentType: false,
            dataType: 'json',
            headers: {
                'RequestVerificationToken': antiForgeryToken()
            }
        })
            .done(function (result) {
                if (success) success(result);
            })
            .fail(function (xhr) {
                console.error('Dosya yükleme hatası:', xhr);
                PopupMesajGoster('Dosya yüklenemedi.', false);
            });
    }

    function belgeYuklemeSonucGoster(sonuc, dosyaIdInputName, dosyaAdiInputName, indirLinkId) {
        if (!sonuc || !sonuc.basarili) {
            PopupMesajGoster((sonuc && (sonuc.hataStr || sonuc.mesaj)) || 'Dosya yüklenemedi.', false);
            return;
        }

        const nesne = sonuc.nesne || sonuc.Nesne || {};
        const dosyaId = nesne.dosyaId || nesne.DosyaId || '';
        const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
        $(`[name="${dosyaIdInputName}"]`).val(dosyaId);
        if (dosyaAdi) $(`[name="${dosyaAdiInputName}"]`).val(dosyaAdi);
        if (dosyaId && indirLinkId) {
            const indirLink = document.getElementById(indirLinkId);
            if (indirLink) {
                indirLink.href = `/Basvuru/DosyaIndir/${dosyaId}`;
                indirLink.classList.remove('d-none');
            }
        }
        PopupMesajGoster(sonuc.mesaj || 'Dosya yüklendi.', true);
    }

    function PaneliKaydet()
    {
        if(active == 1)
            FirmaBasvuruKaydet()
        else if(active == 2)
            FirmaIrtibatKaydet()
        else if(active == 3)
            YatirimKaydet()
        else if(active == 5)
            FinansKaydet()
        else if(active == 6)
            MaliKaydet()
        else if(active == 7)
            PopupMesajGoster('Belge yükleme işlemleri ilgili dosya butonları ile yapılır.', true)
        else
            alert(active);
    }
    
    function UygulamaAdresleriListele() {
        const formId = degerInt('Basvuru.Id');
        AjaxGet('/Basvuru/UygulamaAdresiListele', { basvuruId: formId },
            function (response) {
                RenderUygulamaAdresleri(response.nesne);
            }
        );
    }

    var sonUygulamaAdresleri;

    function modalOlustur(element) {
        if (!element) return null;
        return {
            show: () => window.jQuery(element).modal('show'),
            hide: () => window.jQuery(element).modal('hide')
        };
    }

    function adresModalAc(index) {
        const adres = index >= 0 ? sonUygulamaAdresleri[index] : {};
        modalSet('adresModalIndex', index >= 0 ? String(index) : '');
        modalSet('adresModalSiraNo', adres.siraNo);
        modalSet('adresModalIl', adres.ilId);
        modalSet('adresModalIlce', adres.ilceId);
        modalSet('adresModalTamAdres', adres.tamAdres);
        modalSet('adresModalYatirimYeriStatusu', adres.yatirimYeriStatusu);
        modalSet('adresModalKiraVeyaTahsisSuresi', adres.kiraVeyaTahsisSuresi);
        modalSet('adresModalKiraTahsisBitisTarihi', adres.kiraTahsisBitisTarihi);
        modalSet('adresModalYapiRuhsatiDurumu', adres.yapiRuhsatiDurumu);
        uygulamaAdresModal.show();
    }

    function RenderUygulamaAdresleri(uygulamaAdresleri) {
        const uygulamaAdresListesi = document.getElementById("uygulamaAdresListesi");
        if (!uygulamaAdresListesi) return;
        uygulamaAdresleri = uygulamaAdresleri || [];
        sonUygulamaAdresleri = uygulamaAdresleri;
        uygulamaAdresListesi.innerHTML = '';

        if (uygulamaAdresleri.length === 0) {
            const tr = document.createElement('tr');
            const td = document.createElement('td');
            td.colSpan = "7"; //at(ro ? "7" : "8");
            td.className = 'text-muted text-center';
            td.textContent = adresBosMesaj;
            tr.appendChild(td);
            uygulamaAdresListesi.appendChild(tr);
            return;
        }

        uygulamaAdresleri.forEach((adres, index) => {
            const tr = document.createElement('tr');
            const alanlar = [
                String(adres.siraNo),
                adres.ilAdi,
                adres.ilceAdi,
                adres.tamAdres,
                adres.yatirimYeriStatusuAd,
                adres.kiraTahsisBitis,
                adres.yapiRuhsatiDurumuAd 
            ];

            alanlar.forEach((value, alanIndex) => {
                const td = document.createElement('td');
                td.textContent = value || '';
                if (alanIndex === 3) td.className = 'adres-tam-adres';
                tr.appendChild(td);
            });

            const actionTd = document.createElement('td');
            const editBtn = document.createElement('button');
            const deleteBtn = document.createElement('button');

            editBtn.type = 'button';
            editBtn.className = 'btn btn-sm btn-outline-secondary mr-1';
            editBtn.innerHTML = '<i class="fas fa-edit"></i>';
            editBtn.addEventListener('click', () => adresModalAc(index));

            deleteBtn.type = 'button';
            deleteBtn.className = 'btn btn-sm btn-outline-danger';
            deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
            deleteBtn.addEventListener('click', async () => {
                if (!confirm(adresSilOnay)) return;
                adresSil(adres.id);
            });

            actionTd.appendChild(editBtn);
            actionTd.appendChild(deleteBtn);
            tr.appendChild(actionTd);

            uygulamaAdresListesi.appendChild(tr);
        });
    }
</script>
