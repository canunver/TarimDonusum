    let locked = @(kilitli ? "true" : "false");
    let dirty = false;
    var uygulamaAdresModal;
    var firmaModal;
    var ortakModal;
    var adliSicilModal;
    var sonUygulamaAdresleri = [];
    var basvuruOrtaklari = [];
    var basvuruAdliSicilKisileri = [];
    var pikkEquipmentRows = [];
    var pikkConstructionRows = [];
    var yatirimOzetiBudgetData = {};
    var yatirimOzetiUrunRows = [];
    var yatirimOzetiGiderRows = [];

    document.addEventListener('DOMContentLoaded', () => {
        uygulamaAdresModal = modalOlustur(document.getElementById('uygulamaAdresModal'));
        firmaModal = modalOlustur(document.getElementById('firmaModal'));
        ortakModal = modalOlustur(document.getElementById('ortakModal'));
        adliSicilModal = modalOlustur(document.getElementById('adliSicilModal'));

        document.querySelectorAll('.firma-modal-kapat').forEach(btn => btn.addEventListener('click', () => firmaModal?.hide()));
        document.querySelectorAll('.uygulama-adres-modal-kapat').forEach(btn => btn.addEventListener('click', () => uygulamaAdresModal?.hide()));
        document.querySelectorAll('.ortak-modal-kapat').forEach(btn => btn.addEventListener('click', () => ortakModal?.hide()));
        document.querySelectorAll('.adli-sicil-modal-kapat').forEach(btn => btn.addEventListener('click', () => adliSicilModal?.hide()));

        const stepSelect = document.getElementById('basvuruStepSelect');
        stepSelect?.addEventListener('change', () => BasvuruBolumGoster(Number(stepSelect.value)));
        document.querySelectorAll('.nav-prev').forEach(btn => btn.addEventListener('click', () => BasvuruBolumGoster(KomsuBolum(-1))));
        document.querySelectorAll('.nav-next').forEach(btn => btn.addEventListener('click', () => BasvuruBolumGoster(KomsuBolum(1))));
        document.querySelectorAll('.footer-prev').forEach(btn => btn.addEventListener('click', () => BasvuruBolumGoster(KomsuBolum(-1))));
        document.getElementById('footerPrimaryBtn')?.addEventListener('click', FooterBirincilAksiyon);

        document.getElementById('firmaKaydetBtn')?.addEventListener('click', FirmaKaydetModal);
        document.getElementById('adresKaydetBtn')?.addEventListener('click', UygulamaAdresiModalKaydet);
        document.getElementById('ortakKaydetBtn')?.addEventListener('click', OrtakModalKaydet);
        document.getElementById('ortakUboKycDosya')?.addEventListener('change', OrtakModalUboKycDosyasiYukle);
        document.getElementById('adliSicilKaydetBtn')?.addEventListener('click', AdliSicilModalKaydet);
        document.getElementById('adliSicilDosya')?.addEventListener('change', AdliSicilDosyasiYukle);

        BasvuruBolumIlklendir(active);
        BasvuruAksiyonButonlariGuncelle();
    });

    function modalOlustur(element) {
        if (!element) return null;
        if (window.bootstrap?.Modal) return new bootstrap.Modal(element);
        return {
            show: () => window.jQuery(element).modal('show'),
            hide: () => window.jQuery(element).modal('hide')
        };
    }

    function modalValue(id) {
        return document.getElementById(id)?.value || '';
    }

    function BasvuruId() {
        return degerInt('Basvuru.Id') || 0;
    }

    function BasvuruKimlikleri() {
        return {
            basvuruId: BasvuruId()
        };
    }

    function modalSet(id, value) {
        const el = document.getElementById(id);
        if (!el) return;
        if (el.type === 'date' && value) {
            el.value = String(value).substring(0, 10);
            return;
        }
        el.value = value || '';
    }

    function KomsuBolum(yon) {
        const index = basvuruBolumleri.indexOf(active);
        if (index < 0) return active;
        return basvuruBolumleri[index + yon] || active;
    }

    function BasvuruBolumGoster(bolum) {
        if (!basvuruBolumleri.includes(bolum) || bolum === active) {
            BasvuruStepSec(active);
            return;
        }
        if (locked && bolum !== bolumFirma) {
            alert(lockedMessage);
            BasvuruStepSec(active);
            return;
        }
        if (dirty && !confirm(unsavedMessage)) {
            BasvuruStepSec(active);
            return;
        }

        const container = document.getElementById('basvuruBolumContainer');
        const url = container?.dataset.url;
        if (!container || !url) return;

        $.ajax({
            url: url,
            type: 'GET',
            data: { ...BasvuruKimlikleri(), bolum: bolum },
            dataType: 'html'
        })
            .done(function (html) {
                container.innerHTML = html;
                active = bolum;
                dirty = false;
                BasvuruStepSec(active);
                BasvuruBolumIlklendir(active);
                BasvuruAksiyonButonlariGuncelle();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            })
            .fail(function () {
                PopupMesajGoster(partialLoadFailedMessage, false);
                BasvuruStepSec(active);
            });
    }

    function BasvuruStepSec(bolum) {
        const stepSelect = document.getElementById('basvuruStepSelect');
        if (stepSelect) stepSelect.value = String(bolum);
        BasvuruAksiyonButonlariGuncelle();
    }

    function BasvuruAksiyonButonlariGuncelle() {
        const kaydetBtn = document.getElementById('basvuruKaydetBtn');
        const kayitGerekir = !basvuruReadonly && BolumKayitGerektirir(active);
        const sonBolum = AktifBolumSonMu();
        if (kaydetBtn) kaydetBtn.classList.toggle('d-none', !kayitGerekir);
        const footerPrimary = document.getElementById('footerPrimaryBtn');
        if (footerPrimary) {
            footerPrimary.classList.toggle('d-none', sonBolum);
            footerPrimary.textContent = kayitGerekir ? basvuruAkisMetinleri.saveAndContinue : basvuruAkisMetinleri.continue;
        }
        document.querySelectorAll('.footer-prev').forEach(btn => btn.classList.toggle('invisible', basvuruBolumleri.indexOf(active) <= 0));
    }

    function AktifBolumSonMu() {
        return basvuruBolumleri.indexOf(active) === basvuruBolumleri.length - 1;
    }

    function BolumKayitGerektirir(bolum) {
        return [
            bolumFirma,
            bolumIrtibat,
            bolumYatirim,
            bolumUygulamaAdresi,
            bolumUygunHarcama,
            bolumFinans,
            bolumYatirimOzeti,
            bolumMali,
            bolumOrtaklik,
            bolumCevreselSosyal
        ].includes(bolum);
    }

    function FooterBirincilAksiyon() {
        if (AktifBolumSonMu()) return;
        const sonraki = KomsuBolum(1);
        if (!basvuruReadonly && BolumKayitGerektirir(active)) {
            PaneliKaydet(() => BasvuruBolumGoster(sonraki));
            return;
        }
        BasvuruBolumGoster(sonraki);
    }

    function BasvuruBolumIlklendir(bolum) {
        const container = document.getElementById('basvuruBolumContainer');
        container?.querySelectorAll('input, select, textarea').forEach(el => {
            el.addEventListener('change', () => dirty = true);
            el.addEventListener('input', () => dirty = true);
        });

        if (bolum === bolumFirma) FirmaBolumuIlklendir();
        if (bolum === bolumYatirim) YatirimBolumuIlklendir();
        if (bolum === bolumUygulamaAdresi) UygulamaAdresiBolumuIlklendir();
        if (bolum === bolumFinans || bolum === bolumMali || bolum === bolumOrtaklik) ParaTamsayiAyarla();
        if (bolum === bolumMali) MaliBolumuIlklendir();
        if (bolum === bolumOrtaklik) OrtaklikBolumuIlklendir();
        if (bolum === bolumUygunHarcama) UygunHarcamaBolumuIlklendir();
        if (bolum === bolumYatirimOzeti) YatirimOzetiBolumuIlklendir();
        if (bolum === bolumCevreselSosyal) CevreselSosyalBolumuIlklendir();
        if (bolum === bolumBelgeler || bolum === bolumTaahhutBeyan) BelgelerBolumuIlklendir();
    }

    function FirmaBolumuIlklendir() {
        document.getElementById('firmaSorgulaBtn')?.addEventListener('click', () => {
            AjaxGet('/Basvuru/FirmaSorgula', { vergiKimlikNo: $('#vergiKimlikNo').val(), id: 0 }, FirmaBilgiYaz);
        });
        document.getElementById('firmaYeniBtn')?.addEventListener('click', () => {
            firmaModalDoldur({ id: 0, vergiKimlikNo: $('#vergiKimlikNo').val() || '' });
            firmaModal?.show();
        });
        document.getElementById('firmaDuzenleBtn')?.addEventListener('click', () => {
            const id = document.getElementById('firmaId')?.value || '';
            if (!id) {
                alert(firmaSelectFirstMessage);
                return;
            }
            AjaxGet('/Basvuru/FirmaSorgula', { vergiKimlikNo: $('#vergiKimlikNo').val(), id: 0 }, FirmaBilgiDoldur);
        });
    }

    function YatirimBolumuIlklendir() {
        $('[name="Basvuru.IlId"]').off('change.basvuruBolum').on('change.basvuruBolum', degerZinciriYukle);
        $('#degerZinciriSelect').off('change.basvuruBolum').on('change.basvuruBolum', function () {
            degerZinciriAsamalariYukle($(this).val());
        });
        degerZinciriYukle();
    }

    function UygulamaAdresiBolumuIlklendir() {
        document.getElementById('adresYeniBtn')?.addEventListener('click', () => adresModalAc(-1));
        UygulamaAdresleriListele();
    }

    function BelgelerBolumuIlklendir() {
        AdliSicilInitialOku();
        document.getElementById('adliSicilKisiEkleBtn')?.addEventListener('click', () => AdliSicilModalAc(-1));
        document.querySelectorAll('.basvuru-dosya-input').forEach(input => {
            input.addEventListener('change', function () {
                BasvuruDosyasiYukle(this.dataset.formAd || zorunluBelgeFormAd, Number(this.dataset.dosyaNo || 0), this, this.dataset.nameTarget, this.dataset.downloadTarget);
            });
        });
        document.getElementById('taahhutDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'taahhutDosyaSecim', 'Basvuru.TaahhutDosyaAdi');
            TaahhutDosyasiYukle();
        });
        AdliSicilKisilerRender();
    }

    function AdliSicilInitialOku() {
        const jsonElement = document.getElementById('adliSicilInitialJson');
        if (!jsonElement) {
            basvuruAdliSicilKisileri = [];
            return;
        }

        try {
            const model = JSON.parse(jsonElement.textContent || '[]');
            basvuruAdliSicilKisileri = Array.isArray(model) ? model : [];
        }
        catch {
            basvuruAdliSicilKisileri = [];
        }
    }

    function AdliSicilModalAc(index) {
        const kisi = index >= 0 ? basvuruAdliSicilKisileri[index] : {};
        modalSet('adliSicilModalIndex', index >= 0 ? String(index) : '');
        modalSet('adliSicilTckn', kisi.tckn);
        modalSet('adliSicilAd', kisi.ad);
        modalSet('adliSicilSoyad', kisi.soyad);
        modalSet('adliSicilGorev', kisi.gorev);
        const hata = document.getElementById('adliSicilModalHata');
        if (hata) hata.textContent = '';
        AdliSicilDosyaDurumGuncelle();
        adliSicilModal?.show();
    }

    function AdliSicilModalKaydet() {
        const kisi = {
            id: mevcutAdliSicilKisiId(),
            basvuruId: BasvuruId(),
            siraNo: 0,
            tckn: modalValue('adliSicilTckn').trim(),
            ad: modalValue('adliSicilAd').trim(),
            soyad: modalValue('adliSicilSoyad').trim(),
            gorev: modalValue('adliSicilGorev'),
            dosyaAdi: mevcutAdliSicilDosyaAdi(),
            dosyaId: mevcutAdliSicilDosyaId()
        };

        const indexText = modalValue('adliSicilModalIndex');
        const oncekiTckn = indexText === '' ? '' : basvuruAdliSicilKisileri[Number(indexText)]?.tckn || '';
        if (TcknVknNormalize(oncekiTckn) && TcknVknNormalize(oncekiTckn) !== TcknVknNormalize(kisi.tckn)) {
            kisi.dosyaAdi = '';
            kisi.dosyaId = null;
        }

        if (!kisi.tckn || !kisi.ad || !kisi.soyad || !kisi.gorev) {
            const hata = document.getElementById('adliSicilModalHata');
            if (hata) hata.textContent = adliSicilMetinleri.requiredFields;
            return;
        }
        if (AyniAdliSicilTcknVarMi(kisi.tckn, indexText)) {
            const hata = document.getElementById('adliSicilModalHata');
            if (hata) hata.textContent = adliSicilMetinleri.duplicateTckn;
            return;
        }

        if (indexText === '') basvuruAdliSicilKisileri.push(kisi);
        else basvuruAdliSicilKisileri[Number(indexText)] = kisi;
        basvuruAdliSicilKisileri.forEach((item, index) => item.siraNo = index + 1);
        dirty = true;
        AdliSicilKisilerRender();
        AdliSicilKisileriKaydet(function (sonuc) {
            const kayitliListe = sonuc?.nesne || sonuc?.Nesne || basvuruAdliSicilKisileri;
            basvuruAdliSicilKisileri = Array.isArray(kayitliListe) ? kayitliListe : basvuruAdliSicilKisileri;
            const yeniIndex = basvuruAdliSicilKisileri.findIndex(x => TcknVknNormalize(x.tckn) === TcknVknNormalize(kisi.tckn));
            modalSet('adliSicilModalIndex', yeniIndex >= 0 ? String(yeniIndex) : '');
            AdliSicilKisilerRender();
            AdliSicilDosyaDurumGuncelle();
        });
    }

    function AyniAdliSicilTcknVarMi(tckn, mevcutIndexText) {
        const kimlik = TcknVknNormalize(tckn);
        const mevcutIndex = mevcutIndexText === '' ? -1 : Number(mevcutIndexText);
        return basvuruAdliSicilKisileri.some((kisi, index) =>
            index !== mevcutIndex &&
            TcknVknNormalize(kisi.tckn) === kimlik);
    }

    function AdliSicilSil(index) {
        if (basvuruReadonly) return;
        basvuruAdliSicilKisileri.splice(index, 1);
        basvuruAdliSicilKisileri.forEach((item, itemIndex) => item.siraNo = itemIndex + 1);
        dirty = true;
        AdliSicilKisilerRender();
        AdliSicilKisileriKaydet();
    }

    function AdliSicilKisilerRender() {
        const container = document.getElementById('adliSicilKisilerTable');
        if (!container) return;

        let html = `<div class="table-responsive"><table class="table table-bordered ortak-table"><thead><tr>
            <th>${htmlEncode(ortakMetinleri.rowNo)}</th><th>${htmlEncode(adliSicilMetinleri.tckn)}</th><th>${htmlEncode(adliSicilMetinleri.name)}</th><th>${htmlEncode(adliSicilMetinleri.surname)}</th><th>${htmlEncode(adliSicilMetinleri.role)}</th><th>${htmlEncode(adliSicilMetinleri.fileColumn)}</th><th>${htmlEncode(ortakMetinleri.actions)}</th>
        </tr></thead><tbody>`;

        if (basvuruAdliSicilKisileri.length === 0) {
            html += `<tr><td colspan="7" class="text-muted text-center">${htmlEncode(adliSicilMetinleri.empty)}</td></tr>`;
        }
        else {
            basvuruAdliSicilKisileri.forEach((kisi, index) => {
                const dosyaYuklu = !!kisi.dosyaId;
                const href = dosyaYuklu ? `/Basvuru/DosyaIndir/${kisi.dosyaId}` : '#';
                html += `<tr>
                    <td>${index + 1}</td>
                    <td>${htmlEncode(kisi.tckn)}</td>
                    <td>${htmlEncode(kisi.ad)}</td>
                    <td>${htmlEncode(kisi.soyad)}</td>
                    <td>${htmlEncode(kisi.gorev)}</td>
                    <td><span class="adli-sicil-file-name">${htmlEncode(dosyaYuklu ? kisi.dosyaAdi : adliSicilMetinleri.fileMissing)}</span></td>
                    <td class="text-nowrap">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="AdliSicilModalAc(${index})" ${basvuruReadonly ? 'disabled' : ''}>${htmlEncode(ortakMetinleri.edit)}</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="AdliSicilSil(${index})" ${basvuruReadonly ? 'disabled' : ''}>${htmlEncode(ortakMetinleri.delete)}</button>
                        ${dosyaYuklu ? `<a class="btn btn-sm btn-outline-primary" href="${href}" target="_blank" rel="noopener">${htmlEncode(ortakMetinleri.download)}</a>` : ''}
                    </td>
                </tr>`;
            });
        }

        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function mevcutAdliSicilKisi() {
        const indexText = modalValue('adliSicilModalIndex');
        if (indexText === '') return null;
        return basvuruAdliSicilKisileri[Number(indexText)] || null;
    }

    function mevcutAdliSicilKisiId() {
        return mevcutAdliSicilKisi()?.id || 0;
    }

    function mevcutAdliSicilDosyaId() {
        return mevcutAdliSicilKisi()?.dosyaId || null;
    }

    function mevcutAdliSicilDosyaAdi() {
        return mevcutAdliSicilKisi()?.dosyaAdi || '';
    }

    function AdliSicilDosyaDurumGuncelle() {
        const kisi = mevcutAdliSicilKisi();
        const kayitliMi = !!kisi?.id;
        const input = document.getElementById('adliSicilDosya');
        const button = document.getElementById('adliSicilDosyaSecBtn');
        const name = document.getElementById('adliSicilDosyaAdi');
        const note = document.getElementById('adliSicilDosyaNot');
        const download = document.getElementById('adliSicilIndirBtn');

        if (input) {
            input.disabled = !kayitliMi || basvuruReadonly;
            input.value = '';
        }
        button?.classList.toggle('disabled', !kayitliMi || basvuruReadonly);

        const dosyaYuklu = !!kisi?.dosyaId;
        if (name) name.textContent = dosyaYuklu ? (kisi?.dosyaAdi || '') : adliSicilMetinleri.fileMissing;
        if (note) {
            note.textContent = kayitliMi ? '' : adliSicilMetinleri.savePersonFirst;
            note.classList.toggle('d-none', kayitliMi);
        }
        if (download) {
            if (dosyaYuklu) {
                download.href = `/Basvuru/DosyaIndir/${kisi.dosyaId}`;
                download.classList.remove('d-none');
            }
            else {
                download.href = '#';
                download.classList.add('d-none');
            }
        }
    }

    function AdliSicilDosyasiYukle() {
        const input = document.getElementById('adliSicilDosya');
        const kisi = mevcutAdliSicilKisi();
        if (!kisi?.id) {
            PopupMesajGoster(adliSicilMetinleri.savePersonFirst, false);
            return;
        }

        BasvuruDosyasiYukle('Basvuru_AdliSicil', kisi.id, input, 'adliSicilDosyaAdi', 'adliSicilIndirBtn', function (sonuc) {
            const nesne = sonuc?.nesne || sonuc?.Nesne || {};
            kisi.dosyaId = nesne.dosyaId || nesne.DosyaId || null;
            kisi.dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            AdliSicilDosyaDurumGuncelle();
            AdliSicilKisilerRender();
        });
    }

    function AdliSicilKisileriKaydet(afterSuccess) {
        const model = {
            basvuruId: BasvuruId(),
            kisiler: basvuruAdliSicilKisileri
        };
        AjaxPost('/Basvuru/KaydetAdliSicilKisileri', model, function (sonuc) {
            if (sonuc && sonuc.basarili) {
                dirty = false;
                if (afterSuccess) afterSuccess(sonuc);
            }
            SonucGoster(sonuc);
        });
    }

    var cevreselSosyalSoruGruplari = [];
    var cevreselSosyalCevaplar = { mode: '', answers: {}, declaration: false };

    function CevreselSosyalBolumuIlklendir() {
        CevreselSosyalTanimlariOku();
        CevreselSosyalCevaplariOku();
        const modeSelect = document.getElementById('cevreselSosyalYatirimKapsami');
        if (modeSelect) {
            modeSelect.value = cevreselSosyalCevaplar.mode || '';
            modeSelect.addEventListener('change', CevreselSosyalKapsamGuncelle);
        }
        const beyan = document.getElementById('cevreselSosyalDogrulukBeyani');
        if (beyan) {
            beyan.checked = !!cevreselSosyalCevaplar.declaration;
            beyan.addEventListener('change', function () {
                cevreselSosyalCevaplar.declaration = this.checked;
                dirty = true;
            });
        }
        CevreselSosyalRender();
    }

    function CevreselSosyalTanimlariOku() {
        const element = document.getElementById('cevreselSosyalSoruTanimlariJson');
        if (!element) {
            cevreselSosyalSoruGruplari = [];
            return;
        }

        try {
            const parsed = JSON.parse(element.textContent || '[]');
            cevreselSosyalSoruGruplari = Array.isArray(parsed) ? parsed : [];
        }
        catch {
            cevreselSosyalSoruGruplari = [];
        }
    }

    function CevreselSosyalCevaplariOku() {
        const raw = document.getElementById('cevreselSosyalJson')?.value || '';
        cevreselSosyalCevaplar = { mode: '', answers: {}, declaration: false };
        if (!raw.trim()) return;
        try {
            const parsed = JSON.parse(raw);
            cevreselSosyalCevaplar.mode = parsed.mode || '';
            cevreselSosyalCevaplar.answers = parsed.answers && typeof parsed.answers === 'object' ? parsed.answers : {};
            cevreselSosyalCevaplar.declaration = !!parsed.declaration;
        }
        catch {
            cevreselSosyalCevaplar = { mode: '', answers: {}, declaration: false };
        }
    }

    function CevreselSosyalKapsamGuncelle() {
        cevreselSosyalCevaplar.mode = document.getElementById('cevreselSosyalYatirimKapsami')?.value || '';
        dirty = true;
        CevreselSosyalRender();
    }

    function CevreselSosyalBaglamlari() {
        const mode = document.getElementById('cevreselSosyalYatirimKapsami')?.value || cevreselSosyalCevaplar.mode || '';
        if (mode === 'existing') return ['existing'];
        if (mode === 'planned') return ['planned'];
        if (mode === 'both') return ['existing', 'planned'];
        return [];
    }

    function CevreselSosyalSoruBaglamlari(question) {
        if (question.scope === 'global') return ['global'];
        const base = CevreselSosyalBaglamlari();
        const allowed = Array.isArray(question.contexts) && question.contexts.length > 0 ? question.contexts : ['existing', 'planned'];
        return base.filter(ctx => allowed.includes(ctx));
    }

    function CevreselSosyalBaglamEtiketi(ctx) {
        if (ctx === 'global') return cevreselSosyalMetinleri.globalContext;
        return ctx === 'existing' ? cevreselSosyalMetinleri.existingContext : cevreselSosyalMetinleri.plannedContext;
    }

    function CevreselSosyalAlanId(question, ctx, field) {
        return `csf_${String(question.id || '').replace(/\./g, '_')}_${ctx}_${field}`;
    }

    function CevreselSosyalRender() {
        const container = document.getElementById('cevreselSosyalAnket');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        const modeSelect = document.getElementById('cevreselSosyalYatirimKapsami');
        if (modeSelect) modeSelect.value = cevreselSosyalCevaplar.mode || '';
        if (CevreselSosyalBaglamlari().length === 0) {
            container.innerHTML = `<div class="alert alert-warning">${htmlEncode(cevreselSosyalMetinleri.selectScopeFirst)}</div>`;
            return;
        }
        let html = `<div class="alert alert-success">${htmlEncode(cevreselSosyalMetinleri.openedBySelection)}</div>`;
        cevreselSosyalSoruGruplari.forEach(group => {
            const groupQuestions = (group.questions || []).filter(question => CevreselSosyalSoruBaglamlari(question).length > 0);
            if (groupQuestions.length === 0) return;
            html += `<details class="esf-section" open><summary>${htmlEncode(group.id)}. ${htmlEncode(group.title)}</summary><div class="esf-section-body">`;
            (group.descriptions || []).forEach(description => {
                if (description.type === 'details') {
                    html += `<div class="esf-info"><h4>${htmlEncode(description.title || '')}</h4>${description.text ? `<p>${htmlEncode(description.text)}</p>` : ''}<details><summary>${htmlEncode(cevreselSosyalMetinleri.showHideList)}</summary><ul>`;
                    (description.items || []).forEach(item => html += `<li>${htmlEncode(item)}</li>`);
                    html += '</ul></details></div>';
                }
                else {
                    html += `<div class="esf-info"><strong>${htmlEncode(cevreselSosyalMetinleri.infoLabel)}</strong> ${htmlEncode(description.text || '')}</div>`;
                }
            });
            groupQuestions.forEach(question => html += CevreselSosyalSoruHtml(question, disabled));
            html += '</div></details>';
        });
        container.innerHTML = html;
        CevreselSosyalKosulluAlanlariGuncelle();
    }

    function CevreselSosyalSoruHtml(question, disabled) {
        const contexts = CevreselSosyalSoruBaglamlari(question);
        const plannedOnly = Array.isArray(question.contexts) && question.contexts.length === 1 && question.contexts[0] === 'planned' && CevreselSosyalBaglamlari().includes('existing');
        let html = `<div class="esf-question"><div class="esf-question-title">${htmlEncode(question.id)} ${htmlEncode(question.text || '')}${question.note ? `<small>${htmlEncode(question.note)}</small>` : ''}</div>`;
        if (question.info) html += `<div class="esf-info"><strong>${htmlEncode(cevreselSosyalMetinleri.informativeNote)}</strong> ${htmlEncode(question.info)}</div>`;
        if (plannedOnly) html += `<div class="esf-hidden-note">${htmlEncode(cevreselSosyalMetinleri.plannedOnlyNote)}</div>`;
        html += `<div class="esf-cols ${contexts.length === 1 ? 'single' : ''}">`;
        contexts.forEach(ctx => {
            html += `<div class="esf-answer-box"><h4>${CevreselSosyalBaglamEtiketi(ctx)}</h4>${CevreselSosyalInputHtml(question, ctx, disabled)}<div id="${CevreselSosyalAlanId(question, ctx, 'cond')}" class="conditionalField"></div></div>`;
        });
        return html + '</div></div>';
    }

    function CevreselSosyalInputHtml(question, ctx, disabled) {
        const id = CevreselSosyalAlanId(question, ctx, 'answer');
        const value = cevreselSosyalCevaplar.answers[id] || '';
        const type = question.answerType || question.type || 'text';
        const onchange = `onchange="CevreselSosyalCevapGuncelle('${id}', this.value); CevreselSosyalKosulluAlanGuncelle('${question.id}', '${ctx}')"`;
        const oninput = `oninput="CevreselSosyalCevapGuncelle('${id}', this.value)"`;
        if (type === 'yesno') return `<select id="${id}" ${disabled} ${onchange}><option value="">${htmlEncode(cevreselSosyalMetinleri.select)}</option>${[['Evet', cevreselSosyalMetinleri.yes], ['Hayır', cevreselSosyalMetinleri.no]].map(o => `<option value="${o[0]}" ${value === o[0] ? 'selected' : ''}>${htmlEncode(o[1])}</option>`).join('')}</select>`;
        if (type === 'select') return `<select id="${id}" ${disabled} ${onchange}><option value="">${htmlEncode(cevreselSosyalMetinleri.select)}</option>${(question.options || []).map(o => `<option ${value === o ? 'selected' : ''}>${htmlEncode(o)}</option>`).join('')}</select>`;
        if (type === 'staff') return CevreselSosyalCalisanTablosuHtml(question, ctx, disabled);
        if (type === 'textarea') return `<textarea id="${id}" ${disabled} ${oninput} placeholder="${htmlEncode(question.placeholder || cevreselSosyalMetinleri.explainPlaceholder)}">${htmlEncode(value)}</textarea>`;
        if (type === 'percent') return `<input id="${id}" type="number" min="0" max="100" step="0.01" ${disabled} ${oninput} value="${htmlEncode(value)}" placeholder="%">`;
        return `<input id="${id}" ${disabled} ${oninput} value="${htmlEncode(value)}" placeholder="${htmlEncode(question.placeholder || cevreselSosyalMetinleri.textPlaceholder)}">`;
    }

    function CevreselSosyalCalisanTablosuHtml(question, ctx, disabled) {
        const groups = [
            ['dogrudan', 'Doğrudan Çalışanlar'],
            ['yuklenici', 'Yüklenici Çalışanları'],
            ['tedarikci', 'Birincil Tedarikçi Çalışanları'],
            ['gocmen', 'Göçmen Çalışanlar']
        ];
        const fields = [
            ['kadin', 'Kadın'],
            ['erkek', 'Erkek'],
            ['toplam', 'Toplam']
        ];
        let html = '<div class="staff-grid"><div class="staff-head">Çalışan Grubu</div>';
        fields.forEach(field => html += `<div class="staff-head">${field[1]}</div>`);
        groups.forEach(group => {
            html += `<strong>${group[1]}</strong>`;
            fields.forEach(field => {
                const id = CevreselSosyalAlanId(question, ctx, `${group[0]}_${field[0]}`);
                const value = cevreselSosyalCevaplar.answers[id] || '';
                html += `<input id="${id}" type="number" min="0" step="1" ${disabled} oninput="CevreselSosyalCevapGuncelle('${id}', this.value)" value="${htmlEncode(value)}">`;
            });
        });
        return html + '</div>';
    }

    function CevreselSosyalKosulluAlanlariGuncelle() {
        cevreselSosyalSoruGruplari.forEach(group => (group.questions || []).forEach(question => {
            CevreselSosyalSoruBaglamlari(question).forEach(ctx => CevreselSosyalKosulluAlanGuncelle(question.id, ctx));
        }));
    }

    function CevreselSosyalSoruBul(questionId) {
        for (const group of cevreselSosyalSoruGruplari) {
            const found = (group.questions || []).find(question => String(question.id) === String(questionId));
            if (found) return found;
        }
        return null;
    }

    function CevreselSosyalKosulluAlanGuncelle(questionId, ctx) {
        const question = CevreselSosyalSoruBul(questionId);
        if (!question) return;
        const box = document.getElementById(CevreselSosyalAlanId(question, ctx, 'cond'));
        if (!box) return;
        const answerId = CevreselSosyalAlanId(question, ctx, 'answer');
        const value = document.getElementById(answerId)?.value || '';
        const needExplain = question.alwaysExplain || (question.explainOn || []).includes(value);
        const needDoc = (question.docOn || []).includes(value);
        let html = '';
        if (question.exclusion && value === 'Evet') html += `<div class="alert alert-danger">${htmlEncode(cevreselSosyalMetinleri.exclusionWarning)}</div>`;
        if (needExplain) {
            const explainId = CevreselSosyalAlanId(question, ctx, 'explain');
            html += `<textarea id="${explainId}" placeholder="${htmlEncode(cevreselSosyalMetinleri.explainPlaceholder)}" oninput="CevreselSosyalCevapGuncelle('${explainId}', this.value)">${htmlEncode(cevreselSosyalCevaplar.answers[explainId] || '')}</textarea>`;
        }
        if (needDoc) {
            const docId = CevreselSosyalAlanId(question, ctx, 'doc');
            html += `<div class="doc-mini"><input id="${docId}" placeholder="${htmlEncode(cevreselSosyalMetinleri.documentPlaceholder)}" oninput="CevreselSosyalCevapGuncelle('${docId}', this.value)" value="${htmlEncode(cevreselSosyalCevaplar.answers[docId] || '')}"><input type="file" class="document-file-input"></div>`;
        }
        box.innerHTML = html;
    }

    function CevreselSosyalCevapGuncelle(fieldId, value) {
        cevreselSosyalCevaplar.answers[fieldId] = value;
        dirty = true;
    }

    function CevreselSosyalKaydet(afterSuccess) {
        cevreselSosyalCevaplar.mode = document.getElementById('cevreselSosyalYatirimKapsami')?.value || '';
        cevreselSosyalCevaplar.declaration = !!document.getElementById('cevreselSosyalDogrulukBeyani')?.checked;
        const model = {
            basvuruId: BasvuruId(),
            cevreselSosyalJson: JSON.stringify(cevreselSosyalCevaplar)
        };
        AjaxPost('/Basvuru/KaydetCevreselSosyal', model, sonuc => SonucGosterVeDirtyTemizle(sonuc, afterSuccess));
    }

    function MaliBolumuIlklendir() {
        document.getElementById('denetimDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'denetimDosyaSecim', 'Basvuru.mali.DenetimDosyaAdi');
            DenetimDosyasiYukle();
        });
        document.getElementById('bagimsizDenetimeTabiMi')?.addEventListener('change', DenetimDosyaBolumuGuncelle);
        document.querySelectorAll('.mali-scale-input').forEach(input => {
            input.addEventListener('input', MaliOlcekKontrolGuncelle);
            input.addEventListener('blur', MaliOlcekKontrolGuncelle);
        });
        DenetimDosyaBolumuGuncelle();
        MaliOlcekKontrolGuncelle();
    }

    function DenetimDosyaBolumuGuncelle() {
        const secim = document.getElementById('bagimsizDenetimeTabiMi')?.value || '';
        const bolum = document.getElementById('denetimDosyaBolumu');
        if (!bolum) return;
        bolum.classList.toggle('d-none', secim !== 'true');
    }

    function MaliOlcekKontrolGuncelle() {
        const altLimit = Number(document.getElementById('maliOlcekAltLimit')?.value || 0);
        const ustLimit = Number(document.getElementById('maliOlcekUstLimit')?.value || 0);
        const uyari = document.getElementById('maliOlcekUyari');
        const sonuc = document.getElementById('maliOlcekSonuc');
        if (!uyari || !sonuc || altLimit <= 0 || ustLimit <= 0) return;

        const alanlar = [
            'Basvuru.mali.OncekiYilNetSatis',
            'Basvuru.mali.SonYilNetSatis',
            'Basvuru.mali.OncekiYilAktifToplami',
            'Basvuru.mali.SonYilAktifToplami'
        ];
        const saglandi = alanlar.some(name => {
            const deger = degerDec(name);
            return deger >= altLimit && deger <= ustLimit;
        });

        uyari.classList.toggle('scale-ok', saglandi);
        sonuc.textContent = saglandi ? maliMesajlari.scaleOk : maliMesajlari.scaleNotOk;
    }

    function OrtaklikBolumuIlklendir() {
        OrtaklikInitialOku();
        document.getElementById('hasRelatedEnterprise')?.addEventListener('change', toggleRelatedEnterprise);
        document.getElementById('ortakEkleBtn')?.addEventListener('click', () => OrtakModalAc(-1));
        document.getElementById('ortakKisiTuru')?.addEventListener('change', OrtakModalTuzelAlanGuncelle);
        document.querySelectorAll('.ortaklik-dosya-input').forEach(input => {
            input.addEventListener('change', function () {
                OrtaklikDosyasiYukle(this.dataset.formAd || bagliBelgeFormAd, Number(this.dataset.dosyaNo || 0), this, this.dataset.nameTarget, this.dataset.downloadTarget);
            });
        });
        toggleRelatedEnterprise();
        OrtaklarRender();
    }

    function OrtaklikInitialOku() {
        const jsonElement = document.getElementById('ortaklikInitialJson');
        if (!jsonElement) {
            basvuruOrtaklari = [];
            return;
        }

        try {
            const model = JSON.parse(jsonElement.textContent || '{}');
            basvuruOrtaklari = Array.isArray(model.ortaklar) ? model.ortaklar : [];
        }
        catch {
            basvuruOrtaklari = [];
        }
    }

    function toggleRelatedEnterprise() {
        const secim = document.getElementById('hasRelatedEnterprise')?.value || '';
        document.getElementById('relatedEnterpriseBox')?.classList.toggle('d-none', secim !== 'true');
    }

    function OrtakModalAc(index) {
        const ortak = index >= 0 ? basvuruOrtaklari[index] : {};
        modalSet('ortakModalIndex', index >= 0 ? String(index) : '');
        modalSet('ortakAdUnvan', ortak.adUnvan);
        modalSet('ortakTcknVkn', ortak.tcknVkn);
        modalSet('ortakKisiTuru', ortak.kisiTuru || 'Gerçek Kişi');
        modalSet('ortakPayOrani', ortak.payOrani);
        modalSet('ortakOzelKamuNiteligi', ortak.ozelKamuNiteligi || 'Özel');
        modalSet('ortakNihaiFaydalaniciBilgisi', ortak.nihaiFaydalaniciBilgisi);
        modalSet('ortakHesabaDahilOran', ortak.hesabaDahilOran ?? ortak.payOrani);
        modalSet('ortakOncekiYilNetSatis', ortak.oncekiYilNetSatis);
        modalSet('ortakSonYilNetSatis', ortak.sonYilNetSatis);
        modalSet('ortakOncekiYilAktifToplami', ortak.oncekiYilAktifToplami);
        modalSet('ortakSonYilAktifToplami', ortak.sonYilAktifToplami);
        const hata = document.getElementById('ortakModalHata');
        if (hata) hata.textContent = '';
        OrtakModalTuzelAlanGuncelle();
        OrtakModalUboKycDurumGuncelle();
        ortakModal?.show();
    }

    function OrtakModalTuzelAlanGuncelle() {
        const tuzelMi = modalValue('ortakKisiTuru') === 'Tüzel Kişi';
        document.getElementById('ortakTuzelMaliAlanlari')?.classList.toggle('d-none', !tuzelMi);
    }

    function OrtakModalKaydet() {
        const ortak = {
            id: mevcutOrtakId(),
            basvuruId: BasvuruId(),
            siraNo: 0,
            adUnvan: modalValue('ortakAdUnvan').trim(),
            tcknVkn: modalValue('ortakTcknVkn').trim(),
            kisiTuru: modalValue('ortakKisiTuru'),
            payOrani: sayiOkuId('ortakPayOrani'),
            hesabaDahilOran: sayiOkuId('ortakHesabaDahilOran'),
            ozelKamuNiteligi: modalValue('ortakOzelKamuNiteligi'),
            nihaiFaydalaniciBilgisi: modalValue('ortakNihaiFaydalaniciBilgisi').trim(),
            uboKycBelgeAdi: mevcutOrtakBelgeAdi(),
            uboKycDosyaId: mevcutOrtakDosyaId(),
            oncekiYilNetSatis: sayiOkuId('ortakOncekiYilNetSatis'),
            sonYilNetSatis: sayiOkuId('ortakSonYilNetSatis'),
            oncekiYilAktifToplami: sayiOkuId('ortakOncekiYilAktifToplami'),
            sonYilAktifToplami: sayiOkuId('ortakSonYilAktifToplami')
        };
        const indexText = modalValue('ortakModalIndex');
        const oncekiKimlik = indexText === '' ? '' : basvuruOrtaklari[Number(indexText)]?.tcknVkn || '';
        if (TcknVknNormalize(oncekiKimlik) && TcknVknNormalize(oncekiKimlik) !== TcknVknNormalize(ortak.tcknVkn)) {
            ortak.uboKycBelgeAdi = '';
            ortak.uboKycDosyaId = null;
        }

        if (!ortak.adUnvan || !ortak.tcknVkn) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = ortakMetinleri.requiredNameIdentity;
            return;
        }
        if (AyniTcknVknVarMi(ortak.tcknVkn, modalValue('ortakModalIndex'))) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = ortakMetinleri.duplicateIdentity;
            return;
        }
        if (ortak.kisiTuru === 'Tüzel Kişi' && (!ortak.hesabaDahilOran || ortak.hesabaDahilOran <= 0)) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = ortakMetinleri.legalIncludedRateRequired;
            return;
        }

        if (indexText === '') basvuruOrtaklari.push(ortak);
        else basvuruOrtaklari[Number(indexText)] = ortak;
        basvuruOrtaklari.forEach((item, index) => item.siraNo = index + 1);
        dirty = true;
        OrtaklarRender();
        OrtaklarKaydet(function () {
            modalSet('ortakModalIndex', String(basvuruOrtaklari.findIndex(x => TcknVknNormalize(x.tcknVkn) === TcknVknNormalize(ortak.tcknVkn))));
            OrtakModalUboKycDurumGuncelle();
        });
    }

    function AyniTcknVknVarMi(tcknVkn, mevcutIndexText) {
        const kimlik = TcknVknNormalize(tcknVkn);
        const mevcutIndex = mevcutIndexText === '' ? -1 : Number(mevcutIndexText);
        return basvuruOrtaklari.some((ortak, index) =>
            index !== mevcutIndex &&
            TcknVknNormalize(ortak.tcknVkn) === kimlik);
    }

    function OrtakSil(index) {
        if (ortaklikReadonly) return;
        basvuruOrtaklari.splice(index, 1);
        basvuruOrtaklari.forEach((item, itemIndex) => item.siraNo = itemIndex + 1);
        dirty = true;
        OrtaklarRender();
        OrtaklarKaydet();
    }

    function OrtaklarRender() {
        const container = document.getElementById('partnersTable');
        if (!container) return;
        basvuruOrtaklari.forEach((item, index) => item.siraNo = index + 1);

        let html = `<div class="table-responsive"><table class="table table-bordered ortak-table"><thead><tr>
            <th>${htmlEncode(ortakMetinleri.rowNo)}</th><th>${htmlEncode(ortakMetinleri.partnerNameTitle)}</th><th>${htmlEncode(ortakMetinleri.identity)}</th><th>${htmlEncode(ortakMetinleri.personType)}</th>
            <th>${htmlEncode(ortakMetinleri.shareRate)}</th><th>${htmlEncode(ortakMetinleri.privatePublicType)}</th><th>${htmlEncode(ortakMetinleri.beneficialOwner)}</th><th>${htmlEncode(ortakMetinleri.uboKycDocument)}</th><th></th>
        </tr></thead><tbody>`;

        if (basvuruOrtaklari.length === 0) {
            html += `<tr><td colspan="9" class="text-muted text-center">${htmlEncode(ortakMetinleri.emptyPartners)}</td></tr>`;
        }
        else {
            basvuruOrtaklari.forEach((ortak, index) => {
                html += `<tr>
                    <td>${index + 1}</td>
                    <td>${htmlEncode(ortak.adUnvan)}</td>
                    <td>${htmlEncode(ortak.tcknVkn)}</td>
                    <td>${htmlEncode(OrtakSecimMetni(ortak.kisiTuru))}</td>
                    <td>${sayiYaz(ortak.payOrani)}</td>
                    <td>${htmlEncode(OrtakSecimMetni(ortak.ozelKamuNiteligi))}</td>
                    <td>${htmlEncode(ortak.nihaiFaydalaniciBilgisi)}</td>
                    <td>${OrtakUboKycHucreHtml(ortak, index)}</td>
                    <td class="text-nowrap">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="OrtakModalAc(${index})" ${ortaklikReadonly ? 'disabled' : ''}>${htmlEncode(ortakMetinleri.edit)}</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="OrtakSil(${index})" ${ortaklikReadonly ? 'disabled' : ''}>${htmlEncode(ortakMetinleri.delete)}</button>
                    </td>
                </tr>`;
            });
        }

        html += '</tbody></table></div>';
        container.innerHTML = html;
        OrtaklikOzetGuncelle();
        TuzelOrtakMaliRender();
    }

    function OrtakUboKycHucreHtml(ortak, index) {
        const uboKycYuklu = !!ortak.uboKycDosyaId;
        const dosyaAdi = htmlEncode(uboKycYuklu ? ortak.uboKycBelgeAdi : ortakMetinleri.uboKycMissing);
        const href = ortak.uboKycDosyaId ? `/Basvuru/DosyaIndir/${ortak.uboKycDosyaId}` : '#';
        const indir = uboKycYuklu
            ? `<a class="btn btn-sm btn-outline-primary mt-1" href="${href}" target="_blank" rel="noopener">${htmlEncode(ortakMetinleri.download)}</a>`
            : '';
        return `<div class="ortak-doc-cell">
            <div class="document-file-name">${dosyaAdi}</div>
            ${indir}
        </div>`;
    }

    function mevcutOrtakId() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return 0;
        return basvuruOrtaklari[Number(indexText)]?.id || 0;
    }

    function mevcutOrtakDosyaId() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return null;
        return basvuruOrtaklari[Number(indexText)]?.uboKycDosyaId || null;
    }

    function mevcutOrtakBelgeAdi() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return '';
        return basvuruOrtaklari[Number(indexText)]?.uboKycBelgeAdi || '';
    }

    function OrtakModalUboKycDurumGuncelle() {
        const indexText = modalValue('ortakModalIndex');
        const ortak = indexText === '' ? null : basvuruOrtaklari[Number(indexText)];
        const kayitliMi = !!ortak && !!String(ortak.tcknVkn || '').trim();
        const input = document.getElementById('ortakUboKycDosya');
        const button = document.getElementById('ortakUboKycSecBtn');
        const name = document.getElementById('ortakUboKycDosyaAdi');
        const note = document.getElementById('ortakUboKycNot');
        const download = document.getElementById('ortakUboKycIndirBtn');

        if (input) {
            input.disabled = !kayitliMi || ortaklikReadonly;
            input.value = '';
        }
        button?.classList.toggle('disabled', !kayitliMi || ortaklikReadonly);
        const uboKycYuklu = !!ortak?.uboKycDosyaId;
        if (name) name.textContent = uboKycYuklu ? (ortak?.uboKycBelgeAdi || '') : ortakMetinleri.uboKycMissing;
        if (note) {
            note.textContent = kayitliMi
                ? ''
                : ortakMetinleri.uboKycSavePartnerFirst;
            note.classList.toggle('d-none', kayitliMi);
        }
        if (download) {
            if (uboKycYuklu) {
                download.href = `/Basvuru/DosyaIndir/${ortak.uboKycDosyaId}`;
                download.classList.remove('d-none');
            }
            else {
                download.href = '#';
                download.classList.add('d-none');
            }
        }
    }

    function OrtakModalUboKycDosyasiYukle() {
        const input = document.getElementById('ortakUboKycDosya');
        const indexText = modalValue('ortakModalIndex');
        const index = indexText === '' ? -1 : Number(indexText);
        const ortak = index >= 0 ? basvuruOrtaklari[index] : null;
        if (!ortak) {
            PopupMesajGoster(ortakMetinleri.uboKycSavePartnerFirst, false);
            return;
        }

        BasvuruDosyasiYukle(UboKycFormAdOlustur(ortak.tcknVkn), 1, input, 'ortakUboKycDosyaAdi', 'ortakUboKycIndirBtn', function (sonuc) {
            const nesne = sonuc?.nesne || sonuc?.Nesne || {};
            ortak.uboKycDosyaId = nesne.dosyaId || nesne.DosyaId || null;
            ortak.uboKycBelgeAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            OrtakModalUboKycDurumGuncelle();
            OrtaklarRender();
        });
    }

    function UboKycFormAdOlustur(tcknVkn) {
        return `OBOKYC_${TcknVknNormalize(tcknVkn)}`;
    }

    function TcknVknNormalize(tcknVkn) {
        return String(tcknVkn || '').trim().replace(/[^0-9A-Za-z]/g, '').toLocaleUpperCase('tr-TR');
    }

    function OrtakSecimMetni(value) {
        if (value === 'Gerçek Kişi') return ortakMetinleri.naturalPerson;
        if (value === 'Tüzel Kişi') return ortakMetinleri.legalEntity;
        if (value === 'Özel') return ortakMetinleri.privateSector;
        if (value === 'Kamu') return ortakMetinleri.publicSector;
        return value || '';
    }

    function OrtaklikOzetGuncelle() {
        const toplamPay = basvuruOrtaklari.reduce((sum, ortak) => sum + Number(ortak.payOrani || 0), 0);
        const ozelPay = basvuruOrtaklari
            .filter(ortak => ortak.ozelKamuNiteligi === 'Özel')
            .reduce((sum, ortak) => sum + Number(ortak.payOrani || 0), 0);
        const ozelInput = document.getElementById('privateShareCalculated');
        if (ozelInput) ozelInput.value = sayiYaz(ozelPay);

        const alert = document.getElementById('partnerAlerts');
        if (!alert) return;
        if (toplamPay > 100) {
            alert.innerHTML = `<div class="alert alert-danger">${htmlEncode(ortakMetinleri.totalShareExceeded)}</div>`;
        }
        else if (basvuruOrtaklari.length > 0 && toplamPay !== 100) {
            alert.innerHTML = `<div class="alert alert-warning">${htmlEncode(ortakMetinleri.totalShareExpected.replace('{0}', sayiYaz(toplamPay)))}</div>`;
        }
        else {
            alert.innerHTML = '';
        }
    }

    function TuzelOrtakMaliRender() {
        const container = document.getElementById('legalPartnerFinancials');
        if (!container) return;
        const tuzelOrtaklar = basvuruOrtaklari.filter(ortak => ortak.kisiTuru === 'Tüzel Kişi');
        if (tuzelOrtaklar.length === 0) {
            container.innerHTML = '';
            return;
        }

        let html = `<h3 class="subhead">${htmlEncode(ortakMetinleri.legalFinancialTitle)}</h3>
            <div class="table-responsive"><table class="table table-bordered legal-financial-table"><thead><tr>
                <th>${htmlEncode(ortakMetinleri.partnerColumn)}</th><th>${htmlEncode(ortakMetinleri.includedRate)}</th><th>${htmlEncode(oncekiMaliYil)} ${htmlEncode(ortakMetinleri.netSalesShort)}</th><th>${htmlEncode(sonMaliYil)} ${htmlEncode(ortakMetinleri.netSalesShort)}</th><th>${htmlEncode(oncekiMaliYil)} ${htmlEncode(ortakMetinleri.assetsShort)}</th><th>${htmlEncode(sonMaliYil)} ${htmlEncode(ortakMetinleri.assetsShort)}</th>
            </tr></thead><tbody>`;
        tuzelOrtaklar.forEach(ortak => {
            html += `<tr>
                <td>${htmlEncode(ortak.adUnvan)}</td>
                <td>%${sayiYaz(ortak.hesabaDahilOran ?? ortak.payOrani)}</td>
                <td>${sayiYaz(ortak.oncekiYilNetSatis)}</td>
                <td>${sayiYaz(ortak.sonYilNetSatis)}</td>
                <td>${sayiYaz(ortak.oncekiYilAktifToplami)}</td>
                <td>${sayiYaz(ortak.sonYilAktifToplami)}</td>
            </tr>`;
        });
        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function OrtaklikKaydet(afterSuccess, bosBagliSecimiHayirSay) {
        const secim = document.getElementById('hasRelatedEnterprise')?.value || '';
        const bagliOrtakVarMi = secim === '' ? (bosBagliSecimiHayirSay ? false : null) : secim === 'true';
        if (bagliOrtakVarMi === true) {
            const eksikler = [];
            if (!modalValue('relatedTitle').trim()) eksikler.push(ortakMetinleri.relatedEnterpriseTitleField);
            if (!modalValue('relatedId').trim()) eksikler.push(ortakMetinleri.relatedEnterpriseIdentityField);
            if (sayiAlanBosMu('relPrevNetSales')) eksikler.push(`${oncekiMaliYil} ${ortakMetinleri.netSalesRevenue}`);
            if (sayiAlanBosMu('relLastNetSales')) eksikler.push(`${sonMaliYil} ${ortakMetinleri.netSalesRevenue}`);
            if (sayiAlanBosMu('relPrevAssets')) eksikler.push(`${oncekiMaliYil} ${ortakMetinleri.totalAssets}`);
            if (sayiAlanBosMu('relLastAssets')) eksikler.push(`${sonMaliYil} ${ortakMetinleri.totalAssets}`);
            if (eksikler.length > 0) {
                PopupMesajGoster(ortakMetinleri.requiredEnter.replace('{0}', eksikler.join(', ')), false);
                return;
            }
        }
        const model = {
            ...BasvuruKimlikleri(),
            bagliOrtakIsletmeVarMi: bagliOrtakVarMi,
            ozelSektorPayi: sayiOkuId('privateShareCalculated'),
            ortaklar: basvuruOrtaklari,
            bagliOrtakUnvani: modalValue('relatedTitle'),
            bagliOrtakKimlikNo: modalValue('relatedId'),
            bagliOrtakOncekiYilNetSatis: sayiOkuId('relPrevNetSales'),
            bagliOrtakSonYilNetSatis: sayiOkuId('relLastNetSales'),
            bagliOrtakOncekiYilAktifToplami: sayiOkuId('relPrevAssets'),
            bagliOrtakSonYilAktifToplami: sayiOkuId('relLastAssets')
        };
        AjaxPost('/Basvuru/KaydetOrtaklik', model, function (sonuc) {
            if (sonuc?.basarili) {
                dirty = false;
                if (afterSuccess) afterSuccess(sonuc);
            }
            SonucGoster(sonuc);
        });
    }

