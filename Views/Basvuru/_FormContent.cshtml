@using System.Text.Json
@using TarimDonusum.Models
@model TarimDonusum.ViewModels.Basvuru.BasvuruFormViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    var b = Model.Basvuru;
    bool ro = Model.SaltOkunur;
    bool kilitli = b.Id <= 0 && !Model.DenetciGorunumu;
    IReadOnlyList<BasvuruBolumTanim> bolumler = BasvuruBolumleri.Tum(Model.DenetciGorunumu);
    BasvuruBolumTanim ilkBolum = bolumler.First();

    string T(string key) => L[key].Value;

    string basvuruIlAdi = b.basvuruFirma.il?.ad ?? "";
    if (string.IsNullOrWhiteSpace(basvuruIlAdi) && b.basvuruFirma.il.id > 0)
    {
        basvuruIlAdi = Model.Iller.FirstOrDefault(x => x.id == b.basvuruFirma.il.id)?.ad ?? "";
    }

    int donemYil = b.basvuruFirma.donem?.yil ?? 0;
    if (donemYil <= 0 && b.basvuruFirma.donemId > 0)
    {
        donemYil = Model.Donemler?.FirstOrDefault(x => x.id == b.basvuruFirma.donemId)?.yil ?? 0;
    }
    string oncekiMaliYil = donemYil > 0 ? (donemYil - 2).ToString() : "Önceki Yıl";
    string sonMaliYil = donemYil > 0 ? (donemYil - 1).ToString() : "Son Yıl";
    string[] adliSicilGorevDegerleri = new[] { "Şirket Ortağı", "Temsil ve ilzama yetkili", "Yönetim kurulu üye", "Adli Sicil Kontrolüne Tabi Ek Kişi" };
    string[] adliSicilGorevMetinleri = T("Basvuru.Criminal.RoleOptions").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}
<div class="basvuru-page">
    <div class="basvuru-titlebar">
        <div>
            <h1>@(Model.DenetciGorunumu ? T("Basvuru.Form.AuditTitle") : (b.Id > 0 ? T("Basvuru.Form.EditTitle") : T("Basvuru.Form.NewTitle")))</h1>
            <p>@string.Format(T("Basvuru.Form.ApplicationNo"), b.Id > 0 ? b.Id.ToString() : T("Basvuru.Form.ApplicationNoPending"))</p>
        </div>
    </div>

    <div id="ajaxMesaj"
         class="alert alert-info alert-dismissible floating-message"
         style="display:@(TempData["Mesaj"] != null ? "block" : "none")">
        <span id="ajaxMesajMetin">@TempData["Mesaj"]</span>
        <button type="button" id="ajaxMesajKapat" class="close" aria-label="@T("Basvuru.Common.Close")">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    @if (Model.Hatalar.Count > 0)
    {
        <div class="alert alert-danger">
            @foreach (string hata in Model.Hatalar)
            {
                <div>@hata</div>
            }
        </div>
    }

    @if (kilitli)
    {
        <div class="alert alert-warning">@L["Basvuru.Warning.FirstSectionRequired"]</div>
    }

    <div class="alert alert-info">@L["Basvuru.Flow.Note"]</div>

    <div class="basvuru-stepbar">
        <label for="basvuruStepSelect">@L["Basvuru.Common.Steps"]</label>
        <select id="basvuruStepSelect" class="form-control">
            @foreach (BasvuruBolumTanim bolum in bolumler)
            {
                bool devreDisi = kilitli && bolum.Bolum != enumBasvuruBolum.Firma;
                <option value="@((int)bolum.Bolum)" selected="@(bolum.Bolum == ilkBolum.Bolum)" disabled="@devreDisi">@L[bolum.BaslikResourceKey]</option>
            }
        </select>
        <button type="button" class="btn btn-outline-secondary nav-prev">@L["Basvuru.Common.Previous"]</button>
        <button type="button" class="btn btn-primary" id="basvuruKaydetBtn" onclick="PaneliKaydet()">@L["Basvuru.Common.Save"]</button>
        <button type="button" class="btn btn-outline-primary nav-next">@L["Basvuru.Common.Next"]</button>
        <button type="button" class="btn btn-outline-info icon-action" id="stepHelpBtn" title="@T("Basvuru.Common.Help")">?</button>
    </div>
    <input type="hidden" name="Basvuru.Id" value="@b.Id" />
    <div class="basvuru-shell">
        <main class="basvuru-panels">
            <div id="basvuruBolumContainer" data-url="@Url.Action("BolumGetir", "Basvuru")">
                @await Html.PartialAsync(ilkBolum.PartialView, Model)
            </div>
            <div class="basvuru-footer">
                <button type="button" class="btn btn-outline-secondary footer-prev">@L["Basvuru.Common.Back"]</button>
                <div class="footer-actions-right">
                    <button type="button" class="btn btn-primary footer-primary" id="footerPrimaryBtn">@L["Basvuru.Common.SaveAndContinue"]</button>
                </div>
            </div>
        </main>
    </div>
</div>
@if (!ro)
{
    <div class="modal fade firma-modal" id="firmaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Firma.ModalTitle"]</h5>
                    <button type="button" class="close firma-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <div class="alert alert-info">@L["Basvuru.Firma.ModalInfo"]</div>
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <input type="hidden" id="modalFirmaId" />
                            <label>@L["Basvuru.Field.VergiKimlikNo"]<input id="modalVergiKimlikNo" /></label>
                            <label>@L["Basvuru.Field.TicaretUnvani"]<input id="modalTicaretUnvani" /></label>
                            <label>@L["Basvuru.Field.TicaretSicilNo"]<input id="modalTicaretSicilNo" /></label>
                            <label>@L["Basvuru.Field.KurulusTarihi"]<input id="modalKurulusTarihi" type="date" /></label>
                            <label>@L["Basvuru.Field.MersisNo"]<input id="modalMersisNo" /></label>
                            <label>@L["Basvuru.Field.NaceKodu"]<input id="modalNaceKodu" /></label>
                            <label>@L["Basvuru.Field.WebSitesi"]<input id="modalWebSitesi" /></label>
                            <label>@L["Basvuru.Field.Telefon"]<input id="modalTelefon" /></label>
                            <label>@L["Basvuru.Field.KepAdresi"]<input id="modalKepAdresi" /></label>
                            <label>@L["Basvuru.Field.Eposta"]<input id="modalEposta" type="email" /></label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.FaaliyetKonusu"]<textarea id="modalFaaliyetKonusu"></textarea></label>
                        <label class="wide-label">@L["Basvuru.Field.FirmaAdresi"]<textarea id="modalAdres"></textarea></label>
                    </div>
                    <div class="text-danger mt-2" id="firmaModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary firma-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="firmaKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal uygulama-adres-modal" id="uygulamaAdresModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Address.ModalTitle"]</h5>
                    <button type="button" class="close uygulama-adres-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="adresModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Field.SiraNo"]<input id="adresModalSiraNo" type="number" min="1" step="1" /></label>
                            <label>@L["Basvuru.Field.Il"]<input id="adresModalIl" value="@basvuruIlAdi" readonly /></label>
                            <label>
                                @L["Basvuru.Field.Ilce"]
                                <select id="adresModalIlce">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @foreach (var ilce in Model.Ilceler)
                                    {
                                        <option value="@ilce.Id">@ilce.Ad</option>
                                    }
                                </select>
                            </label>
                            <label>
                                @L["Basvuru.Field.YatirimYeriStatusu"]
                                <select id="adresModalYatirimYeriStatusu">
                                    @foreach(var item in Enum.GetValues<TarimDonusum.Models.enumUygulamaAdresiYatirimYeriStatusu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                            <label>@L["Basvuru.Field.KiraVeyaTahsisSuresi"]<input id="adresModalKiraVeyaTahsisSuresi" type="number" min="0" step="1" /></label>
                            <label>@L["Basvuru.Field.KiraTahsisBitisTarihi"]<input id="adresModalKiraTahsisBitisTarihi" type="date" /></label>
                            <label>
                                @L["Basvuru.Field.YapiRuhsatiDurumu"]
                                <select id="adresModalYapiRuhsatiDurumu">
                                    @foreach (var item in Enum.GetValues < TarimDonusum.Models.enumUygulamaAdresiYapiRuhsatiDurumu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.TamAdres"]<textarea id="adresModalTamAdres"></textarea></label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary uygulama-adres-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="adresKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal" id="ortakModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Ortaklik.Modal.Title"]</h5>
                    <button type="button" class="close ortak-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="ortakModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Ortaklik.PartnerNameTitle"]<input id="ortakAdUnvan" /></label>
                            <label>@L["Basvuru.Ortaklik.Identity"]<input id="ortakTcknVkn" /></label>
                            <label>
                                @L["Basvuru.Ortaklik.PersonType"]
                                <select id="ortakKisiTuru">
                                    <option value="Gerçek Kişi">@L["Basvuru.Ortaklik.NaturalPerson"]</option>
                                    <option value="Tüzel Kişi">@L["Basvuru.Ortaklik.LegalEntity"]</option>
                                </select>
                            </label>
                            <label>@L["Basvuru.Ortaklik.ShareRate"]<input id="ortakPayOrani" type="number" min="0" max="100" step="0.01" /></label>
                            <label>
                                @L["Basvuru.Ortaklik.PrivatePublicType"]
                                <select id="ortakOzelKamuNiteligi">
                                    <option value="Özel">@L["Basvuru.Ortaklik.PrivateSector"]</option>
                                    <option value="Kamu">@L["Basvuru.Ortaklik.PublicSector"]</option>
                                </select>
                            </label>
                            <label>@L["Basvuru.Ortaklik.BeneficialOwner"]<input id="ortakNihaiFaydalaniciBilgisi" /></label>
                        </div>
                        <div class="document-upload-box mt-3" id="ortakUboKycBox">
                            <div class="document-file-row">
                                <label class="btn btn-primary mb-0 disabled" for="ortakUboKycDosya" id="ortakUboKycSecBtn">@L["Basvuru.Ortaklik.UboKycUpload"]</label>
                                <input id="ortakUboKycDosya" type="file" class="document-file-input" disabled />
                                <span id="ortakUboKycDosyaAdi" class="document-file-name">@L["Basvuru.Ortaklik.UboKycMissing"]</span>
                                <a id="ortakUboKycIndirBtn" class="btn btn-outline-primary d-none" href="#" target="_blank" rel="noopener">@L["Basvuru.Common.Download"]</a>
                            </div>
                            <div class="document-note" id="ortakUboKycNot">@L["Basvuru.Ortaklik.UboKycSavePartnerFirst"]</div>
                        </div>
                        <div id="ortakTuzelMaliAlanlari" class="legal-partner-modal-fields">
                            <h6>@L["Basvuru.Ortaklik.LegalFinancialTitle"]</h6>
                            <div class="form-grid">
                                <label>@L["Basvuru.Ortaklik.IncludedRatePercent"]<input id="ortakHesabaDahilOran" type="number" min="0" max="100" step="0.01" /></label>
                                <label>@oncekiMaliYil @L["Basvuru.Ortaklik.NetSalesShort"]<input id="ortakOncekiYilNetSatis" class="money-integer" /></label>
                                <label>@sonMaliYil @L["Basvuru.Ortaklik.NetSalesShort"]<input id="ortakSonYilNetSatis" class="money-integer" /></label>
                                <label>@oncekiMaliYil @L["Basvuru.Ortaklik.AssetsShort"]<input id="ortakOncekiYilAktifToplami" class="money-integer" /></label>
                                <label>@sonMaliYil @L["Basvuru.Ortaklik.AssetsShort"]<input id="ortakSonYilAktifToplami" class="money-integer" /></label>
                            </div>
                        </div>
                    </div>
                    <div class="text-danger mt-2" id="ortakModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary ortak-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="ortakKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal" id="adliSicilModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Criminal.ModalTitle"]</h5>
                    <button type="button" class="close adli-sicil-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="adliSicilModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Field.Tckn"]<input id="adliSicilTckn" /></label>
                            <label>@L["Basvuru.Field.Ad"]<input id="adliSicilAd" /></label>
                            <label>@L["Basvuru.Field.Soyad"]<input id="adliSicilSoyad" /></label>
                            <label>
                                @L["Basvuru.Criminal.Role"]
                                <select id="adliSicilGorev">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @for (int i = 0; i < adliSicilGorevDegerleri.Length; i++)
                                    {
                                        string gorev = adliSicilGorevDegerleri[i];
                                        string metin = adliSicilGorevMetinleri.Length > i ? adliSicilGorevMetinleri[i] : gorev;
                                        <option value="@gorev">@metin</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <div class="document-upload-box mt-3" id="adliSicilDosyaBox">
                            <div class="document-file-row">
                                <label class="btn btn-primary mb-0 disabled" for="adliSicilDosya" id="adliSicilDosyaSecBtn">@L["Basvuru.Criminal.Upload"]</label>
                                <input id="adliSicilDosya" type="file" class="document-file-input" disabled />
                                <span id="adliSicilDosyaAdi" class="document-file-name">@L["Basvuru.Criminal.FileMissing"]</span>
                                <a id="adliSicilIndirBtn" class="btn btn-outline-primary d-none" href="#" target="_blank" rel="noopener">@L["Basvuru.Common.Download"]</a>
                            </div>
                            <div class="document-note" id="adliSicilDosyaNot">@L["Basvuru.Criminal.SavePersonFirst"]</div>
                        </div>
                    </div>
                    <div class="text-danger mt-2" id="adliSicilModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary adli-sicil-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="adliSicilKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    var active = @((int)ilkBolum.Bolum);
    let basvuruIlId = @b.basvuruFirma.ilId;
    const bolumFirma = @((int)enumBasvuruBolum.Firma);
    const bolumIrtibat = @((int)enumBasvuruBolum.Irtibat);
    const bolumYatirim = @((int)enumBasvuruBolum.Yatirim);
    const bolumUygulamaAdresi = @((int)enumBasvuruBolum.UygulamaAdresi);
    const bolumUygunHarcama = @((int)enumBasvuruBolum.UygunHarcama);
    const bolumFinans = @((int)enumBasvuruBolum.Finans);
    const bolumYatirimOzeti = @((int)enumBasvuruBolum.YatirimOzeti);
    const bolumMali = @((int)enumBasvuruBolum.Mali);
    const bolumBelgeler = @((int)enumBasvuruBolum.Belgeler);
    const bolumOrtaklik = @((int)enumBasvuruBolum.Ortaklik);
    const bolumCevreselSosyal = @((int)enumBasvuruBolum.CevreselSosyal);
    const bolumTaahhutBeyan = @((int)enumBasvuruBolum.TaahhutBeyan);
    const basvuruReadonly = @(ro ? "true" : "false");
    const ortaklikReadonly = @(ro ? "true" : "false");
    const oncekiMaliYil = @Html.Raw(JsonSerializer.Serialize(oncekiMaliYil));
    const sonMaliYil = @Html.Raw(JsonSerializer.Serialize(sonMaliYil));
    const zorunluBelgeFormAd = 'Basvuru_ZorunluBelge';
    const bagliBelgeFormAd = 'Basvuru_BagliBelge';
    const basvuruBolumleri = @Html.Raw(JsonSerializer.Serialize(bolumler.Select(x => (int)x.Bolum)));
    const adresBosMesaj = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.Empty")));
    const adresSilOnay = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.DeleteConfirm")));
    const lockedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.LockedMessage")));
    const unsavedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.UnsavedMessage")));
    const partialLoadFailedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Message.NotFound")));
    const firmaCreateQuestion = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.CreateQuestion")));
    const firmaSelectFirstMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.SelectFirst")));
    const belgeMesajlari = {
        noFileSelected: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.NoFileSelected"))),
        packageFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.PackageFileRequired"))),
        uploadErrorConsole: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadErrorConsole"))),
        uploadFailed: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadFailed"))),
        uploadSucceeded: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadSucceeded"))),
        sectionSaveInfo: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.SectionSaveInfo"))),
        commitmentFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.CommitmentFileRequired"))),
        auditFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Mali.AuditFileRequired")))
    };
    const basvuruAkisMetinleri = {
        saveAndContinue: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.SaveAndContinue"))),
        continue: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.Continue")))
    };
    const ortakMetinleri = {
        rowNo: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.RowNo"))),
        actions: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.Actions"))),
        edit: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.Edit"))),
        delete: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.Delete"))),
        download: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Common.Download"))),
        partnerNameTitle: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PartnerNameTitle"))),
        identity: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.Identity"))),
        personType: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PersonType"))),
        shareRate: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.ShareRate"))),
        privatePublicType: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PrivatePublicType"))),
        beneficialOwner: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.BeneficialOwner"))),
        uboKycDocument: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.UboKycDocument"))),
        uboKycMissing: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.UboKycMissing"))),
        uboKycSavePartnerFirst: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.UboKycSavePartnerFirst"))),
        naturalPerson: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.NaturalPerson"))),
        legalEntity: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.LegalEntity"))),
        privateSector: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PrivateSector"))),
        publicSector: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PublicSector"))),
        emptyPartners: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.EmptyPartners"))),
        totalShareExceeded: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.TotalShareExceeded"))),
        totalShareExpected: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.TotalShareExpected"))),
        legalFinancialTitle: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.LegalFinancialTitle"))),
        partnerColumn: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.PartnerColumn"))),
        includedRate: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.IncludedRate"))),
        netSalesShort: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.NetSalesShort"))),
        assetsShort: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Ortaklik.AssetsShort"))),
