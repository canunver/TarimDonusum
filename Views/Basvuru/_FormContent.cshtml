    function UygunHarcamaBolumuIlklendir() {
        const raw = document.getElementById('pikkListesiJson')?.value || '';
        pikkEquipmentRows = [];
        pikkConstructionRows = [];
        if (raw) {
            try {
                const data = JSON.parse(raw);
                pikkEquipmentRows = Array.isArray(data.equipmentRows) ? data.equipmentRows : [];
                pikkConstructionRows = Array.isArray(data.constructionRows) ? data.constructionRows : [];
            }
            catch {
                pikkEquipmentRows = [];
                pikkConstructionRows = [];
            }
        }
        if (PikkMakineEkipmanSecili() && pikkEquipmentRows.length === 0) pikkEquipmentRows.push(PikkBosSatir());
        if (PikkYapimIsleriSecili() && pikkConstructionRows.length === 0) pikkConstructionRows.push(PikkBosSatir());
        PikkRender();
    }

    function PikkMakineEkipmanSecili() {
        return document.getElementById('pikkMakineEkipmanSecili')?.value === 'true';
    }

    function PikkYapimIsleriSecili() {
        return document.getElementById('pikkYapimIsleriSecili')?.value === 'true';
    }

    function PikkBosSatir() {
        return { name: '', purpose: '' };
    }

    function PikkRender() {
        const container = document.getElementById('pikkLists');
        if (!container) return;
        const parcalar = [];
        if (PikkMakineEkipmanSecili()) {
            parcalar.push(PikkListeHtml('equipment', pikkMesajlari.equipmentTitle, pikkMesajlari.equipmentNote, pikkMesajlari.equipmentName, pikkMesajlari.addEquipment, pikkEquipmentRows));
        }
        if (PikkYapimIsleriSecili()) {
            parcalar.push(PikkListeHtml('construction', pikkMesajlari.constructionTitle, pikkMesajlari.constructionNote, pikkMesajlari.constructionName, pikkMesajlari.addConstruction, pikkConstructionRows));
        }
        if (parcalar.length === 0) {
            parcalar.push(`<div class="alert alert-info">${htmlEncode(pikkMesajlari.noList)}</div>`);
        }
        container.innerHTML = parcalar.join('');
    }

    function PikkListeHtml(tur, baslik, not, adBaslik, ekleMetni, satirlar) {
        const disabled = basvuruReadonly ? 'disabled' : '';
        let html = `<div class="pikk-list"><h3 class="subhead">${htmlEncode(baslik)}</h3><p class="mini">${htmlEncode(not)}</p>
            <div class="table-responsive"><table class="table table-bordered pikk-table"><thead><tr>
                <th>${htmlEncode(pikkMesajlari.rowNo)}</th>
                <th>${htmlEncode(adBaslik)}</th>
                <th>${htmlEncode(pikkMesajlari.purpose)}</th>
                <th>${htmlEncode(pikkMesajlari.action)}</th>
            </tr></thead><tbody>`;
        satirlar.forEach((satir, index) => {
            html += `<tr>
                <td class="text-center">${index + 1}</td>
                <td><input value="${htmlEncode(satir.name)}" maxlength="250" ${disabled} oninput="PikkSatirGuncelle('${tur}', ${index}, 'name', this.value)" /></td>
                <td><textarea maxlength="500" ${disabled} oninput="PikkSatirGuncelle('${tur}', ${index}, 'purpose', this.value)">${htmlEncode(satir.purpose)}</textarea></td>
                <td><button type="button" class="btn btn-outline-danger" ${disabled} onclick="PikkSatirSil('${tur}', ${index})">${htmlEncode(pikkMesajlari.delete)}</button></td>
            </tr>`;
        });
        html += `</tbody></table></div>
            <div class="pikk-actions"><button type="button" class="btn btn-outline-primary" ${disabled} onclick="PikkSatirEkle('${tur}')">${htmlEncode(ekleMetni)}</button></div></div>`;
        return html;
    }

    function PikkSatirGuncelle(tur, index, alan, value) {
        const liste = tur === 'equipment' ? pikkEquipmentRows : pikkConstructionRows;
        if (!liste[index]) return;
        liste[index][alan] = value;
        dirty = true;
    }

    function PikkSatirEkle(tur) {
        const liste = tur === 'equipment' ? pikkEquipmentRows : pikkConstructionRows;
        liste.push(PikkBosSatir());
        dirty = true;
        PikkRender();
    }

    function PikkSatirSil(tur, index) {
        const liste = tur === 'equipment' ? pikkEquipmentRows : pikkConstructionRows;
        liste.splice(index, 1);
        if (liste.length === 0) liste.push(PikkBosSatir());
        dirty = true;
        PikkRender();
    }

    function PikkDoluSatirVarMi(liste) {
        return liste.some(satir => String(satir.name || '').trim() && String(satir.purpose || '').trim());
    }

    function UygunHarcamaKaydet(afterSuccess) {
        if (PikkMakineEkipmanSecili() && !PikkDoluSatirVarMi(pikkEquipmentRows)) {
            PopupMesajGoster(pikkMesajlari.equipmentRequired, false);
            return;
        }
        if (PikkYapimIsleriSecili() && !PikkDoluSatirVarMi(pikkConstructionRows)) {
            PopupMesajGoster(pikkMesajlari.constructionRequired, false);
            return;
        }
        const model = {
            ...BasvuruKimlikleri(),
            pikkListesiJson: JSON.stringify({
                equipmentRows: PikkMakineEkipmanSecili() ? pikkEquipmentRows : [],
                constructionRows: PikkYapimIsleriSecili() ? pikkConstructionRows : []
            })
        };
        AjaxPost('/Basvuru/KaydetUygunHarcama', model, sonuc => SonucGosterVeDirtyTemizle(sonuc, afterSuccess));
    }

    function YatirimOzetiBolumuIlklendir() {
        const raw = document.getElementById('yatirimOzetiJson')?.value || '';
        yatirimOzetiUrunRows = [];
        yatirimOzetiGiderRows = [];
        if (raw) {
            try {
                const data = JSON.parse(raw);
                yatirimOzetiUrunRows = Array.isArray(data.urunler) ? data.urunler : [];
                yatirimOzetiGiderRows = Array.isArray(data.sabitGiderler) ? data.sabitGiderler : [];
            }
            catch {
                yatirimOzetiUrunRows = [];
                yatirimOzetiGiderRows = [];
            }
        }
        if (yatirimOzetiUrunRows.length === 0) yatirimOzetiUrunRows.push(YatirimOzetiBosUrun());
        if (yatirimOzetiGiderRows.length === 0) YatirimOzetiSabitGiderleriYukle(false);
        YatirimOzetiRender();
    }

    function YatirimOzetiBosUrun() {
        return { ad: '', birim: '', miktar: null, birimFiyat: null };
    }

    function YatirimOzetiBosGider(ad) {
        return { ad: ad || '', aylikTutar: null };
    }

    function YatirimOzetiSabitGiderleriYukle(render = true) {
        yatirimOzetiGiderRows = [
            YatirimOzetiBosGider('Personel giderleri'),
            YatirimOzetiBosGider('Enerji giderleri'),
            YatirimOzetiBosGider('Bakım-onarım giderleri'),
            YatirimOzetiBosGider('Kira / tahsis giderleri'),
            YatirimOzetiBosGider('Pazarlama ve dağıtım giderleri'),
            YatirimOzetiBosGider('Diğer sabit giderler')
        ];
        dirty = true;
        if (render) YatirimOzetiRender();
    }

    function YatirimOzetiUrunEkle() {
        yatirimOzetiUrunRows.push(YatirimOzetiBosUrun());
        dirty = true;
        YatirimOzetiRender();
    }

    function YatirimOzetiGiderEkle() {
        yatirimOzetiGiderRows.push(YatirimOzetiBosGider());
        dirty = true;
        YatirimOzetiRender();
    }

    function YatirimOzetiUrunSil(index) {
        yatirimOzetiUrunRows.splice(index, 1);
        if (yatirimOzetiUrunRows.length === 0) yatirimOzetiUrunRows.push(YatirimOzetiBosUrun());
        dirty = true;
        YatirimOzetiRender();
    }

    function YatirimOzetiGiderSil(index) {
        yatirimOzetiGiderRows.splice(index, 1);
        if (yatirimOzetiGiderRows.length === 0) yatirimOzetiGiderRows.push(YatirimOzetiBosGider());
        dirty = true;
        YatirimOzetiRender();
    }

    function YatirimOzetiUrunGuncelle(index, alan, value) {
        if (!yatirimOzetiUrunRows[index]) return;
        yatirimOzetiUrunRows[index][alan] = alan === 'miktar' || alan === 'birimFiyat' ? YatirimOzetiSayi(value) : value;
        dirty = true;
        YatirimOzetiHesapla();
    }

    function YatirimOzetiGiderGuncelle(index, alan, value) {
        if (!yatirimOzetiGiderRows[index]) return;
        yatirimOzetiGiderRows[index][alan] = alan === 'aylikTutar' ? YatirimOzetiSayi(value) : value;
        dirty = true;
        YatirimOzetiHesapla();
    }

    function YatirimOzetiRender() {
        YatirimOzetiUrunRender();
        YatirimOzetiGiderRender();
        YatirimOzetiHesapla();
    }

    function YatirimOzetiUrunRender() {
        const container = document.getElementById('yatirimOzetiUrunler');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        let html = `<div class="table-responsive"><table class="table table-bordered yatirim-ozeti-table"><thead><tr>
            <th>Sıra</th><th>Ürün adı</th><th>Birim</th><th>Yıllık miktar</th><th>Birim satış fiyatı (USD)</th><th>Yıllık gelir</th><th>İşlem</th>
        </tr></thead><tbody>`;
        yatirimOzetiUrunRows.forEach((row, index) => {
            const gelir = Number(row.miktar || 0) * Number(row.birimFiyat || 0);
            html += `<tr>
                <td class="text-center">${index + 1}</td>
                <td><input value="${htmlEncode(row.ad)}" ${disabled} oninput="YatirimOzetiUrunGuncelle(${index}, 'ad', this.value)" /></td>
                <td><input value="${htmlEncode(row.birim)}" ${disabled} oninput="YatirimOzetiUrunGuncelle(${index}, 'birim', this.value)" /></td>
                <td><input type="number" min="0" step="0.01" value="${row.miktar ?? ''}" ${disabled} oninput="YatirimOzetiUrunGuncelle(${index}, 'miktar', this.value)" /></td>
                <td><input type="number" min="0" step="0.01" value="${row.birimFiyat ?? ''}" ${disabled} oninput="YatirimOzetiUrunGuncelle(${index}, 'birimFiyat', this.value)" /></td>
                <td class="text-right">${YatirimOzetiPara(gelir)}</td>
                <td class="text-center"><button type="button" class="btn btn-outline-danger" ${disabled} onclick="YatirimOzetiUrunSil(${index})">Sil</button></td>
            </tr>`;
        });
        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function YatirimOzetiGiderRender() {
        const container = document.getElementById('yatirimOzetiGiderler');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        let html = `<div class="table-responsive"><table class="table table-bordered yatirim-ozeti-table"><thead><tr>
            <th>Sıra</th><th>Sabit gider kalemi</th><th>Aylık tutar (USD)</th><th>Yıllık tutar</th><th>İşlem</th>
        </tr></thead><tbody>`;
        yatirimOzetiGiderRows.forEach((row, index) => {
            const yillik = Number(row.aylikTutar || 0) * 12;
            html += `<tr>
                <td class="text-center">${index + 1}</td>
                <td><input value="${htmlEncode(row.ad)}" ${disabled} oninput="YatirimOzetiGiderGuncelle(${index}, 'ad', this.value)" /></td>
                <td><input type="number" min="0" step="0.01" value="${row.aylikTutar ?? ''}" ${disabled} oninput="YatirimOzetiGiderGuncelle(${index}, 'aylikTutar', this.value)" /></td>
                <td class="text-right">${YatirimOzetiPara(yillik)}</td>
                <td class="text-center"><button type="button" class="btn btn-outline-danger" ${disabled} onclick="YatirimOzetiGiderSil(${index})">Sil</button></td>
            </tr>`;
        });
        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function YatirimOzetiHesapla() {
        const toplamYatirim = YatirimOzetiHiddenSayi('yatirimOzetiToplamYatirimTutari');
        const finansmanOrani = YatirimOzetiHiddenSayi('yatirimOzetiFinansmanOrani');
        const basvuruKatkisi = YatirimOzetiHiddenSayi('yatirimOzetiBasvuruSahibiKatkisi');
        const toplamGelir = yatirimOzetiUrunRows.reduce((sum, row) => sum + Number(row.miktar || 0) * Number(row.birimFiyat || 0), 0);
        const toplamGider = yatirimOzetiGiderRows.reduce((sum, row) => sum + Number(row.aylikTutar || 0) * 12, 0);
        YatirimOzetiText('ozetToplamYatirim', YatirimOzetiPara(toplamYatirim));
        YatirimOzetiText('ozetTalepFinansman', YatirimOzetiPara(toplamYatirim * finansmanOrani / 100));
        YatirimOzetiText('ozetBasvuruKatkisi', YatirimOzetiPara(basvuruKatkisi));
        YatirimOzetiText('ozetNetEtki', YatirimOzetiPara(toplamGelir - toplamGider));
    }

    function YatirimOzetiKaydet(afterSuccess) {
        const model = {
            ...BasvuruKimlikleri(),
            yatirimOzetiJson: JSON.stringify({
                hesaplanan: {
                    toplamYatirimTutari: YatirimOzetiHiddenSayi('yatirimOzetiToplamYatirimTutari'),
                    talepEdilenFinansmanOrani: YatirimOzetiHiddenSayi('yatirimOzetiFinansmanOrani'),
                    basvuruSahibiKatkisi: YatirimOzetiHiddenSayi('yatirimOzetiBasvuruSahibiKatkisi'),
                    talepEdilenVadeSuresiYil: YatirimOzetiHiddenSayi('yatirimOzetiVadeSuresiYil')
                },
                urunler: yatirimOzetiUrunRows,
                sabitGiderler: yatirimOzetiGiderRows
            })
        };
        AjaxPost('/Basvuru/KaydetYatirimOzeti', model, SonucGosterVeDirtyTemizle);
    }

    function YatirimOzetiHiddenSayi(id) {
        return YatirimOzetiSayi(document.getElementById(id)?.value || '');
    }

    function YatirimOzetiSayi(value) {
        const text = String(value ?? '').trim();
        if (!text) return 0;
        const normalized = text.includes(',')
            ? text.replace(/\./g, '').replace(',', '.')
            : (/^\d{1,3}(\.\d{3})+$/.test(text) ? text.replace(/\./g, '') : text);
        const number = Number(normalized);
        return Number.isFinite(number) ? number : 0;
    }

    function YatirimOzetiPara(value) {
        return Number(value || 0).toLocaleString('tr-TR', { maximumFractionDigits: 2 });
    }

    function YatirimOzetiText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    const yatirimOzetiBudgetRows = [
        { key: 'A', label: 'A - Uygun Harcamalar', type: 'sum', children: ['A1', 'A2', 'A3', 'A4'] },
        { key: 'A1', label: 'A1 - Yapım İşleri', type: 'input' },
        { key: 'A2', label: 'A2 - Makine ve Ekipman Alımları', type: 'input' },
        { key: 'A3', label: 'A3 - Genel Harcamalar (Hizmet Alımları)', type: 'input' },
        { key: 'A4', label: 'A4 - Görünürlük Harcamaları', type: 'input' },
        { key: 'B', label: 'B - Uygun Olmayan Harcamalar', type: 'sum', children: ['B1', 'B2', 'B3', 'B4', 'B5', 'B6', 'B7'] },
        { key: 'B1', label: 'B1 - Yapım İşleri', type: 'input' },
        { key: 'B2', label: 'B2 - Makine ve Ekipman Alımları', type: 'input' },
        { key: 'B3', label: 'B3 - Diğer Harcamalar', type: 'input' },
        { key: 'B4', label: 'B4 - Genel Harcamalar (Hizmet Alımları)', type: 'input' },
        { key: 'B5', label: 'B5 - İşletme Sermayesi Değişimi', type: 'input' },
        { key: 'B6', label: 'B6 - Yatırım Dönemi Finansman Giderleri', type: 'input' },
        { key: 'B7', label: 'B7 - Yatırım Dönemi KDV Ödemeleri', type: 'input' },
        { key: 'C', label: 'C - Toplam Yatırım Tutarı (A+B)', type: 'sum', children: ['A', 'B'] },
        { key: 'D', label: 'D - Özkaynak', type: 'input', group: 'finance' },
        { key: 'E', label: 'E - Banka Kredisi', type: 'input', group: 'finance' },
        { key: 'F', label: 'F - IPARD Destek Tutarı', type: 'sum', children: ['F1', 'F2'], group: 'finance' },
        { key: 'F1', label: 'F1 - 1. Taksit', type: 'input', group: 'finance' },
        { key: 'F2', label: 'F2 - 2. Taksit', type: 'input', group: 'finance' },
        { key: 'G', label: 'G - Diğer Kaynaklar', type: 'input', group: 'finance' },
        { key: 'H', label: 'H - Finansman Kaynakları Toplamı (D+E+F+G)', type: 'sum', children: ['D', 'E', 'F', 'G'], group: 'finance' }
    ];
    const yatirimOzetiPeriodLabels = ['Mevcut Durum', '1. Yıl', '2. Yıl', '3. Yıl', '4. Yıl', '5. Yıl', '6. Yıl', '7. Yıl', '8. Yıl', '9. Yıl', '10. Yıl'];
    const yatirimOzetiProductionMetrics = [
        { key: 'capacity', label: 'Kurulu Kapasite' },
        { key: 'production', label: 'Üretim Miktarı' },
        { key: 'sales', label: 'Satış Miktarı' },
        { key: 'price', label: 'Birim Satış Fiyatı' }
    ];

    function YatirimOzetiVarsayilanButce() {
        const data = {};
        yatirimOzetiBudgetRows.filter(row => row.type === 'input').forEach(row => data[row.key] = { t1: '', t2: '' });
        return data;
    }

    function YatirimOzetiVarsayilanUrun() {
        const data = {};
        yatirimOzetiProductionMetrics.forEach(metric => data[metric.key] = yatirimOzetiPeriodLabels.map(() => ''));
        return { name: '', unit: '', data: data };
    }

    function YatirimOzetiBolumuIlklendir() {
        const raw = document.getElementById('yatirimOzetiJson')?.value || '';
        yatirimOzetiBudgetData = YatirimOzetiVarsayilanButce();
        yatirimOzetiUrunRows = [YatirimOzetiVarsayilanUrun()];
        yatirimOzetiGiderRows = YatirimOzetiVarsayilanGiderler();
        if (raw) {
            try {
                const data = JSON.parse(raw);
                yatirimOzetiBudgetData = data.investmentBudgetData || data.butce || yatirimOzetiBudgetData;
                yatirimOzetiUrunRows = Array.isArray(data.productionRows) ? data.productionRows : (Array.isArray(data.urunler) ? data.urunler : yatirimOzetiUrunRows);
                yatirimOzetiGiderRows = Array.isArray(data.operatingExpenseRows) ? data.operatingExpenseRows : (Array.isArray(data.sabitGiderler) ? data.sabitGiderler : yatirimOzetiGiderRows);
            }
            catch {
                yatirimOzetiBudgetData = YatirimOzetiVarsayilanButce();
            }
        }
        if (!Array.isArray(yatirimOzetiUrunRows) || yatirimOzetiUrunRows.length === 0) yatirimOzetiUrunRows = [YatirimOzetiVarsayilanUrun()];
        if (!Array.isArray(yatirimOzetiGiderRows) || yatirimOzetiGiderRows.length === 0) yatirimOzetiGiderRows = YatirimOzetiVarsayilanGiderler();
        YatirimOzetiRender();
    }

    function YatirimOzetiRender() {
        YatirimOzetiButceRender();
        YatirimOzetiUrunRender();
        YatirimOzetiGiderRender();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiButceDegeri(key, part) {
        const row = yatirimOzetiBudgetRows.find(item => item.key === key);
        if (!row) return 0;
        if (row.type === 'input') return YatirimOzetiSayi(yatirimOzetiBudgetData?.[key]?.[part]);
        return (row.children || []).reduce((sum, child) => sum + YatirimOzetiButceDegeri(child, part), 0);
    }

    function YatirimOzetiButceSatirToplami(key) {
        return YatirimOzetiButceDegeri(key, 't1') + YatirimOzetiButceDegeri(key, 't2');
    }

    function YatirimOzetiButceToplamlari() {
        const investment = YatirimOzetiButceSatirToplami('C');
        const finance = YatirimOzetiButceSatirToplami('H');
        return { investment: investment, finance: finance, gap: finance - investment };
    }

    function YatirimOzetiButceRender() {
        const container = document.getElementById('investmentBudgetBox');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        let html = `<div class="table-responsive"><table class="table table-bordered yatirim-ozeti-budget-table"><thead><tr>
            <th>Bölüm / Harcama Kalemi</th><th>1. Taksit (TL)</th><th>2. Taksit (TL)</th><th>Toplam (TL)</th>
        </tr></thead><tbody>`;
        yatirimOzetiBudgetRows.forEach(row => {
            const sumClass = row.type === 'sum' ? ' class="summary-row"' : '';
            html += `<tr${sumClass}><td><strong>${htmlEncode(row.label)}</strong></td>`;
            ['t1', 't2'].forEach(part => {
                if (row.type === 'sum') {
                    html += `<td><strong id="butce_${row.key}_${part}">${YatirimOzetiPara(YatirimOzetiButceDegeri(row.key, part))}</strong></td>`;
                }
                else {
                    const value = yatirimOzetiBudgetData?.[row.key]?.[part] ?? '';
                    html += `<td><input type="text" inputmode="decimal" value="${htmlEncode(YatirimOzetiInputPara(value))}" ${disabled} placeholder="TL" oninput="YatirimOzetiButceGuncelle('${row.key}', '${part}', this.value)" onblur="YatirimOzetiButceInputCikis(this, '${row.key}', '${part}')" /></td>`;
                }
            });
            html += `<td><strong id="butce_${row.key}_toplam">${YatirimOzetiPara(YatirimOzetiButceSatirToplami(row.key))}</strong></td></tr>`;
        });
        html += '</tbody></table></div><div id="investmentBudgetAlerts"></div>';
        container.innerHTML = html;
    }

    function YatirimOzetiButceGuncelle(key, part, value) {
        if (!yatirimOzetiBudgetData[key]) yatirimOzetiBudgetData[key] = { t1: '', t2: '' };
        yatirimOzetiBudgetData[key][part] = value;
        dirty = true;
        YatirimOzetiButceToplamlariniGuncelle();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiButceInputCikis(input, key, part) {
        const sayi = YatirimOzetiSayi(input.value);
        input.value = input.value.trim() === '' ? '' : YatirimOzetiPara(sayi);
        if (!yatirimOzetiBudgetData[key]) yatirimOzetiBudgetData[key] = { t1: '', t2: '' };
        yatirimOzetiBudgetData[key][part] = input.value;
        YatirimOzetiButceToplamlariniGuncelle();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiButceToplamlariniGuncelle() {
        yatirimOzetiBudgetRows.forEach(row => {
            ['t1', 't2'].forEach(part => YatirimOzetiText(`butce_${row.key}_${part}`, YatirimOzetiPara(YatirimOzetiButceDegeri(row.key, part))));
            YatirimOzetiText(`butce_${row.key}_toplam`, YatirimOzetiPara(YatirimOzetiButceSatirToplami(row.key)));
        });
    }

    function YatirimOzetiInputPara(value) {
        const text = String(value ?? '').trim();
        if (!text) return '';
        return YatirimOzetiPara(YatirimOzetiSayi(text));
    }

    function YatirimOzetiUrunNormalize(row) {
        const normalized = row && typeof row === 'object' ? row : YatirimOzetiVarsayilanUrun();
        normalized.name = normalized.name || '';
        normalized.unit = normalized.unit || '';
        normalized.data = normalized.data || {};
        yatirimOzetiProductionMetrics.forEach(metric => {
            if (!Array.isArray(normalized.data[metric.key])) normalized.data[metric.key] = yatirimOzetiPeriodLabels.map(() => '');
            while (normalized.data[metric.key].length < yatirimOzetiPeriodLabels.length) normalized.data[metric.key].push('');
        });
        return normalized;
    }

    function YatirimOzetiUrunRender() {
        const container = document.getElementById('productionInfoBox');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        let html = '';
        yatirimOzetiUrunRows.forEach((row, index) => {
            row = YatirimOzetiUrunNormalize(row);
            yatirimOzetiUrunRows[index] = row;
            html += `<div class="yatirim-ozeti-product-block"><div class="form-grid two-fields">
                <label>Ürün / Ürün Grubu Adı<input value="${htmlEncode(row.name)}" ${disabled} oninput="YatirimOzetiUrunBaslikGuncelle(${index}, 'name', this.value)" /></label>
                <label>Birim<input value="${htmlEncode(row.unit)}" ${disabled} oninput="YatirimOzetiUrunBaslikGuncelle(${index}, 'unit', this.value)" /></label>
            </div><div class="table-responsive"><table class="table table-bordered yatirim-ozeti-production-table"><thead><tr><th>Gösterge</th>${yatirimOzetiPeriodLabels.map(label => `<th>${htmlEncode(label)}</th>`).join('')}</tr></thead><tbody>`;
            yatirimOzetiProductionMetrics.forEach(metric => {
                html += `<tr><td><strong>${htmlEncode(metric.label)}</strong></td>`;
                yatirimOzetiPeriodLabels.forEach((_, periodIndex) => {
                    html += `<td><input type="number" step="0.01" value="${htmlEncode(row.data[metric.key][periodIndex] || '')}" ${disabled} oninput="YatirimOzetiUrunVeriGuncelle(${index}, '${metric.key}', ${periodIndex}, this.value)" /></td>`;
                });
                html += '</tr>';
            });
            html += `</tbody></table></div><button type="button" class="btn btn-outline-danger" ${disabled} onclick="YatirimOzetiUrunSil(${index})">Bu ürün satırını sil</button></div>`;
        });
        container.innerHTML = html;
    }

    function YatirimOzetiUrunBaslikGuncelle(index, field, value) {
        yatirimOzetiUrunRows[index] = YatirimOzetiUrunNormalize(yatirimOzetiUrunRows[index]);
        yatirimOzetiUrunRows[index][field] = value;
        dirty = true;
    }

    function YatirimOzetiUrunVeriGuncelle(index, metric, periodIndex, value) {
        yatirimOzetiUrunRows[index] = YatirimOzetiUrunNormalize(yatirimOzetiUrunRows[index]);
        yatirimOzetiUrunRows[index].data[metric][periodIndex] = value;
        dirty = true;
    }

    function YatirimOzetiUrunEkle() {
        yatirimOzetiUrunRows.push(YatirimOzetiVarsayilanUrun());
        dirty = true;
        YatirimOzetiUrunRender();
    }

    function YatirimOzetiUrunSil(index) {
        yatirimOzetiUrunRows.splice(index, 1);
        if (yatirimOzetiUrunRows.length === 0) yatirimOzetiUrunRows.push(YatirimOzetiVarsayilanUrun());
        dirty = true;
        YatirimOzetiUrunRender();
    }

    function YatirimOzetiVarsayilanGiderler() {
        return [
            { group: 'Direkt İlk Madde ve Malzeme', item: 'İlk Madde Kullanımı', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Direkt İlk Madde ve Malzeme', item: 'Yardımcı Madde', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Direkt İlk Madde ve Malzeme', item: 'İşletme Malzemesi Kullanımı', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Direkt İşçilik Giderleri', item: 'Direkt İşçilik', qty: '', unit: 'Kişi/Yıl', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Genel Üretim Giderleri', item: 'Elektrik Giderleri', qty: '', unit: 'kWh', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Genel Üretim Giderleri', item: 'Su / Gaz Giderleri', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
