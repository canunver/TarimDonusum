@using System.Globalization
@using System.Text.Json
@model TarimDonusum.ViewModels.Basvuru.BasvuruFormViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    var b = Model.Basvuru;
    bool ro = Model.SaltOkunur;
    bool kilitli = b.Id <= 0 && !Model.DenetciGorunumu;
    int sonBolum = Model.DenetciGorunumu ? 8 : 7;

    bool CheckedStr(IEnumerable<string> values, string value) => values.Contains(value);
    bool CheckedInt(IEnumerable<int> values, int value) => values.Contains(value);
    bool CheckedDZA(IEnumerable<DegerZinciriAsama> values, int value) => value == 1;
    
    string T(string key) => L[key].Value;
    string[] Items(string key) => T(key).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    string[] evetHayir = Items("Basvuru.Options.YesNo");    
    string[] belgeGruplari =
    [
        "Adli sicil kaydı",
        "Gelir tablosu",
        "Bilanço",
        "İflas, konkordato ve tasfiye sürecinin olmadığına dair belge",
        "Ticaret sicil gazetesi (kuruluş ve mevcut)",
        "Noter onaylı imza sirküleri"
    ];
    
    string basvuruIlAdi = b.basvuruFirma.il?.ad ?? "";
    if (string.IsNullOrWhiteSpace(basvuruIlAdi) && b.basvuruFirma.il.id>0)
    {
        basvuruIlAdi = Model.Iller.FirstOrDefault(x => x.id == b.basvuruFirma.il.id)?.ad ?? "";
    }

    Donem? maliDonem = b.basvuruFirma.donem;
    if ((maliDonem == null || maliDonem.yil <= 0) && b.basvuruFirma.donem.id > 0)
    {
        maliDonem = Model.Donemler.FirstOrDefault(x => x.id == b.basvuruFirma.donem.id);
    }

    int maliOncekiYil = maliDonem?.yil > 1 ? maliDonem.yil - 2 : 0;
    int maliSonYil = maliDonem?.yil > 0 ? maliDonem.yil - 1 : 0;
    string maliOncekiYilBaslik = maliOncekiYil > 0
        ? string.Format(T("Basvuru.Mali.OncekiYilHeader"), maliOncekiYil)
        : T("Basvuru.Mali.OncekiYilFallback");
    string maliSonYilBaslik = maliSonYil > 0
        ? string.Format(T("Basvuru.Mali.SonYilHeader"), maliSonYil)
        : T("Basvuru.Mali.SonYilFallback");
}

<div class="basvuru-page">
    <div class="basvuru-titlebar">
        <div>
            <h1>@(Model.DenetciGorunumu ? T("Basvuru.Form.AuditTitle") : (b.Id > 0 ? T("Basvuru.Form.EditTitle") : T("Basvuru.Form.NewTitle")))</h1>
            <p>@string.Format(T("Basvuru.Form.ApplicationNo"), b.Id > 0 ? b.Id.ToString() : T("Basvuru.Form.ApplicationNoPending"))</p>
        </div>
    </div>

    <div id="ajaxMesaj"
         class="alert alert-info alert-dismissible floating-message"
         style="display:@(TempData["Mesaj"] != null ? "block" : "none")">
        <span id="ajaxMesajMetin">@TempData["Mesaj"]</span>
        <button type="button" id="ajaxMesajKapat" class="close" aria-label="@T("Basvuru.Common.Close")">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    @if (Model.Hatalar.Count > 0)
    {
        <div class="alert alert-danger">
            @foreach (string hata in Model.Hatalar)
            {
                <div>@hata</div>
            }
        </div>
    }

    @if (kilitli)
    {
        <div class="alert alert-warning">@L["Basvuru.Warning.FirstSectionRequired"]</div>
    }

    <div class="alert alert-info">@L["Basvuru.Flow.Note"]</div>

    <div class="basvuru-stepbar">
        <label for="basvuruStepSelect">@L["Basvuru.Common.Steps"]</label>
        <select id="basvuruStepSelect" class="form-control">
            <option value="1" selected="selected">@L["Basvuru.Step.1"]</option>
            <option value="2" disabled="@(kilitli)">@L["Basvuru.Step.2"]</option>
            <option value="3" disabled="@(kilitli)">@L["Basvuru.Step.3"]</option>
            <option value="4" disabled="@(kilitli)">@L["Basvuru.Step.4"]</option>
            <option value="5" disabled="@(kilitli)">@L["Basvuru.Step.5"]</option>
            <option value="6" disabled="@(kilitli)">@L["Basvuru.Step.6"]</option>
            <option value="7" disabled="@(kilitli)">@L["Basvuru.Step.7"]</option>
            @if (Model.DenetciGorunumu)
            {
                <option value="8">@L["Basvuru.Step.8"]</option>
            }
        </select>
        <button type="button" class="btn btn-outline-secondary nav-prev">@L["Basvuru.Common.Previous"]</button>
        <button type="button" class="btn btn-primary" onclick="PaneliKaydet()">@L["Basvuru.Common.Save"]</button>
        <button type="button" class="btn btn-outline-primary nav-next">@L["Basvuru.Common.Next"]</button>
        <button type="button" class="btn btn-outline-info icon-action" id="stepHelpBtn" title="@T("Basvuru.Common.Help")">?</button>
    </div>
    <input type="hidden" name="Basvuru.Id" value="@b.Id" />
    <div class="basvuru-shell">
        <main class="basvuru-panels">
            <section class="basvuru-panel active" data-panel="1">
                <h2>@L["Basvuru.Section1.Title"]</h2>
                <p>@L["Basvuru.Section1.Description"]</p>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="basvuruDonemi">@L["Basvuru.Field.BasvuruDonemi"]</label>
                        <select id="basvuruDonemi" name="Basvuru.DonemId" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            @foreach (var donem in Model.Donemler)
                            {
                                bool secili = b.basvuruFirma.donem.id == donem.id;
                                bool secilebilir = donem.SecilebilirMi();
                                string durum = secilebilir ? T("Basvuru.Donem.Open") : T("Basvuru.Donem.Closed");
                                <option value="@donem.id" selected="@secili" disabled="@(!secilebilir && !secili)">
                                    @donem.ad (@durum)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line">
                        <label for="basvuruIl">@L["Basvuru.Field.Il"]</label>
                        <select id="basvuruIl" name="Basvuru.IlId" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            @foreach (var il in Model.Iller)
                            {
                                <option value="@il.id" selected="@(b.basvuruFirma.il.id == il.id)">@il.kod.ToString("00") - @il.ad</option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line company-line">
                        <label for="vergiKimlikNo">@L["Basvuru.Field.VergiKimlikNo"]</label>
                        <input type="hidden" id='firmaId' name="Basvuru.FirmaId" value="@b.basvuruFirma.firma.id" />

                        <input id="vergiKimlikNo" name="Basvuru.VergiKimlikNo" value="@b.basvuruFirma.firma.vergiKimlikNo" disabled="@ro" />
                        @if (!ro)
                        {
                            <button type="button" class="btn btn-outline-primary icon-action" id="firmaSorgulaBtn" title="@T("Basvuru.Firma.Query")">?</button>
                            <button type="button" class="btn btn-outline-success icon-action" id="firmaYeniBtn" title="@T("Basvuru.Firma.ModalTitle")">+</button>
                            <button type="button" class="btn btn-outline-secondary icon-action" id="firmaDuzenleBtn" title="@T("Basvuru.Common.Edit")">
                                <i class="fas fa-edit"></i>
                            </button>
                        }
                    </div>

                    <div class="preapp-line">
                        <label for="firmaAdi">@L["Basvuru.Field.FirmaAdi"]</label>
                        <input id="firmaAdi" name="Basvuru.TicaretUnvani" value="@b.basvuruFirma.firma.ticaretUnvani" readonly aria-label="@T("Basvuru.Field.FirmaAdi")" />
                    </div>

                    <div class="preapp-line two-fields">
                        <label for="basvuruKonusu">@L["Basvuru.Field.BasvuruKonusu"]</label>
                        <input id="basvuruKonusu" name="Basvuru.BasvuruKonusu" value="@b.basvuruFirma.basvuruKonusu" disabled="@ro" />
                        <label for="basvuruTipi">@L["Basvuru.Field.BasvuruTipi"]</label>
                        <select id="basvuruTipi" name="Basvuru.BasvuruSahibiTuru" disabled="@ro">
                            @foreach (TarimDonusum.Models.enumBasvuruSahibiTuru item in Enum.GetValues<TarimDonusum.Models.enumBasvuruSahibiTuru>())
                            {
                                <option value="@((int)item)" selected="@(b.basvuruFirma.basvuruSahibiTuru == item)">@IsimBul.EnumAdi(item, L)</option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line">
                        <label for="sonIkiYil">@L["Basvuru.Field.SonIkiYildirFaalMi"]</label>
                        <select id="sonIkiYil" name="Basvuru.SonIkiYildirFaalMi" disabled="@ro">
                            <option value="false" selected="@(!b.basvuruFirma.sonIkiYildirFaalMi)">@(evetHayir.Length > 1 ? evetHayir[1] : "Hayır")</option>
                            <option value="true" selected="@(b.basvuruFirma.sonIkiYildirFaalMi)">@(evetHayir.Length > 0 ? evetHayir[0] : "Evet")</option>
                        </select>
                    </div>

                    <h3 class="preapp-subtitle">@L["Basvuru.Section2.PartnershipTitle"]</h3>
                    <div class="preapp-line two-fields">
                        <label for="ozelSektorPayi">@L["Basvuru.Field.OzelSektorPayi"]</label>
                        <input id="ozelSektorPayi" name="Basvuru.OzelSektorPayi" type="text" value="@IsimBul.MetneCevirKuruslu(b.basvuruFirma.ozelSektorPayi)" disabled="@ro" />
                        <label for="bagliOrtakIsletmeVarMi">@L["Basvuru.Field.BagliOrtakIsletmeVarMi"]</label>
                        <select id="bagliOrtakIsletmeVarMi" name="Basvuru.BagliOrtakIsletmeVarMi" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            <option value="false" selected="@(!b.basvuruFirma.bagliOrtakIsletmeVarMi )">@(evetHayir.Length > 1 ? evetHayir[1] : "Hayır")</option>
                            <option value="true" selected="@(b.basvuruFirma.bagliOrtakIsletmeVarMi )">@(evetHayir.Length > 0 ? evetHayir[0] : "Evet")</option>
                        </select>
                    </div>
                    <div class="preapp-line textarea-line"><label for="bagliOrtakAciklama">@L["Basvuru.Field.BagliOrtakAciklama"]</label>
                        <textarea id="bagliOrtakAciklama" name="Basvuru.BagliOrtakAciklama" disabled="@ro">@b.basvuruFirma.bagliOrtakAciklama</textarea>
                    </div>
                </div>
            </section>
            <section class="basvuru-panel" data-panel="2">
                <h2>@L["Basvuru.Section2.Title"]</h2>
                <h3 class="preapp-subtitle">@L["Basvuru.ContactInformation"]</h3>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="irtibatKisisi">@L["Basvuru.Field.IrtibatKisisi"]</label>
                        <input id="irtibatKisisi" name="Basvuru.irtibat.kisi" value="@b.irtibat.kisi" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatUnvani">@L["Basvuru.Field.IrtibatUnvani"]</label>
                        <input id="irtibatUnvani" name="Basvuru.irtibat.unvan" value="@b.irtibat.unvan" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatTelefon">@L["Basvuru.Field.IrtibatTelefon"]</label>
                        <input id="irtibatTelefon" name="Basvuru.irtibat.telefon" value="@b.irtibat.telefon" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatEposta">@L["Basvuru.Field.IrtibatEposta"]</label>
                        <input id="irtibatEposta" name="Basvuru.irtibat.ePosta" type="email" value="@b.irtibat.ePosta" disabled="@ro" />
                    </div>
                    <div class="preapp-line textarea-line">
                        <label for="iletisimAdresi">@L["Basvuru.Field.IletisimAdresi"]</label>
                        <textarea id="iletisimAdresi" name="Basvuru.irtibat.adres" disabled="@ro">@b.irtibat.adres</textarea>
                    </div>
                    <div class="preapp-line textarea-line">
                        <label for="yetkiliKisiler">@L["Basvuru.Field.YetkiliKisiler"]</label>
                        <textarea id="yetkiliKisiler" name="Basvuru.irtibat.yetkiliKisiler" disabled="@ro">@b.irtibat.yetkiliKisiler</textarea>
                    </div>
                </div>
            </section>
            <section class="basvuru-panel" data-panel="3">
                <h2>@L["Basvuru.Section3.Title"]</h2>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="yatirimAdi">@L["Basvuru.Field.YatirimAdi"]</label>
                        <input id="yatirimAdi" name="Basvuru.YatirimAdi" value="@b.yatirim.yatirimAdi" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="yatirimTuru">@L["Basvuru.Field.YatirimTuru"]</label>
                        <select id="yatirimTuru" name="Basvuru.yatirim.yatirimTuru" disabled="@ro">
                            @foreach (enumYatirimTuru item in Enum.GetValues<enumYatirimTuru>())
                            {
                                <option value="@((int)item)" selected="@(b.yatirim.yatirimTuru == item)">
                                    @IsimBul.EnumAdi(item, L)
                                </option>
                            }

                        </select>
                    </div>
                    <div class="preapp-line">
                        <label for="degerZinciriSelect">@L["Basvuru.Field.DegerZinciri"]</label>
                        <select id="degerZinciriSelect" name="Basvuru.DegerZinciriId" disabled="@ro">
                        </select>
                    </div>
                </div>
                <h3>@L["Basvuru.Field.DegerZinciriAsamalari"]</h3>
                <div class="table-responsive deger-zinciri-asama-wrap">
                    <table class="table deger-zinciri-asama-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Common.Select"]</th>
                                <th>@L["Basvuru.Field.DegerZinciriAsamasi"]</th>
                                <th>@L["Basvuru.Field.KisaAciklama"]</th>
                            </tr>
                        </thead>
                        <tbody id="degerZinciriAsamaListesi">
                        </tbody>
                    </table>
                </div>
                <h3>@L["Basvuru.Field.HarcamaTurleri"]</h3>
                <div class="check-grid">
                    @foreach (var item in Enum.GetValues<enumHarcamaTuru>())
                    {
                        if ((int)item > 0)
                        {
                            <label><input type="checkbox" name="Basvuru.yatirim.harcamaTurleri" value="@((int)item)" checked="@CheckedInt(b.yatirim.harcamaTurleri, (int)item)" disabled="@ro" /> @IsimBul.EnumAdi(item, L)</label>
                        }
                    }
                </div>
            </section>
            <section class="basvuru-panel" data-panel="4">
                <h2>@L["Basvuru.Section4.Title"]</h2>
                <div class="adres-toolbar">
                    @if (!ro)
                    {
                        <button type="button" class="btn btn-outline-primary" id="adresYeniBtn"><i class="fas fa-plus"></i> @L["Basvuru.Address.New"]</button>
                    }
                </div>
                <div class="table-responsive uygulama-adres-wrap">
                    <table class="table uygulama-adres-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Field.SiraNo"]</th>
                                <th>@L["Basvuru.Field.Il"]</th>
                                <th>@L["Basvuru.Field.Ilce"]</th>
                                <th>@L["Basvuru.Field.TamAdres"]</th>
                                <th>@L["Basvuru.Field.YatirimYeriStatusu"]</th>
                                <th>@L["Basvuru.Field.KiraTahsis"]</th>
                                <th>@L["Basvuru.Field.YapiRuhsatiDurumu"]</th>
                                @if (!ro)
                                {
                                    <th>@L["Basvuru.Common.Actions"]</th>
                                }
                            </tr>
                        </thead>
                        <tbody id="uygulamaAdresListesi"></tbody>
                    </table>
                </div>
            </section>
            <section class="basvuru-panel" data-panel="5">
                <h2>@L["Basvuru.Section5.Title"]</h2>
                <div class="form-grid">
                    <label>@L["Basvuru.Field.ToplamYatirimTutari"]<input class="money-integer" name="Basvuru.finans.ToplamYatirimTutari" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.finans.toplamYatirimTutari)" disabled="@ro" /></label>
                    <label>@L["Basvuru.Field.UygunHarcamaTutari"]<input class="money-integer" name="Basvuru.finans.UygunHarcamaTutari" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.finans.uygunHarcamaTutari)" disabled="@ro" /></label>
                    <label>@L["Basvuru.Field.TalepEdilenDestekTutari"]<input class="money-integer" name="Basvuru.finans.TalepEdilenDestekTutari" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.finans.talepEdilenDestekTutari)" disabled="@ro" /></label>
                    <label>@L["Basvuru.Field.BasvuruSahibiKatkisi"]<input class="money-integer" name="Basvuru.finans.BasvuruSahibiKatkisi" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.finans.basvuruSahibiKatkisi)" disabled="@ro" /></label>
                    <label>@L["Basvuru.Field.DestekOrani"]<input name="Basvuru.finans.DestekOrani" type="text" value="@IsimBul.MetneCevirKuruslu(b.finans.destekOrani)" disabled="@ro" /></label>
                </div>
                <label class="wide-label">@L["Basvuru.Field.YatiriminAmaci"]<textarea name="Basvuru.finans.YatiriminAmaci" disabled="@ro">@b.finans.yatiriminAmaci</textarea></label>
            </section>

            <section class="basvuru-panel" data-panel="6">
                <h2>@L["Basvuru.Section6.Title"]</h2>
                <div class="mali-section-title">@L["Basvuru.Mali.GelirTablosu"]</div>
                <div class="table-responsive mali-table-wrap">
                    <table class="table mali-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Mali.GelirTablosuKalemi"]</th>
                                <th>@maliOncekiYilBaslik</th>
                                <th>@maliSonYilBaslik</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@L["Basvuru.Mali.YillikNetSatisHasilati"]</td>
                                <td><input class="money-integer" name="Basvuru.mali.OncekiYilNetSatis" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.mali.oncekiYilNetSatis)" disabled="@ro" /></td>
                                <td><input class="money-integer" name="Basvuru.mali.SonYilNetSatis" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.mali.sonYilNetSatis)" disabled="@ro" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mali-section-title">@L["Basvuru.Mali.Bilanco"]</div>
                <div class="table-responsive mali-table-wrap">
                    <table class="table mali-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Mali.BilancoKalemi"]</th>
                                <th>@maliOncekiYilBaslik</th>
                                <th>@maliSonYilBaslik</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@L["Basvuru.Mali.AktifToplami"]</td>
                                <td><input class="money-integer" name="Basvuru.mali.OncekiYilAktifToplami" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.mali.oncekiYilAktifToplami)" disabled="@ro" /></td>
                                <td><input class="money-integer" name="Basvuru.mali.SonYilAktifToplami" type="text" inputmode="numeric" value="@IsimBul.MetneCevirKurussuz(b.mali.sonYilAktifToplami)" disabled="@ro" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="basvuru-panel" data-panel="7">
                <h2>@L["Basvuru.Section7.Title"]</h2>
                <p>Zorunlu belgeler tek bir doküman paketi olarak yüklenecektir. Ayrıca başvuru rehberi ekinde yer alan beyan ve taahhütler ayrı bir dosya olarak eklenecektir.</p>

                <div class="document-upload-box">
                    <div class="document-file-row">
                        <label class="btn btn-primary mb-0" for="belgePaketiDosya">Tek doküman paketini seç</label>
                        <input id="belgePaketiDosya" type="file" class="document-file-input" disabled="@ro" />
                        <span id="belgePaketiDosyaSecim" class="document-file-name">@(string.IsNullOrWhiteSpace(b.BelgePaketiDosyaAdi) ? "Henüz dosya seçilmedi." : b.BelgePaketiDosyaAdi)</span>
                    </div>
                    <label class="wide-label">Yüklenen doküman paketi adı <span class="required-mark">*</span>
                        <input name="Basvuru.BelgePaketiDosyaAdi" value="@b.BelgePaketiDosyaAdi" readonly />
                    </label>
                    <div class="document-note">Dosya sunucuya yüklendikten sonra dosya adı, dosya id bilgisi ve belge kontrol beyanı başvuru kaydına işlenir.</div>
                </div>

                <h3>@L["Basvuru.Field.BelgeGruplari"]</h3>
                <div class="check-grid">
                    @foreach (string belgeGrubu in belgeGruplari)
                    {
                        <label><input type="checkbox" class="belge-grubu-check" value="@belgeGrubu" disabled="@ro" /> @belgeGrubu <span class="required-mark">*</span></label>
                    }
                </div>
                <div class="document-two-column">
                    <label>@L["Basvuru.Field.BelgeBeyani"] <span class="required-mark">*</span>
                        <select id="belgeBeyaniSelect" name="Basvuru.BelgeBeyani" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            <option value="Evet" selected="@(string.Equals(b.BelgeBeyani, "Evet", StringComparison.OrdinalIgnoreCase))">Evet</option>
                            <option value="Hayır" selected="@(string.Equals(b.BelgeBeyani, "Hayır", StringComparison.OrdinalIgnoreCase))">Hayır</option>
                        </select>
                    </label>
                    <label>Belge açıklaması / not <span class="required-mark">*</span>
                        <textarea name="Basvuru.BelgePaketiAciklama" disabled="@ro">@b.BelgePaketiAciklama</textarea>
                    </label>
                </div>
                <div class="document-action-row">
                    @if (!ro)
                    {
                        <button type="button" class="btn btn-primary document-upload-action" id="belgePaketiYukleBtn">Tek Doküman Paketi Yükle</button>
                    }
                    <a class="btn btn-outline-primary document-download-action @(b.BelgePaketiDosyaId.HasValue ? "" : "d-none")"
                       id="belgePaketiIndirBtn"
                       href="@(b.BelgePaketiDosyaId.HasValue ? Url.Action("DosyaIndir", "Basvuru", new { id = b.BelgePaketiDosyaId.Value }) : "#")"
                       target="_blank"
                       rel="noopener">Dosya indir</a>
                </div>
                <input type="hidden" name="Basvuru.BelgePaketiDosyaId" value="@b.BelgePaketiDosyaId" />

                <h3>Taahhüt / Başvuru rehberi eki beyanlar</h3>
                <div class="document-upload-box">
                    <div class="document-file-row">
                        <label class="btn btn-primary mb-0" for="taahhutDosya">Taahhüt dosyasını seç</label>
                        <input id="taahhutDosya" type="file" class="document-file-input" disabled="@ro" />
                        <span id="taahhutDosyaSecim" class="document-file-name">@(string.IsNullOrWhiteSpace(b.TaahhutDosyaAdi) ? "Henüz dosya seçilmedi." : b.TaahhutDosyaAdi)</span>
                    </div>
                    <label class="wide-label">Yüklenen taahhüt / beyan dosyası adı <span class="required-mark">*</span>
                        <input name="Basvuru.TaahhutDosyaAdi" value="@b.TaahhutDosyaAdi" readonly />
                    </label>
                    <label class="wide-label">Taahhüt açıklaması / not <span class="required-mark">*</span>
                        <textarea name="Basvuru.TaahhutAciklama" disabled="@ro">@b.TaahhutAciklama</textarea>
                    </label>
                    <div class="document-note">Bu alan, başvuru rehberi ekinde yer alan beyan ve taahhütlerin imzalı/yetkili dosyasının yüklenmesi için ayrılmıştır.</div>
                </div>
                <div class="document-action-row">
                    @if (!ro)
                    {
                        <button type="button" class="btn btn-primary document-upload-action" id="taahhutYukleBtn">Taahhüt dosyayı ekle</button>
                    }
                    <a class="btn btn-outline-primary document-download-action @(b.TaahhutDosyaId.HasValue ? "" : "d-none")"
                       id="taahhutIndirBtn"
                       href="@(b.TaahhutDosyaId.HasValue ? Url.Action("DosyaIndir", "Basvuru", new { id = b.TaahhutDosyaId.Value }) : "#")"
                       target="_blank"
                       rel="noopener">Dosya indir</a>
                </div>
                <input type="hidden" name="Basvuru.TaahhutDosyaId" value="@b.TaahhutDosyaId" />
            </section>

            @if (Model.DenetciGorunumu)
            {
                <section class="basvuru-panel" data-panel="8">
                    <h2>@L["Basvuru.Section8.Title"]</h2>
                    <div class="metric-grid">
                        <div><span>@L["Basvuru.Common.Application"]</span><strong>@b.Id</strong></div>
                        <div><span>@L["Basvuru.Field.Durum"]</span><strong>@IsimBul.EnumAdi(@b.durum, L)</strong></div>
                        <div><span>@L["Basvuru.Field.BelgeGruplariShort"]</span><strong>b.BelgeGruplari.Count / belgeler.Length</strong></div>
                    </div>
                    <label class="wide-label">@L["Basvuru.Field.DenetciNotu"]<textarea name="Basvuru.DenetciNotu" disabled>@b.DenetciNotu</textarea></label>
                    <label class="wide-label">@L["Basvuru.Field.DenetimSonucu"]<input name="Basvuru.DenetimSonucu" value="@b.DenetimSonucu" disabled /></label>
                </section>
            }

            <div class="basvuru-footer">
                <div>
                </div>
            </div>
        </main>
    </div>
</div>

