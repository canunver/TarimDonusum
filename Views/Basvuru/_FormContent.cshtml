            { group: 'Beklenebilecek Farklar', item: 'Beklenebilecek Farklar', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Pazarlama, Satış ve Dağıtım Giderleri', item: 'Personel Giderleri', qty: '', unit: 'Kişi/Yıl', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Pazarlama, Satış ve Dağıtım Giderleri', item: 'Nakliye / Dağıtım Giderleri', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' },
            { group: 'Pazarlama, Satış ve Dağıtım Giderleri', item: 'Diğer Giderler', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' }
        ];
    }

    function YatirimOzetiGiderToplami(row) {
        return YatirimOzetiSayi(row.qty) * YatirimOzetiSayi(row.unitPrice);
    }

    function YatirimOzetiGiderToplamlari() {
        const total = yatirimOzetiGiderRows.reduce((sum, row) => sum + YatirimOzetiGiderToplami(row), 0);
        const fixed = yatirimOzetiGiderRows.reduce((sum, row) => sum + YatirimOzetiGiderToplami(row) * YatirimOzetiSayi(row.fixedPct) / 100, 0);
        const variable = yatirimOzetiGiderRows.reduce((sum, row) => sum + YatirimOzetiGiderToplami(row) * YatirimOzetiSayi(row.variablePct) / 100, 0);
        return { total: total, fixed: fixed, variable: variable };
    }

    function YatirimOzetiGiderRender() {
        const container = document.getElementById('operatingExpensesBox');
        if (!container) return;
        const disabled = basvuruReadonly ? 'disabled' : '';
        const totals = YatirimOzetiGiderToplamlari();
        let html = `<div class="table-responsive"><table class="table table-bordered yatirim-ozeti-expense-table"><thead><tr>
            <th>Gider Grubu</th><th>Gider Unsuru</th><th>Miktar</th><th>Birim</th><th>Birim Fiyat (TL)</th><th>Toplam Tutar (TL)</th><th>Sabit (%)</th><th>Değişken (%)</th><th>Giderdeki Pay (%)</th><th>Sabit Tutar</th><th>Değişken Tutar</th><th>İşlem</th>
        </tr></thead><tbody>`;
        yatirimOzetiGiderRows.forEach((row, index) => {
            row = row || {};
            yatirimOzetiGiderRows[index] = row;
            const total = YatirimOzetiGiderToplami(row);
            const fixed = total * YatirimOzetiSayi(row.fixedPct) / 100;
            const variable = total * YatirimOzetiSayi(row.variablePct) / 100;
            const share = totals.total ? total / totals.total * 100 : 0;
            html += `<tr>
                <td><input value="${htmlEncode(row.group || '')}" ${disabled} oninput="YatirimOzetiGiderGuncelle(${index}, 'group', this.value)" /></td>
                <td><input value="${htmlEncode(row.item || '')}" ${disabled} oninput="YatirimOzetiGiderGuncelle(${index}, 'item', this.value)" /></td>
                <td><input type="number" step="0.01" value="${htmlEncode(row.qty || '')}" ${disabled} onchange="YatirimOzetiGiderGuncelle(${index}, 'qty', this.value, true)" /></td>
                <td><input value="${htmlEncode(row.unit || '')}" ${disabled} oninput="YatirimOzetiGiderGuncelle(${index}, 'unit', this.value)" /></td>
                <td><input type="number" step="0.01" value="${htmlEncode(row.unitPrice || '')}" ${disabled} onchange="YatirimOzetiGiderGuncelle(${index}, 'unitPrice', this.value, true)" /></td>
                <td><strong>${YatirimOzetiPara(total)}</strong></td>
                <td><input type="number" min="0" max="100" step="0.01" value="${htmlEncode(row.fixedPct ?? '')}" ${disabled} onchange="YatirimOzetiGiderGuncelle(${index}, 'fixedPct', this.value, true)" /></td>
                <td><input type="number" min="0" max="100" step="0.01" value="${htmlEncode(row.variablePct ?? '')}" ${disabled} onchange="YatirimOzetiGiderGuncelle(${index}, 'variablePct', this.value, true)" /></td>
                <td>${share.toFixed(2)}</td>
                <td>${YatirimOzetiPara(fixed)}</td>
                <td>${YatirimOzetiPara(variable)}</td>
                <td><button type="button" class="btn btn-outline-danger" ${disabled} onclick="YatirimOzetiGiderSil(${index})">Sil</button></td>
            </tr>`;
        });
        html += `<tr class="summary-row"><th colspan="5">TOPLAM İŞLETME GİDERLERİ</th><th>${YatirimOzetiPara(totals.total)}</th><th></th><th></th><th>100.00</th><th>${YatirimOzetiPara(totals.fixed)}</th><th>${YatirimOzetiPara(totals.variable)}</th><th></th></tr>`;
        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function YatirimOzetiGiderGuncelle(index, field, value, rerender = false) {
        if (!yatirimOzetiGiderRows[index]) yatirimOzetiGiderRows[index] = {};
        yatirimOzetiGiderRows[index][field] = value;
        dirty = true;
        if (rerender) {
            YatirimOzetiGiderRender();
            YatirimOzetiKartlariGuncelle();
        }
    }

    function YatirimOzetiGiderEkle() {
        yatirimOzetiGiderRows.push({ group: '', item: '', qty: '', unit: '', unitPrice: '', fixedPct: '0', variablePct: '100' });
        dirty = true;
        YatirimOzetiGiderRender();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiGiderSil(index) {
        yatirimOzetiGiderRows.splice(index, 1);
        if (yatirimOzetiGiderRows.length === 0) yatirimOzetiGiderRows = YatirimOzetiVarsayilanGiderler();
        dirty = true;
        YatirimOzetiGiderRender();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiSabitGiderleriYukle() {
        yatirimOzetiGiderRows = YatirimOzetiVarsayilanGiderler();
        dirty = true;
        YatirimOzetiGiderRender();
        YatirimOzetiKartlariGuncelle();
    }

    function YatirimOzetiKartlariGuncelle() {
        const budget = YatirimOzetiButceToplamlari();
        const expense = YatirimOzetiGiderToplamlari();
        YatirimOzetiText('invBudgetTotalCard', `${YatirimOzetiPara(budget.investment)} TL`);
        YatirimOzetiText('financeSourceTotalCard', `${YatirimOzetiPara(budget.finance)} TL`);
        YatirimOzetiText('financeGapCard', `${YatirimOzetiPara(budget.gap)} TL`);
        YatirimOzetiText('opexTotalCard', `${YatirimOzetiPara(expense.total)} TL`);
        const alert = document.getElementById('investmentBudgetAlerts');
        if (alert) {
            if (budget.investment || budget.finance) {
                alert.innerHTML = Math.abs(budget.gap) > 1
                    ? `<div class="alert alert-warning">Finansman kaynakları toplamı ile toplam yatırım tutarı arasında ${YatirimOzetiPara(budget.gap)} TL fark bulunmaktadır.</div>`
                    : '<div class="alert alert-success">Yatırım bütçesi ile finansman kaynakları dengelidir.</div>';
            }
            else {
                alert.innerHTML = '<div class="alert alert-warning">Yatırım bütçesi ve finansman kaynakları henüz girilmemiştir.</div>';
            }
        }
    }

    function YatirimOzetiKaydet() {
        const model = {
            ...BasvuruKimlikleri(),
            yatirimOzetiJson: JSON.stringify({
                investmentBudgetData: yatirimOzetiBudgetData,
                productionRows: yatirimOzetiUrunRows,
                operatingExpenseRows: yatirimOzetiGiderRows,
                totals: {
                    budget: YatirimOzetiButceToplamlari(),
                    operatingExpense: YatirimOzetiGiderToplamlari()
                }
            })
        };
        AjaxPost('/Basvuru/KaydetYatirimOzeti', model, sonuc => SonucGosterVeDirtyTemizle(sonuc, afterSuccess));
    }

    function PaneliKaydet(afterSuccess) {
        if (active === bolumFirma) BasvuruSahibiKaydet(afterSuccess);
        else if (active === bolumIrtibat) FirmaIrtibatKaydet(afterSuccess);
        else if (active === bolumYatirim) DegerZinciriKaydet(afterSuccess);
        else if (active === bolumUygulamaAdresi) YatirimBilgileriKaydet(afterSuccess);
        else if (active === bolumUygunHarcama) UygunHarcamaKaydet(afterSuccess);
        else if (active === bolumFinans) FinansKaydet(afterSuccess);
        else if (active === bolumYatirimOzeti) YatirimOzetiKaydet(afterSuccess);
        else if (active === bolumMali) MaliKaydet(afterSuccess);
        else if (active === bolumOrtaklik) OrtaklikKaydet(afterSuccess);
        else if (active === bolumCevreselSosyal) CevreselSosyalKaydet(afterSuccess);
        else if (active === bolumBelgeler || active === bolumTaahhutBeyan) PopupMesajGoster(belgeMesajlari.sectionSaveInfo, true);
        else PopupMesajGoster(String(active), false);
    }

    function degerZinciriAsamalariYukle(zincirId) {
        const kimlik = BasvuruKimlikleri();
        const $tbody = $('#degerZinciriAsamaListesi');
        $tbody.empty();
        if (!zincirId) return;
        AjaxGet('/Basvuru/DegerZinciriAsamalariListele', { ...kimlik, zincirId: zincirId }, function (response) {
            if (response && response.nesne) {
                const isReadOnly = $('#degerZinciriSelect').is(':disabled') ? 'disabled' : '';
                $.each(response.nesne, function (_, item) {
                    const checkedAttr = item.secili ? 'checked="checked"' : '';
                    const faaliyet = item.yapilacakFaaliyetler || item.YapilacakFaaliyetler || '';
                    const disabledAttr = isReadOnly || !item.secili ? 'disabled' : '';
                    $tbody.append(`<tr>
                        <td class="text-center"><input type="checkbox" name="Basvuru.DegerZinciriAsamalari" value="${item.id}" ${checkedAttr} ${isReadOnly} /></td>
                        <td><strong>${htmlEncode(item.ad || '')}</strong></td>
                        <td>${htmlEncode(item.aciklama || '')}</td>
                        <td>
                            <textarea class="deger-zinciri-faaliyet" data-asama-id="${item.id}" maxlength="500" ${disabledAttr} placeholder="Seçilen aşama için en fazla 500 karakter">${htmlEncode(faaliyet)}</textarea>
                            <div class="char-counter"><span>${faaliyet.length}</span>/500</div>
                        </td>
                    </tr>`);
                });
                DegerZinciriFaaliyetIlklendir();
            }
        });
    }

    function DegerZinciriFaaliyetIlklendir() {
        $('#degerZinciriAsamaListesi input[name="Basvuru.DegerZinciriAsamalari"]').off('change.faaliyet').on('change.faaliyet', function () {
            const textarea = $(`textarea.deger-zinciri-faaliyet[data-asama-id="${this.value}"]`);
            textarea.prop('disabled', !this.checked);
            dirty = true;
        });
        $('#degerZinciriAsamaListesi textarea.deger-zinciri-faaliyet').off('input.faaliyet').on('input.faaliyet', function () {
            const value = this.value || '';
            $(this).siblings('.char-counter').find('span').text(value.length);
            dirty = true;
        });
    }

    function degerZinciriYukle() {
        const ilAlani = $('#basvuruIl');
        const ilId = ilAlani.length ? ilAlani.val() : basvuruIlId;
        const kimlik = BasvuruKimlikleri();
        const $select = $('#degerZinciriSelect');
        $select.html('<option value="">Seçiniz...</option>');
        $('#degerZinciriAsamaListesi').empty();
        if (!ilId) return;
        AjaxGet('/Basvuru/DegerZincirleriListele', { ...kimlik, ilId: ilId }, function (response) {
            if (response && response.nesne) {
                let aktifZincirId = null;
                $.each(response.nesne, function (_, item) {
                    const selectedAttr = item.secili ? 'selected="selected"' : '';
                    $select.append(`<option value="${item.id}" ${selectedAttr}>${item.ad}</option>`);
                    if (item.secili) aktifZincirId = item.id;
                });
                if (aktifZincirId) degerZinciriAsamalariYukle(aktifZincirId);
            }
        });
    }

    function UygulamaAdresiModalKaydet() {
        const indexText = modalValue('adresModalIndex');
        const mevcutAdres = indexText === '' ? {} : sonUygulamaAdresleri[Number(indexText)];
        const adres = {
            id: mevcutAdres?.id || 0,
            ...BasvuruKimlikleri(),
            siraNo: Number(modalValue('adresModalSiraNo') || 0) || 1,
            ilceId: Number(modalValue('adresModalIlce') || 0) || 0,
            tamAdres: modalValue('adresModalTamAdres'),
            yatirimYeriStatusu: Number(modalValue('adresModalYatirimYeriStatusu') || 0) || 0,
            kiraVeyaTahsisSuresi: Number(modalValue('adresModalKiraVeyaTahsisSuresi') || 0) || 0,
            kiraTahsisBitisTarihi: modalValue('adresModalKiraTahsisBitisTarihi'),
            yapiRuhsatiDurumu: Number(modalValue('adresModalYapiRuhsatiDurumu') || 0) || 0
        };
        adresKaydet(adres);
    }

    function adresKaydet(adres) {
        AjaxPost('/Basvuru/UygulamaAdresiKaydet', adres, SonucGosterGizle);
    }

    function adresSil(adresId) {
        if (!adresId) return;
        AjaxPost('/Basvuru/UygulamaAdresiSil', { ...BasvuruKimlikleri(), id: adresId }, SonucGosterGizle);
    }

    function SonucGoster(sonuc) {
        if (sonuc?.basarili) PopupMesajGoster(sonuc.mesaj, true);
        else PopupMesajGoster(sonuc?.hataStr || sonuc?.mesaj || '', false);
    }

    function SonucGosterVeDirtyTemizle(sonuc, afterSuccess) {
        if (sonuc?.basarili) dirty = false;
        SonucGoster(sonuc);
        if (sonuc?.basarili && typeof afterSuccess === 'function') afterSuccess();
    }

    function SonucGosterGizle(sonuc) {
        UygulamaAdresleriListele();
        uygulamaAdresModal?.hide();
        SonucGoster(sonuc);
    }

    function UygulamaAdresleriListele() {
        AjaxGet('/Basvuru/UygulamaAdresiListele', BasvuruKimlikleri(), function (response) {
            RenderUygulamaAdresleri(response.nesne);
        });
    }

    function adresModalAc(index) {
        const adres = index >= 0 ? sonUygulamaAdresleri[index] : {};
        modalSet('adresModalIndex', index >= 0 ? String(index) : '');
        modalSet('adresModalSiraNo', adres.siraNo);
        modalSet('adresModalIlce', adres.ilceId);
        modalSet('adresModalTamAdres', adres.tamAdres);
        modalSet('adresModalYatirimYeriStatusu', adres.yatirimYeriStatusu);
        modalSet('adresModalKiraVeyaTahsisSuresi', adres.kiraVeyaTahsisSuresi);
        modalSet('adresModalKiraTahsisBitisTarihi', adres.kiraTahsisBitisTarihi);
        modalSet('adresModalYapiRuhsatiDurumu', adres.yapiRuhsatiDurumu);
        uygulamaAdresModal?.show();
    }

    function RenderUygulamaAdresleri(uygulamaAdresleri) {
        const tbody = document.getElementById('uygulamaAdresListesi');
        if (!tbody) return;
        sonUygulamaAdresleri = uygulamaAdresleri || [];
        tbody.innerHTML = '';
        if (sonUygulamaAdresleri.length === 0) {
            const tr = document.createElement('tr');
            const td = document.createElement('td');
            td.colSpan = '8';
            td.className = 'text-muted text-center';
            td.textContent = adresBosMesaj;
            tr.appendChild(td);
            tbody.appendChild(tr);
            return;
        }
        sonUygulamaAdresleri.forEach((adres, index) => {
            const tr = document.createElement('tr');
            [adres.siraNo, adres.ilAdi, adres.ilceAdi, adres.tamAdres, adres.yatirimYeriStatusuAd, adres.kiraTahsisBitis, adres.yapiRuhsatiDurumuAd].forEach((value, alanIndex) => {
                const td = document.createElement('td');
                td.textContent = value || '';
                if (alanIndex === 3) td.className = 'adres-tam-adres';
                tr.appendChild(td);
            });
            const actionTd = document.createElement('td');
            const editBtn = document.createElement('button');
            editBtn.type = 'button';
            editBtn.className = 'btn btn-sm btn-outline-secondary mr-1';
            editBtn.innerHTML = '<i class="fas fa-edit"></i>';
            editBtn.addEventListener('click', () => adresModalAc(index));
            const deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'btn btn-sm btn-outline-danger';
            deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
            deleteBtn.addEventListener('click', () => {
                if (confirm(adresSilOnay)) adresSil(adres.id);
            });
            actionTd.appendChild(editBtn);
            actionTd.appendChild(deleteBtn);
            tr.appendChild(actionTd);
            tbody.appendChild(tr);
        });
    }

    function antiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    function dosyaSecimYaz(input, hedefId, dosyaAdiInputName) {
        const dosyaAdi = input.files && input.files.length ? input.files[0].name : belgeMesajlari.noFileSelected;
        const hedef = document.getElementById(hedefId);
        if (hedef) hedef.textContent = dosyaAdi;
        const dosyaAdiInput = document.querySelector(`[name="${dosyaAdiInputName}"]`);
        if (dosyaAdiInput && input.files && input.files.length) dosyaAdiInput.value = dosyaAdi;
    }

    function belgePaketiDogrula() {
        const dosya = document.getElementById('belgePaketiDosya');
