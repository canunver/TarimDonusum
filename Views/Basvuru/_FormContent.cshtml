    function sayiAlanBosMu(id) {
        return (document.getElementById(id)?.value || '').toString().trim() === '';
    }

    function sayiOkuId(id) {
        const value = (document.getElementById(id)?.value || '').toString().trim();
        if (!value) return null;
        const normalized = value.includes(',')
            ? value.replace(/\./g, '').replace(',', '.')
            : value.replace(/\s/g, '');
        const number = Number(normalized);
        return Number.isFinite(number) ? number : null;
    }

    function sayiYaz(value) {
        const number = Number(value || 0);
        return Number.isFinite(number) ? number.toLocaleString('tr-TR', { maximumFractionDigits: 2 }) : '';
    }

    function htmlEncode(value) {
        return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

