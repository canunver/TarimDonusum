@using System.Text.Json
@using TarimDonusum.Models
@model TarimDonusum.ViewModels.Basvuru.BasvuruFormViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    var b = Model.Basvuru;
    bool ro = Model.SaltOkunur;
    bool kilitli = b.Id <= 0 && !Model.DenetciGorunumu;
    IReadOnlyList<BasvuruBolumTanim> bolumler = BasvuruBolumleri.Tum(Model.DenetciGorunumu);
    BasvuruBolumTanim ilkBolum = bolumler.First();

    string T(string key) => L[key].Value;

    string basvuruIlAdi = b.basvuruFirma.il?.ad ?? "";
    if (string.IsNullOrWhiteSpace(basvuruIlAdi) && b.basvuruFirma.il.id > 0)
    {
        basvuruIlAdi = Model.Iller.FirstOrDefault(x => x.id == b.basvuruFirma.il.id)?.ad ?? "";
    }

    int donemYil = b.basvuruFirma.donem?.yil ?? 0;
    if (donemYil <= 0 && b.basvuruFirma.donemId > 0)
    {
        donemYil = Model.Donemler?.FirstOrDefault(x => x.id == b.basvuruFirma.donemId)?.yil ?? 0;
    }
    string oncekiMaliYil = donemYil > 0 ? (donemYil - 2).ToString() : "Önceki Yıl";
    string sonMaliYil = donemYil > 0 ? (donemYil - 1).ToString() : "Son Yıl";
}
<div class="basvuru-page">
    <div class="basvuru-titlebar">
        <div>
            <h1>@(Model.DenetciGorunumu ? T("Basvuru.Form.AuditTitle") : (b.Id > 0 ? T("Basvuru.Form.EditTitle") : T("Basvuru.Form.NewTitle")))</h1>
            <p>@string.Format(T("Basvuru.Form.ApplicationNo"), b.Id > 0 ? b.Id.ToString() : T("Basvuru.Form.ApplicationNoPending"))</p>
        </div>
    </div>

    <div id="ajaxMesaj"
         class="alert alert-info alert-dismissible floating-message"
         style="display:@(TempData["Mesaj"] != null ? "block" : "none")">
        <span id="ajaxMesajMetin">@TempData["Mesaj"]</span>
        <button type="button" id="ajaxMesajKapat" class="close" aria-label="@T("Basvuru.Common.Close")">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    @if (Model.Hatalar.Count > 0)
    {
        <div class="alert alert-danger">
            @foreach (string hata in Model.Hatalar)
            {
                <div>@hata</div>
            }
        </div>
    }

    @if (kilitli)
    {
        <div class="alert alert-warning">@L["Basvuru.Warning.FirstSectionRequired"]</div>
    }

    <div class="alert alert-info">@L["Basvuru.Flow.Note"]</div>

    <div class="basvuru-stepbar">
        <label for="basvuruStepSelect">@L["Basvuru.Common.Steps"]</label>
        <select id="basvuruStepSelect" class="form-control">
            @foreach (BasvuruBolumTanim bolum in bolumler)
            {
                bool devreDisi = kilitli && bolum.Bolum != enumBasvuruBolum.Firma;
                <option value="@((int)bolum.Bolum)" selected="@(bolum.Bolum == ilkBolum.Bolum)" disabled="@devreDisi">@L[bolum.BaslikResourceKey]</option>
            }
        </select>
        <button type="button" class="btn btn-outline-secondary nav-prev">@L["Basvuru.Common.Previous"]</button>
        <button type="button" class="btn btn-primary" onclick="PaneliKaydet()">@L["Basvuru.Common.Save"]</button>
        <button type="button" class="btn btn-outline-primary nav-next">@L["Basvuru.Common.Next"]</button>
        <button type="button" class="btn btn-outline-info icon-action" id="stepHelpBtn" title="@T("Basvuru.Common.Help")">?</button>
    </div>
    <input type="hidden" name="Basvuru.Id" value="@b.Id" />
    <div class="basvuru-shell">
        <main class="basvuru-panels">
            <div id="basvuruBolumContainer" data-url="@Url.Action("BolumGetir", "Basvuru")">
                @await Html.PartialAsync(ilkBolum.PartialView, Model)
            </div>
            <div class="basvuru-footer">
                <div>
                </div>
            </div>
        </main>
    </div>
</div>
@if (!ro)
{
    <div class="modal fade firma-modal" id="firmaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Firma.ModalTitle"]</h5>
                    <button type="button" class="close firma-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <div class="alert alert-info">@L["Basvuru.Firma.ModalInfo"]</div>
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <input type="hidden" id="modalFirmaId" />
                            <label>@L["Basvuru.Field.VergiKimlikNo"]<input id="modalVergiKimlikNo" /></label>
                            <label>@L["Basvuru.Field.TicaretUnvani"]<input id="modalTicaretUnvani" /></label>
                            <label>@L["Basvuru.Field.TicaretSicilNo"]<input id="modalTicaretSicilNo" /></label>
                            <label>@L["Basvuru.Field.KurulusTarihi"]<input id="modalKurulusTarihi" type="date" /></label>
                            <label>@L["Basvuru.Field.MersisNo"]<input id="modalMersisNo" /></label>
                            <label>@L["Basvuru.Field.NaceKodu"]<input id="modalNaceKodu" /></label>
                            <label>@L["Basvuru.Field.WebSitesi"]<input id="modalWebSitesi" /></label>
                            <label>@L["Basvuru.Field.Telefon"]<input id="modalTelefon" /></label>
                            <label>@L["Basvuru.Field.KepAdresi"]<input id="modalKepAdresi" /></label>
                            <label>@L["Basvuru.Field.Eposta"]<input id="modalEposta" type="email" /></label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.FaaliyetKonusu"]<textarea id="modalFaaliyetKonusu"></textarea></label>
                        <label class="wide-label">@L["Basvuru.Field.FirmaAdresi"]<textarea id="modalAdres"></textarea></label>
                    </div>
                    <div class="text-danger mt-2" id="firmaModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary firma-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="firmaKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal uygulama-adres-modal" id="uygulamaAdresModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Address.ModalTitle"]</h5>
                    <button type="button" class="close uygulama-adres-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="adresModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Field.SiraNo"]<input id="adresModalSiraNo" type="number" min="1" step="1" /></label>
                            <label>@L["Basvuru.Field.Il"]<input id="adresModalIl" value="@basvuruIlAdi" readonly /></label>
                            <label>
                                @L["Basvuru.Field.Ilce"]
                                <select id="adresModalIlce">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @foreach (var ilce in Model.Ilceler)
                                    {
                                        <option value="@ilce.Id">@ilce.Ad</option>
                                    }
                                </select>
                            </label>
                            <label>
                                @L["Basvuru.Field.YatirimYeriStatusu"]
                                <select id="adresModalYatirimYeriStatusu">
                                    @foreach(var item in Enum.GetValues<TarimDonusum.Models.enumUygulamaAdresiYatirimYeriStatusu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                            <label>@L["Basvuru.Field.KiraVeyaTahsisSuresi"]<input id="adresModalKiraVeyaTahsisSuresi" type="number" min="0" step="1" /></label>
                            <label>@L["Basvuru.Field.KiraTahsisBitisTarihi"]<input id="adresModalKiraTahsisBitisTarihi" type="date" /></label>
                            <label>
                                @L["Basvuru.Field.YapiRuhsatiDurumu"]
                                <select id="adresModalYapiRuhsatiDurumu">
                                    @foreach (var item in Enum.GetValues < TarimDonusum.Models.enumUygulamaAdresiYapiRuhsatiDurumu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.TamAdres"]<textarea id="adresModalTamAdres"></textarea></label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary uygulama-adres-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="adresKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal" id="ortakModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">Ortak / pay sahibi bilgisi</h5>
                    <button type="button" class="close ortak-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="ortakModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>Ortak / pay sahibi adı-unvanı<input id="ortakAdUnvan" /></label>
                            <label>TCKN / VKN<input id="ortakTcknVkn" /></label>
                            <label>
                                Gerçek / tüzel kişi
                                <select id="ortakKisiTuru">
                                    <option value="Gerçek Kişi">Gerçek Kişi</option>
                                    <option value="Tüzel Kişi">Tüzel Kişi</option>
                                </select>
                            </label>
                            <label>Pay oranı (%)<input id="ortakPayOrani" type="number" min="0" max="100" step="0.01" /></label>
                            <label>
                                Özel / kamu niteliği
                                <select id="ortakOzelKamuNiteligi">
                                    <option value="Özel">Özel</option>
                                    <option value="Kamu">Kamu</option>
                                </select>
                            </label>
                            <label>Nihai/gerçek faydalanıcı bilgisi<input id="ortakNihaiFaydalaniciBilgisi" /></label>
                        </div>
                        <div class="document-upload-box mt-3" id="ortakUboKycBox">
                            <div class="document-file-row">
                                <label class="btn btn-primary mb-0 disabled" for="ortakUboKycDosya" id="ortakUboKycSecBtn">UBO-KYC belgesi yükle</label>
                                <input id="ortakUboKycDosya" type="file" class="document-file-input" disabled />
                                <span id="ortakUboKycDosyaAdi" class="document-file-name">UBO-KYC belgesi yüklü değil, yükleyiniz</span>
                                <a id="ortakUboKycIndirBtn" class="btn btn-outline-primary d-none" href="#" target="_blank" rel="noopener">İndir</a>
                            </div>
                            <div class="document-note" id="ortakUboKycNot">UBO-KYC belgesi yüklemek için önce ortağı kaydedin.</div>
                        </div>
                        <div id="ortakTuzelMaliAlanlari" class="legal-partner-modal-fields">
                            <h6>Tüzel kişi mali verileri</h6>
                            <div class="form-grid">
                                <label>Hesaba dahil oran (%)<input id="ortakHesabaDahilOran" type="number" min="0" max="100" step="0.01" /></label>
                                <label>@oncekiMaliYil net satış<input id="ortakOncekiYilNetSatis" class="money-integer" /></label>
                                <label>@sonMaliYil net satış<input id="ortakSonYilNetSatis" class="money-integer" /></label>
                                <label>@oncekiMaliYil aktif<input id="ortakOncekiYilAktifToplami" class="money-integer" /></label>
                                <label>@sonMaliYil aktif<input id="ortakSonYilAktifToplami" class="money-integer" /></label>
                            </div>
                        </div>
                    </div>
                    <div class="text-danger mt-2" id="ortakModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary ortak-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="ortakKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    var active = @((int)ilkBolum.Bolum);
    const bolumFirma = @((int)enumBasvuruBolum.Firma);
    const bolumIrtibat = @((int)enumBasvuruBolum.Irtibat);
    const bolumYatirim = @((int)enumBasvuruBolum.Yatirim);
    const bolumUygulamaAdresi = @((int)enumBasvuruBolum.UygulamaAdresi);
    const bolumFinans = @((int)enumBasvuruBolum.Finans);
    const bolumMali = @((int)enumBasvuruBolum.Mali);
    const bolumBelgeler = @((int)enumBasvuruBolum.Belgeler);
    const bolumOrtaklik = @((int)enumBasvuruBolum.Ortaklik);
    const ortaklikReadonly = @(ro ? "true" : "false");
    const oncekiMaliYil = @Html.Raw(JsonSerializer.Serialize(oncekiMaliYil));
    const sonMaliYil = @Html.Raw(JsonSerializer.Serialize(sonMaliYil));
    const zorunluBelgeFormAd = 'Basvuru_ZorunluBelge';
    const bagliBelgeFormAd = 'Basvuru_BagliBelge';
    const basvuruBolumleri = @Html.Raw(JsonSerializer.Serialize(bolumler.Select(x => (int)x.Bolum)));
    const adresBosMesaj = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.Empty")));
    const adresSilOnay = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.DeleteConfirm")));
    const lockedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.LockedMessage")));
    const unsavedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.UnsavedMessage")));
    const partialLoadFailedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Message.NotFound")));
    const firmaCreateQuestion = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.CreateQuestion")));
    const firmaSelectFirstMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Firma.SelectFirst")));
    const belgeMesajlari = {
        noFileSelected: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.NoFileSelected"))),
        packageFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.PackageFileRequired"))),
        uploadErrorConsole: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadErrorConsole"))),
        uploadFailed: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadFailed"))),
        uploadSucceeded: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.UploadSucceeded"))),
        sectionSaveInfo: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.SectionSaveInfo"))),
        commitmentFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Documents.CommitmentFileRequired"))),
        auditFileRequired: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Mali.AuditFileRequired")))
    };
    const maliMesajlari = {
        scaleOk: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Mali.ScaleCheckOk"))),
        scaleNotOk: @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Mali.ScaleCheckNotOk")))
    };

    let locked = @(kilitli ? "true" : "false");
    let dirty = false;
    var uygulamaAdresModal;
    var firmaModal;
    var ortakModal;
    var sonUygulamaAdresleri = [];
    var basvuruOrtaklari = [];

    document.addEventListener('DOMContentLoaded', () => {
        uygulamaAdresModal = modalOlustur(document.getElementById('uygulamaAdresModal'));
        firmaModal = modalOlustur(document.getElementById('firmaModal'));
        ortakModal = modalOlustur(document.getElementById('ortakModal'));

        document.querySelectorAll('.firma-modal-kapat').forEach(btn => btn.addEventListener('click', () => firmaModal?.hide()));
        document.querySelectorAll('.uygulama-adres-modal-kapat').forEach(btn => btn.addEventListener('click', () => uygulamaAdresModal?.hide()));
        document.querySelectorAll('.ortak-modal-kapat').forEach(btn => btn.addEventListener('click', () => ortakModal?.hide()));

        const stepSelect = document.getElementById('basvuruStepSelect');
        stepSelect?.addEventListener('change', () => BasvuruBolumGoster(Number(stepSelect.value)));
        document.querySelectorAll('.nav-prev').forEach(btn => btn.addEventListener('click', () => BasvuruBolumGoster(KomsuBolum(-1))));
        document.querySelectorAll('.nav-next').forEach(btn => btn.addEventListener('click', () => BasvuruBolumGoster(KomsuBolum(1))));

        document.getElementById('firmaKaydetBtn')?.addEventListener('click', FirmaKaydetModal);
        document.getElementById('adresKaydetBtn')?.addEventListener('click', UygulamaAdresiModalKaydet);
        document.getElementById('ortakKaydetBtn')?.addEventListener('click', OrtakModalKaydet);
        document.getElementById('ortakUboKycDosya')?.addEventListener('change', OrtakModalUboKycDosyasiYukle);

        BasvuruBolumIlklendir(active);
    });

    function modalOlustur(element) {
        if (!element) return null;
        if (window.bootstrap?.Modal) return new bootstrap.Modal(element);
        return {
            show: () => window.jQuery(element).modal('show'),
            hide: () => window.jQuery(element).modal('hide')
        };
    }

    function modalValue(id) {
        return document.getElementById(id)?.value || '';
    }

    function BasvuruId() {
        return degerInt('Basvuru.Id') || 0;
    }

    function BasvuruKimlikleri() {
        return {
            basvuruId: BasvuruId()
        };
    }

    function modalSet(id, value) {
        const el = document.getElementById(id);
        if (!el) return;
        if (el.type === 'date' && value) {
            el.value = String(value).substring(0, 10);
            return;
        }
        el.value = value || '';
    }

    function KomsuBolum(yon) {
        const index = basvuruBolumleri.indexOf(active);
        if (index < 0) return active;
        return basvuruBolumleri[index + yon] || active;
    }

    function BasvuruBolumGoster(bolum) {
        if (!basvuruBolumleri.includes(bolum) || bolum === active) {
            BasvuruStepSec(active);
            return;
        }
        if (locked && bolum !== bolumFirma) {
            alert(lockedMessage);
            BasvuruStepSec(active);
            return;
        }
        if (dirty && !confirm(unsavedMessage)) {
            BasvuruStepSec(active);
            return;
        }

        const container = document.getElementById('basvuruBolumContainer');
        const url = container?.dataset.url;
        if (!container || !url) return;

        $.ajax({
            url: url,
            type: 'GET',
            data: { ...BasvuruKimlikleri(), bolum: bolum },
            dataType: 'html'
        })
            .done(function (html) {
                container.innerHTML = html;
                active = bolum;
                dirty = false;
                BasvuruStepSec(active);
                BasvuruBolumIlklendir(active);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            })
            .fail(function () {
                PopupMesajGoster(partialLoadFailedMessage, false);
                BasvuruStepSec(active);
            });
    }

    function BasvuruStepSec(bolum) {
        const stepSelect = document.getElementById('basvuruStepSelect');
        if (stepSelect) stepSelect.value = String(bolum);
    }

    function BasvuruBolumIlklendir(bolum) {
        const container = document.getElementById('basvuruBolumContainer');
        container?.querySelectorAll('input, select, textarea').forEach(el => {
            el.addEventListener('change', () => dirty = true);
            el.addEventListener('input', () => dirty = true);
        });

        if (bolum === bolumFirma) FirmaBolumuIlklendir();
        if (bolum === bolumYatirim) YatirimBolumuIlklendir();
        if (bolum === bolumUygulamaAdresi) UygulamaAdresiBolumuIlklendir();
        if (bolum === bolumFinans || bolum === bolumMali || bolum === bolumOrtaklik) ParaTamsayiAyarla();
        if (bolum === bolumMali) MaliBolumuIlklendir();
        if (bolum === bolumOrtaklik) OrtaklikBolumuIlklendir();
        if (bolum === bolumBelgeler) BelgelerBolumuIlklendir();
    }

    function FirmaBolumuIlklendir() {
        document.getElementById('firmaSorgulaBtn')?.addEventListener('click', () => {
            AjaxGet('/Basvuru/FirmaSorgula', { vergiKimlikNo: $('#vergiKimlikNo').val(), id: 0 }, FirmaBilgiYaz);
        });
        document.getElementById('firmaYeniBtn')?.addEventListener('click', () => {
            firmaModalDoldur({ id: 0, vergiKimlikNo: $('#vergiKimlikNo').val() || '' });
            firmaModal?.show();
        });
        document.getElementById('firmaDuzenleBtn')?.addEventListener('click', () => {
            const id = document.getElementById('firmaId')?.value || '';
            if (!id) {
                alert(firmaSelectFirstMessage);
                return;
            }
            AjaxGet('/Basvuru/FirmaSorgula', { vergiKimlikNo: $('#vergiKimlikNo').val(), id: 0 }, FirmaBilgiDoldur);
        });
    }

    function YatirimBolumuIlklendir() {
        $('[name="Basvuru.IlId"]').off('change.basvuruBolum').on('change.basvuruBolum', degerZinciriYukle);
        $('#degerZinciriSelect').off('change.basvuruBolum').on('change.basvuruBolum', function () {
            degerZinciriAsamalariYukle($(this).val());
        });
        degerZinciriYukle();
    }

    function UygulamaAdresiBolumuIlklendir() {
        document.getElementById('adresYeniBtn')?.addEventListener('click', () => adresModalAc(-1));
        UygulamaAdresleriListele();
    }

    function BelgelerBolumuIlklendir() {
        document.querySelectorAll('.basvuru-dosya-input').forEach(input => {
            input.addEventListener('change', function () {
                BasvuruDosyasiYukle(this.dataset.formAd || zorunluBelgeFormAd, Number(this.dataset.dosyaNo || 0), this, this.dataset.nameTarget, this.dataset.downloadTarget);
            });
        });
        document.getElementById('taahhutDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'taahhutDosyaSecim', 'Basvuru.TaahhutDosyaAdi');
        });
        document.getElementById('taahhutYukleBtn')?.addEventListener('click', TaahhutDosyasiYukle);
    }

    function MaliBolumuIlklendir() {
        document.getElementById('denetimDosya')?.addEventListener('change', function () {
            dosyaSecimYaz(this, 'denetimDosyaSecim', 'Basvuru.mali.DenetimDosyaAdi');
            DenetimDosyasiYukle();
        });
        document.getElementById('bagimsizDenetimeTabiMi')?.addEventListener('change', DenetimDosyaBolumuGuncelle);
        document.querySelectorAll('.mali-scale-input').forEach(input => {
            input.addEventListener('input', MaliOlcekKontrolGuncelle);
            input.addEventListener('blur', MaliOlcekKontrolGuncelle);
        });
        DenetimDosyaBolumuGuncelle();
        MaliOlcekKontrolGuncelle();
    }

    function DenetimDosyaBolumuGuncelle() {
        const secim = document.getElementById('bagimsizDenetimeTabiMi')?.value || '';
        const bolum = document.getElementById('denetimDosyaBolumu');
        if (!bolum) return;
        bolum.classList.toggle('d-none', secim !== 'true');
    }

    function MaliOlcekKontrolGuncelle() {
        const altLimit = Number(document.getElementById('maliOlcekAltLimit')?.value || 0);
        const ustLimit = Number(document.getElementById('maliOlcekUstLimit')?.value || 0);
        const uyari = document.getElementById('maliOlcekUyari');
        const sonuc = document.getElementById('maliOlcekSonuc');
        if (!uyari || !sonuc || altLimit <= 0 || ustLimit <= 0) return;

        const alanlar = [
            'Basvuru.mali.OncekiYilNetSatis',
            'Basvuru.mali.SonYilNetSatis',
            'Basvuru.mali.OncekiYilAktifToplami',
            'Basvuru.mali.SonYilAktifToplami'
        ];
        const saglandi = alanlar.some(name => {
            const deger = degerDec(name);
            return deger >= altLimit && deger <= ustLimit;
        });

        uyari.classList.toggle('scale-ok', saglandi);
        sonuc.textContent = saglandi ? maliMesajlari.scaleOk : maliMesajlari.scaleNotOk;
    }

    function OrtaklikBolumuIlklendir() {
        OrtaklikInitialOku();
        document.getElementById('hasRelatedEnterprise')?.addEventListener('change', toggleRelatedEnterprise);
        document.getElementById('ortakEkleBtn')?.addEventListener('click', () => OrtakModalAc(-1));
        document.getElementById('ortakKisiTuru')?.addEventListener('change', OrtakModalTuzelAlanGuncelle);
        document.querySelectorAll('.ortaklik-dosya-input').forEach(input => {
            input.addEventListener('change', function () {
                OrtaklikDosyasiYukle(this.dataset.formAd || bagliBelgeFormAd, Number(this.dataset.dosyaNo || 0), this, this.dataset.nameTarget, this.dataset.downloadTarget);
            });
        });
        toggleRelatedEnterprise();
        OrtaklarRender();
    }

    function OrtaklikInitialOku() {
        const jsonElement = document.getElementById('ortaklikInitialJson');
        if (!jsonElement) {
            basvuruOrtaklari = [];
            return;
        }

        try {
            const model = JSON.parse(jsonElement.textContent || '{}');
            basvuruOrtaklari = Array.isArray(model.ortaklar) ? model.ortaklar : [];
        }
        catch {
            basvuruOrtaklari = [];
        }
    }

    function toggleRelatedEnterprise() {
        const secim = document.getElementById('hasRelatedEnterprise')?.value || '';
        document.getElementById('relatedEnterpriseBox')?.classList.toggle('d-none', secim !== 'true');
    }

    function OrtakModalAc(index) {
        const ortak = index >= 0 ? basvuruOrtaklari[index] : {};
        modalSet('ortakModalIndex', index >= 0 ? String(index) : '');
        modalSet('ortakAdUnvan', ortak.adUnvan);
        modalSet('ortakTcknVkn', ortak.tcknVkn);
        modalSet('ortakKisiTuru', ortak.kisiTuru || 'Gerçek Kişi');
        modalSet('ortakPayOrani', ortak.payOrani);
        modalSet('ortakOzelKamuNiteligi', ortak.ozelKamuNiteligi || 'Özel');
        modalSet('ortakNihaiFaydalaniciBilgisi', ortak.nihaiFaydalaniciBilgisi);
        modalSet('ortakHesabaDahilOran', ortak.hesabaDahilOran ?? ortak.payOrani);
        modalSet('ortakOncekiYilNetSatis', ortak.oncekiYilNetSatis);
        modalSet('ortakSonYilNetSatis', ortak.sonYilNetSatis);
        modalSet('ortakOncekiYilAktifToplami', ortak.oncekiYilAktifToplami);
        modalSet('ortakSonYilAktifToplami', ortak.sonYilAktifToplami);
        const hata = document.getElementById('ortakModalHata');
        if (hata) hata.textContent = '';
        OrtakModalTuzelAlanGuncelle();
        OrtakModalUboKycDurumGuncelle();
        ortakModal?.show();
    }

    function OrtakModalTuzelAlanGuncelle() {
        const tuzelMi = modalValue('ortakKisiTuru') === 'Tüzel Kişi';
        document.getElementById('ortakTuzelMaliAlanlari')?.classList.toggle('d-none', !tuzelMi);
    }

    function OrtakModalKaydet() {
        const ortak = {
            id: mevcutOrtakId(),
            basvuruId: BasvuruId(),
            siraNo: 0,
            adUnvan: modalValue('ortakAdUnvan').trim(),
            tcknVkn: modalValue('ortakTcknVkn').trim(),
            kisiTuru: modalValue('ortakKisiTuru'),
            payOrani: sayiOkuId('ortakPayOrani'),
            hesabaDahilOran: sayiOkuId('ortakHesabaDahilOran'),
            ozelKamuNiteligi: modalValue('ortakOzelKamuNiteligi'),
            nihaiFaydalaniciBilgisi: modalValue('ortakNihaiFaydalaniciBilgisi').trim(),
            uboKycBelgeAdi: mevcutOrtakBelgeAdi(),
            uboKycDosyaId: mevcutOrtakDosyaId(),
            oncekiYilNetSatis: sayiOkuId('ortakOncekiYilNetSatis'),
            sonYilNetSatis: sayiOkuId('ortakSonYilNetSatis'),
            oncekiYilAktifToplami: sayiOkuId('ortakOncekiYilAktifToplami'),
            sonYilAktifToplami: sayiOkuId('ortakSonYilAktifToplami')
        };
        const indexText = modalValue('ortakModalIndex');
        const oncekiKimlik = indexText === '' ? '' : basvuruOrtaklari[Number(indexText)]?.tcknVkn || '';
        if (TcknVknNormalize(oncekiKimlik) && TcknVknNormalize(oncekiKimlik) !== TcknVknNormalize(ortak.tcknVkn)) {
            ortak.uboKycBelgeAdi = '';
            ortak.uboKycDosyaId = null;
        }

        if (!ortak.adUnvan || !ortak.tcknVkn) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = 'Ortak adı/unvanı ve TCKN/VKN girilmelidir.';
            return;
        }
        if (AyniTcknVknVarMi(ortak.tcknVkn, modalValue('ortakModalIndex'))) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = 'Aynı TCKN/VKN ile iki ortak kaydedilemez.';
            return;
        }
        if (ortak.kisiTuru === 'Tüzel Kişi' && (!ortak.hesabaDahilOran || ortak.hesabaDahilOran <= 0)) {
            const hata = document.getElementById('ortakModalHata');
            if (hata) hata.textContent = 'Tüzel kişi ortak için hesaba dahil oran girilmelidir.';
            return;
        }

        if (indexText === '') basvuruOrtaklari.push(ortak);
        else basvuruOrtaklari[Number(indexText)] = ortak;
        basvuruOrtaklari.forEach((item, index) => item.siraNo = index + 1);
        dirty = true;
        OrtaklarRender();
        OrtaklarKaydet(function () {
            modalSet('ortakModalIndex', String(basvuruOrtaklari.findIndex(x => TcknVknNormalize(x.tcknVkn) === TcknVknNormalize(ortak.tcknVkn))));
            OrtakModalUboKycDurumGuncelle();
        });
    }

    function AyniTcknVknVarMi(tcknVkn, mevcutIndexText) {
        const kimlik = TcknVknNormalize(tcknVkn);
        const mevcutIndex = mevcutIndexText === '' ? -1 : Number(mevcutIndexText);
        return basvuruOrtaklari.some((ortak, index) =>
            index !== mevcutIndex &&
            TcknVknNormalize(ortak.tcknVkn) === kimlik);
    }

    function OrtakSil(index) {
        if (ortaklikReadonly) return;
        basvuruOrtaklari.splice(index, 1);
        basvuruOrtaklari.forEach((item, itemIndex) => item.siraNo = itemIndex + 1);
        dirty = true;
        OrtaklarRender();
        OrtaklarKaydet();
    }

    function OrtaklarRender() {
        const container = document.getElementById('partnersTable');
        if (!container) return;
        basvuruOrtaklari.forEach((item, index) => item.siraNo = index + 1);

        let html = `<div class="table-responsive"><table class="table table-bordered ortak-table"><thead><tr>
            <th>Sıra</th><th>Ortak / pay sahibi adı-unvanı</th><th>TCKN / VKN</th><th>Gerçek / tüzel kişi</th>
            <th>Pay oranı (%)</th><th>Özel / kamu niteliği</th><th>Nihai/gerçek faydalanıcı bilgisi</th><th>UBO-KYC belgesi</th><th></th>
        </tr></thead><tbody>`;

        if (basvuruOrtaklari.length === 0) {
            html += `<tr><td colspan="9" class="text-muted text-center">Ortak/pay sahibi eklenmedi.</td></tr>`;
        }
        else {
            basvuruOrtaklari.forEach((ortak, index) => {
                html += `<tr>
                    <td>${index + 1}</td>
                    <td>${htmlEncode(ortak.adUnvan)}</td>
                    <td>${htmlEncode(ortak.tcknVkn)}</td>
                    <td>${htmlEncode(ortak.kisiTuru)}</td>
                    <td>${sayiYaz(ortak.payOrani)}</td>
                    <td>${htmlEncode(ortak.ozelKamuNiteligi)}</td>
                    <td>${htmlEncode(ortak.nihaiFaydalaniciBilgisi)}</td>
                    <td>${OrtakUboKycHucreHtml(ortak, index)}</td>
                    <td class="text-nowrap">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="OrtakModalAc(${index})" ${ortaklikReadonly ? 'disabled' : ''}>Düzenle</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="OrtakSil(${index})" ${ortaklikReadonly ? 'disabled' : ''}>Sil</button>
                    </td>
                </tr>`;
            });
        }

        html += '</tbody></table></div>';
        container.innerHTML = html;
        OrtaklikOzetGuncelle();
        TuzelOrtakMaliRender();
    }

    function OrtakUboKycHucreHtml(ortak, index) {
        const uboKycYuklu = !!ortak.uboKycDosyaId;
        const dosyaAdi = htmlEncode(uboKycYuklu ? ortak.uboKycBelgeAdi : 'UBO-KYC belgesi yüklü değil, yükleyiniz');
        const href = ortak.uboKycDosyaId ? `/Basvuru/DosyaIndir/${ortak.uboKycDosyaId}` : '#';
        const indir = uboKycYuklu
            ? `<a class="btn btn-sm btn-outline-primary mt-1" href="${href}" target="_blank" rel="noopener">İndir</a>`
            : '';
        return `<div class="ortak-doc-cell">
            <div class="document-file-name">${dosyaAdi}</div>
            ${indir}
        </div>`;
    }

    function mevcutOrtakId() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return 0;
        return basvuruOrtaklari[Number(indexText)]?.id || 0;
    }

    function mevcutOrtakDosyaId() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return null;
        return basvuruOrtaklari[Number(indexText)]?.uboKycDosyaId || null;
    }

    function mevcutOrtakBelgeAdi() {
        const indexText = modalValue('ortakModalIndex');
        if (indexText === '') return '';
        return basvuruOrtaklari[Number(indexText)]?.uboKycBelgeAdi || '';
    }

    function OrtakModalUboKycDurumGuncelle() {
        const indexText = modalValue('ortakModalIndex');
        const ortak = indexText === '' ? null : basvuruOrtaklari[Number(indexText)];
        const kayitliMi = !!ortak && !!String(ortak.tcknVkn || '').trim();
        const input = document.getElementById('ortakUboKycDosya');
        const button = document.getElementById('ortakUboKycSecBtn');
        const name = document.getElementById('ortakUboKycDosyaAdi');
        const note = document.getElementById('ortakUboKycNot');
        const download = document.getElementById('ortakUboKycIndirBtn');

        if (input) {
            input.disabled = !kayitliMi || ortaklikReadonly;
            input.value = '';
        }
        button?.classList.toggle('disabled', !kayitliMi || ortaklikReadonly);
        const uboKycYuklu = !!ortak?.uboKycDosyaId;
        if (name) name.textContent = uboKycYuklu ? (ortak?.uboKycBelgeAdi || '') : 'UBO-KYC belgesi yüklü değil, yükleyiniz';
        if (note) {
            note.textContent = kayitliMi
                ? ''
                : 'UBO-KYC belgesi yüklemek için önce ortağı kaydedin.';
            note.classList.toggle('d-none', kayitliMi);
        }
        if (download) {
            if (uboKycYuklu) {
                download.href = `/Basvuru/DosyaIndir/${ortak.uboKycDosyaId}`;
                download.classList.remove('d-none');
            }
            else {
                download.href = '#';
                download.classList.add('d-none');
            }
        }
    }

    function OrtakModalUboKycDosyasiYukle() {
        const input = document.getElementById('ortakUboKycDosya');
        const indexText = modalValue('ortakModalIndex');
        const index = indexText === '' ? -1 : Number(indexText);
        const ortak = index >= 0 ? basvuruOrtaklari[index] : null;
        if (!ortak) {
            PopupMesajGoster('UBO-KYC belgesi yüklemek için önce ortağı kaydedin.', false);
            return;
        }

        BasvuruDosyasiYukle(UboKycFormAdOlustur(ortak.tcknVkn), 1, input, 'ortakUboKycDosyaAdi', 'ortakUboKycIndirBtn', function (sonuc) {
            const nesne = sonuc?.nesne || sonuc?.Nesne || {};
            ortak.uboKycDosyaId = nesne.dosyaId || nesne.DosyaId || null;
            ortak.uboKycBelgeAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            OrtakModalUboKycDurumGuncelle();
            OrtaklarRender();
        });
    }

    function UboKycFormAdOlustur(tcknVkn) {
        return `OBOKYC_${TcknVknNormalize(tcknVkn)}`;
    }

    function TcknVknNormalize(tcknVkn) {
        return String(tcknVkn || '').trim().replace(/[^0-9A-Za-z]/g, '').toLocaleUpperCase('tr-TR');
    }

    function OrtaklikOzetGuncelle() {
        const toplamPay = basvuruOrtaklari.reduce((sum, ortak) => sum + Number(ortak.payOrani || 0), 0);
        const ozelPay = basvuruOrtaklari
            .filter(ortak => ortak.ozelKamuNiteligi === 'Özel')
            .reduce((sum, ortak) => sum + Number(ortak.payOrani || 0), 0);
        const ozelInput = document.getElementById('privateShareCalculated');
        if (ozelInput) ozelInput.value = sayiYaz(ozelPay);

        const alert = document.getElementById('partnerAlerts');
        if (!alert) return;
        if (toplamPay > 100) {
            alert.innerHTML = '<div class="alert alert-danger">Ortak/pay sahibi toplam pay oranı 100\'ü geçemez.</div>';
        }
        else if (basvuruOrtaklari.length > 0 && toplamPay !== 100) {
            alert.innerHTML = `<div class="alert alert-warning">Toplam pay oranı: ${sayiYaz(toplamPay)}%. Toplamın 100 olması beklenir.</div>`;
        }
        else {
            alert.innerHTML = '';
        }
    }

    function TuzelOrtakMaliRender() {
        const container = document.getElementById('legalPartnerFinancials');
        if (!container) return;
        const tuzelOrtaklar = basvuruOrtaklari.filter(ortak => ortak.kisiTuru === 'Tüzel Kişi');
        if (tuzelOrtaklar.length === 0) {
            container.innerHTML = '';
            return;
        }

        let html = `<h3 class="subhead">Tüzel kişi ortak mali verileri</h3>
            <div class="table-responsive"><table class="table table-bordered legal-financial-table"><thead><tr>
                <th>Ortak / pay sahibi</th><th>Hesaba dahil oran</th><th>${htmlEncode(oncekiMaliYil)} net satış</th><th>${htmlEncode(sonMaliYil)} net satış</th><th>${htmlEncode(oncekiMaliYil)} aktif</th><th>${htmlEncode(sonMaliYil)} aktif</th>
            </tr></thead><tbody>`;
        tuzelOrtaklar.forEach(ortak => {
            html += `<tr>
                <td>${htmlEncode(ortak.adUnvan)}</td>
                <td>%${sayiYaz(ortak.hesabaDahilOran ?? ortak.payOrani)}</td>
                <td>${sayiYaz(ortak.oncekiYilNetSatis)}</td>
                <td>${sayiYaz(ortak.sonYilNetSatis)}</td>
                <td>${sayiYaz(ortak.oncekiYilAktifToplami)}</td>
                <td>${sayiYaz(ortak.sonYilAktifToplami)}</td>
            </tr>`;
        });
        html += '</tbody></table></div>';
        container.innerHTML = html;
    }

    function OrtaklikKaydet(afterSuccess, bosBagliSecimiHayirSay) {
        const secim = document.getElementById('hasRelatedEnterprise')?.value || '';
        const bagliOrtakVarMi = secim === '' ? (bosBagliSecimiHayirSay ? false : null) : secim === 'true';
        if (bagliOrtakVarMi === true) {
            const eksikler = [];
            if (!modalValue('relatedTitle').trim()) eksikler.push('Bağlı/ortak işletme unvanı');
            if (!modalValue('relatedId').trim()) eksikler.push('Bağlı/ortak işletme VKN/MERSİS');
            if (sayiAlanBosMu('relPrevNetSales')) eksikler.push(`${oncekiMaliYil} net satış hasılatı`);
            if (sayiAlanBosMu('relLastNetSales')) eksikler.push(`${sonMaliYil} net satış hasılatı`);
            if (sayiAlanBosMu('relPrevAssets')) eksikler.push(`${oncekiMaliYil} aktif toplamı`);
            if (sayiAlanBosMu('relLastAssets')) eksikler.push(`${sonMaliYil} aktif toplamı`);
            if (eksikler.length > 0) {
                PopupMesajGoster(`${eksikler.join(', ')} girilmelidir.`, false);
                return;
            }
        }
        const model = {
            ...BasvuruKimlikleri(),
            bagliOrtakIsletmeVarMi: bagliOrtakVarMi,
            ozelSektorPayi: sayiOkuId('privateShareCalculated'),
            ortaklar: basvuruOrtaklari,
            bagliOrtakUnvani: modalValue('relatedTitle'),
            bagliOrtakKimlikNo: modalValue('relatedId'),
            bagliOrtakOncekiYilNetSatis: sayiOkuId('relPrevNetSales'),
            bagliOrtakSonYilNetSatis: sayiOkuId('relLastNetSales'),
            bagliOrtakOncekiYilAktifToplami: sayiOkuId('relPrevAssets'),
            bagliOrtakSonYilAktifToplami: sayiOkuId('relLastAssets')
        };
        AjaxPost('/Basvuru/KaydetOrtaklik', model, function (sonuc) {
            if (sonuc?.basarili) {
                dirty = false;
                if (afterSuccess) afterSuccess(sonuc);
            }
            SonucGoster(sonuc);
        });
    }

    function OrtaklarKaydet(afterSuccess) {
        const model = {
            ...BasvuruKimlikleri(),
            ortaklar: basvuruOrtaklari
        };
        AjaxPost('/Basvuru/KaydetOrtaklar', model, function (sonuc) {
            if (sonuc?.basarili) {
                dirty = false;
                if (afterSuccess) afterSuccess(sonuc);
            }
            SonucGoster(sonuc);
        });
    }

    function sayiAlanBosMu(id) {
        return (document.getElementById(id)?.value || '').toString().trim() === '';
    }

    function sayiOkuId(id) {
        const value = (document.getElementById(id)?.value || '').toString().trim();
        if (!value) return null;
        const normalized = value.includes(',')
            ? value.replace(/\./g, '').replace(',', '.')
            : value.replace(/\s/g, '');
        const number = Number(normalized);
        return Number.isFinite(number) ? number : null;
    }

    function sayiYaz(value) {
        const number = Number(value || 0);
        return Number.isFinite(number) ? number.toLocaleString('tr-TR', { maximumFractionDigits: 2 }) : '';
    }

    function htmlEncode(value) {
        return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function setFirma(firma) {
        modalSet('firmaId', firma.id);
        modalSet('vergiKimlikNo', firma.vergiKimlikNo);
        modalSet('firmaAdi', firma.ticaretUnvani);
        modalSet('firmaTicaretSicilNo', firma.ticaretSicilNo);
        modalSet('firmaKurulusTarihi', firma.kurulusTarihi);
        modalSet('firmaTelefon', firma.telefon);
        modalSet('firmaWebSitesi', firma.webSitesi);
        modalSet('firmaMersisNo', firma.mersisNo);
        modalSet('firmaNaceKodu', firma.naceKodu);
        modalSet('firmaKepAdresi', firma.kepAdresi);
        modalSet('firmaEposta', firma.eposta);
        modalSet('firmaFaaliyetKonusu', firma.faaliyetKonusu);
        modalSet('firmaAdres', firma.adres);
        dirty = true;
    }

    function firmaModalDoldur(firma) {
        modalSet('modalFirmaId', firma.id);
        modalSet('modalVergiKimlikNo', firma.vergiKimlikNo);
        modalSet('modalTicaretUnvani', firma.ticaretUnvani);
        modalSet('modalTicaretSicilNo', firma.ticaretSicilNo);
        modalSet('modalKurulusTarihi', firma.kurulusTarihi);
        modalSet('modalMersisNo', firma.mersisNo);
        modalSet('modalNaceKodu', firma.naceKodu);
        modalSet('modalWebSitesi', firma.webSitesi);
        modalSet('modalTelefon', firma.telefon);
        modalSet('modalKepAdresi', firma.kepAdresi);
        modalSet('modalEposta', firma.eposta);
        modalSet('modalFaaliyetKonusu', firma.faaliyetKonusu);
        modalSet('modalAdres', firma.adres);
        const hata = document.getElementById('firmaModalHata');
        if (hata) hata.textContent = '';
    }

    function FirmaBilgiYaz(result) {
        if (!result.basarili) {
            alert(result.hataStr);
            return;
        }
        if (result.nesne) {
            setFirma(result.nesne);
            return;
        }
        if (confirm(result.mesaj || firmaCreateQuestion)) {
            firmaModalDoldur({ vergiKimlikNo: $('#vergiKimlikNo').val() || '' });
            firmaModal?.show();
        }
    }

    function FirmaBilgiDoldur(result) {
        if (!result.basarili) {
            alert(result.hataStr);
            return;
        }
        if (result.nesne) firmaModalDoldur(result.nesne);
        firmaModal?.show();
    }

    function FirmaKaydetModal() {
        const firma = {
            id: modalValue('modalFirmaId'),
            vergiKimlikNo: modalValue('modalVergiKimlikNo'),
            ticaretUnvani: modalValue('modalTicaretUnvani'),
            ticaretSicilNo: modalValue('modalTicaretSicilNo'),
            kurulusTarihi: modalValue('modalKurulusTarihi'),
            mersisNo: modalValue('modalMersisNo'),
            naceKodu: modalValue('modalNaceKodu'),
            webSitesi: modalValue('modalWebSitesi'),
            telefon: modalValue('modalTelefon'),
            kepAdresi: modalValue('modalKepAdresi'),
            eposta: modalValue('modalEposta'),
            faaliyetKonusu: modalValue('modalFaaliyetKonusu'),
            adres: modalValue('modalAdres')
        };
        AjaxPost('/Basvuru/FirmaKaydet', firma, function (sonuc) {
            if (sonuc.basarili) {
                firmaModal?.hide();
                setFirma({ ...firma, id: sonuc.nesne || firma.id });
            }
            SonucGoster(sonuc);
        });
    }

    function FirmaIrtibatKaydet() {
        AjaxPost('/Basvuru/KaydetIrtibat', IrtibatModeliOlustur(), SonucGoster);
    }

    function IrtibatModeliOlustur() {
        return {
            ...BasvuruKimlikleri(),
            kisi: degerStr('Basvuru.irtibat.kisi'),
            unvan: degerStr('Basvuru.irtibat.unvan'),
            telefon: degerStr('Basvuru.irtibat.telefon'),
            ePosta: degerStr('Basvuru.irtibat.ePosta'),
            adres: degerStr('Basvuru.irtibat.adres'),
            yetkiliKisiler: degerStr('Basvuru.irtibat.yetkiliKisiler')
        };
    }

    function BasvuruFirmaModeliOlustur() {
        return {
            id: BasvuruId(),
            firmaId: degerInt('Basvuru.FirmaId'),
            donemId: degerInt('Basvuru.DonemId'),
            ilId: degerInt('Basvuru.IlId'),
            basvuruKonusu: '',
            sonIkiYildirFaalMi: degerStr('Basvuru.SonIkiYildirFaalMi') === '' ? null : degerBool('Basvuru.SonIkiYildirFaalMi'),
            basvuruSahibiTuru: degerInt('Basvuru.BasvuruSahibiTuru'),
            ozelSektorPayi: $('[name="Basvuru.OzelSektorPayi"]').length ? degerDec('Basvuru.OzelSektorPayi') : 0,
            bagliOrtakIsletmeVarMi: $('[name="Basvuru.BagliOrtakIsletmeVarMi"]').length ? degerBool('Basvuru.BagliOrtakIsletmeVarMi') : null,
            bagliOrtakAciklama: $('[name="Basvuru.BagliOrtakAciklama"]').length ? degerStr('Basvuru.BagliOrtakAciklama') : null
        };
    }

    function FirmaBasvuruKaydet() {
        AjaxPost('/Basvuru/KaydetFirmaBasvuru', BasvuruFirmaModeliOlustur(), BasvuruKayitSonucGoster);
    }

    function BasvuruSahibiKaydet() {
        AjaxPost('/Basvuru/KaydetBasvuruSahibi', {
            basvuruFirma: BasvuruFirmaModeliOlustur(),
            irtibat: IrtibatModeliOlustur()
        }, BasvuruKayitSonucGoster);
    }

    function BasvuruKayitKimlikGuncelle(sonuc) {
        if (sonuc?.basarili && sonuc.nesne) {
            $('[name="Basvuru.Id"]').val(sonuc.nesne);
            locked = false;
            $('#basvuruStepSelect option').prop('disabled', false);
            dirty = false;
        }
    }

    function BasvuruKayitSonucGoster(sonuc) {
        BasvuruKayitKimlikGuncelle(sonuc);
        SonucGoster(sonuc);
    }

    function YatirimKaydet() {
        const yatirim = {
            ...BasvuruKimlikleri(),
            yatirimAdi: degerStr('Basvuru.YatirimAdi'),
            yatirimTuru: degerInt('Basvuru.yatirim.yatirimTuru'),
            harcamaTurleri: $('input[name="Basvuru.yatirim.harcamaTurleri"]:checked').map(function () { return parseInt(this.value); }).get(),
            degerZinciriAsamalari: $('input[name="Basvuru.DegerZinciriAsamalari"]:checked').map(function () { return { id: parseInt(this.value) }; }).get()
        };
        AjaxPost('/Basvuru/KaydetYatirim', yatirim, SonucGoster);
    }

    function FinansKaydet() {
        const model = {
            ...BasvuruKimlikleri(),
            toplamYatirimTutari: degerDec('Basvuru.finans.ToplamYatirimTutari'),
            uygunHarcamaTutari: degerDec('Basvuru.finans.UygunHarcamaTutari'),
            talepEdilenDestekTutari: degerDec('Basvuru.finans.TalepEdilenDestekTutari'),
            basvuruSahibiKatkisi: degerDec('Basvuru.finans.BasvuruSahibiKatkisi'),
            destekOrani: degerDec('Basvuru.finans.DestekOrani'),
            yatiriminAmaci: degerStr('Basvuru.finans.YatiriminAmaci')
        };
        AjaxPost('/Basvuru/KaydetFinans', model, SonucGoster);
    }

    function MaliKaydet() {
        const model = {
            ...BasvuruKimlikleri(),
            oncekiYilNetSatis: degerDec('Basvuru.mali.OncekiYilNetSatis'),
            sonYilNetSatis: degerDec('Basvuru.mali.SonYilNetSatis'),
            oncekiYilAktifToplami: degerDec('Basvuru.mali.OncekiYilAktifToplami'),
            sonYilAktifToplami: degerDec('Basvuru.mali.SonYilAktifToplami'),
            bagimsizDenetimeTabiMi: degerStr('Basvuru.mali.BagimsizDenetimeTabiMi') === '' ? null : degerBool('Basvuru.mali.BagimsizDenetimeTabiMi'),
            denetimDosyaAdi: degerStr('Basvuru.mali.DenetimDosyaAdi'),
            denetimDosyaId: degerInt('Basvuru.mali.DenetimDosyaId')
        };
        AjaxPost('/Basvuru/KaydetMali', model, SonucGoster);
    }

    function PaneliKaydet() {
        if (active === bolumFirma) BasvuruSahibiKaydet();
        else if (active === bolumIrtibat) FirmaIrtibatKaydet();
        else if (active === bolumYatirim) YatirimKaydet();
        else if (active === bolumFinans) FinansKaydet();
        else if (active === bolumMali) MaliKaydet();
        else if (active === bolumOrtaklik) OrtaklikKaydet();
        else if (active === bolumBelgeler) PopupMesajGoster(belgeMesajlari.sectionSaveInfo, true);
        else PopupMesajGoster(String(active), false);
    }

    function degerZinciriAsamalariYukle(zincirId) {
        const kimlik = BasvuruKimlikleri();
        const $tbody = $('#degerZinciriAsamaListesi');
        $tbody.empty();
        if (!zincirId) return;
        AjaxGet('/Basvuru/DegerZinciriAsamalariListele', { ...kimlik, zincirId: zincirId }, function (response) {
            if (response && response.nesne) {
                const isReadOnly = $('#degerZinciriSelect').is(':disabled') ? 'disabled' : '';
                $.each(response.nesne, function (_, item) {
                    const checkedAttr = item.secili ? 'checked="checked"' : '';
                    $tbody.append(`<tr><td class="text-center"><input type="checkbox" name="Basvuru.DegerZinciriAsamalari" value="${item.id}" ${checkedAttr} ${isReadOnly} /></td><td><strong>${item.ad}</strong></td><td>${item.aciklama ?? ''}</td></tr>`);
                });
            }
        });
    }

    function degerZinciriYukle() {
        const ilId = $('#basvuruIl').val();
        const kimlik = BasvuruKimlikleri();
        const $select = $('#degerZinciriSelect');
        $select.html('<option value="">Seçiniz...</option>');
        $('#degerZinciriAsamaListesi').empty();
        if (!ilId) return;
        AjaxGet('/Basvuru/DegerZincirleriListele', { ...kimlik, ilId: ilId }, function (response) {
            if (response && response.nesne) {
                let aktifZincirId = null;
                $.each(response.nesne, function (_, item) {
                    const selectedAttr = item.secili ? 'selected="selected"' : '';
                    $select.append(`<option value="${item.id}" ${selectedAttr}>${item.ad}</option>`);
                    if (item.secili) aktifZincirId = item.id;
                });
                if (aktifZincirId) degerZinciriAsamalariYukle(aktifZincirId);
            }
        });
    }

    function UygulamaAdresiModalKaydet() {
        const indexText = modalValue('adresModalIndex');
        const mevcutAdres = indexText === '' ? {} : sonUygulamaAdresleri[Number(indexText)];
        const adres = {
            id: mevcutAdres?.id || 0,
            ...BasvuruKimlikleri(),
            siraNo: Number(modalValue('adresModalSiraNo') || 0) || 1,
            ilceId: Number(modalValue('adresModalIlce') || 0) || 0,
            tamAdres: modalValue('adresModalTamAdres'),
            yatirimYeriStatusu: Number(modalValue('adresModalYatirimYeriStatusu') || 0) || 0,
            kiraVeyaTahsisSuresi: Number(modalValue('adresModalKiraVeyaTahsisSuresi') || 0) || 0,
            kiraTahsisBitisTarihi: modalValue('adresModalKiraTahsisBitisTarihi'),
            yapiRuhsatiDurumu: Number(modalValue('adresModalYapiRuhsatiDurumu') || 0) || 0
        };
        adresKaydet(adres);
    }

    function adresKaydet(adres) {
        AjaxPost('/Basvuru/UygulamaAdresiKaydet', adres, SonucGosterGizle);
    }

    function adresSil(adresId) {
        if (!adresId) return;
        AjaxPost('/Basvuru/UygulamaAdresiSil', { ...BasvuruKimlikleri(), id: adresId }, SonucGosterGizle);
    }

    function SonucGoster(sonuc) {
        if (sonuc?.basarili) PopupMesajGoster(sonuc.mesaj, true);
        else PopupMesajGoster(sonuc?.hataStr || sonuc?.mesaj || '', false);
    }

    function SonucGosterGizle(sonuc) {
        UygulamaAdresleriListele();
        uygulamaAdresModal?.hide();
        SonucGoster(sonuc);
    }

    function UygulamaAdresleriListele() {
        AjaxGet('/Basvuru/UygulamaAdresiListele', BasvuruKimlikleri(), function (response) {
            RenderUygulamaAdresleri(response.nesne);
        });
    }

    function adresModalAc(index) {
        const adres = index >= 0 ? sonUygulamaAdresleri[index] : {};
        modalSet('adresModalIndex', index >= 0 ? String(index) : '');
        modalSet('adresModalSiraNo', adres.siraNo);
        modalSet('adresModalIlce', adres.ilceId);
        modalSet('adresModalTamAdres', adres.tamAdres);
        modalSet('adresModalYatirimYeriStatusu', adres.yatirimYeriStatusu);
        modalSet('adresModalKiraVeyaTahsisSuresi', adres.kiraVeyaTahsisSuresi);
        modalSet('adresModalKiraTahsisBitisTarihi', adres.kiraTahsisBitisTarihi);
        modalSet('adresModalYapiRuhsatiDurumu', adres.yapiRuhsatiDurumu);
        uygulamaAdresModal?.show();
    }

    function RenderUygulamaAdresleri(uygulamaAdresleri) {
        const tbody = document.getElementById('uygulamaAdresListesi');
        if (!tbody) return;
        sonUygulamaAdresleri = uygulamaAdresleri || [];
        tbody.innerHTML = '';
        if (sonUygulamaAdresleri.length === 0) {
            const tr = document.createElement('tr');
            const td = document.createElement('td');
            td.colSpan = '8';
            td.className = 'text-muted text-center';
            td.textContent = adresBosMesaj;
            tr.appendChild(td);
            tbody.appendChild(tr);
            return;
        }
        sonUygulamaAdresleri.forEach((adres, index) => {
            const tr = document.createElement('tr');
            [adres.siraNo, adres.ilAdi, adres.ilceAdi, adres.tamAdres, adres.yatirimYeriStatusuAd, adres.kiraTahsisBitis, adres.yapiRuhsatiDurumuAd].forEach((value, alanIndex) => {
                const td = document.createElement('td');
                td.textContent = value || '';
                if (alanIndex === 3) td.className = 'adres-tam-adres';
                tr.appendChild(td);
            });
            const actionTd = document.createElement('td');
            const editBtn = document.createElement('button');
            editBtn.type = 'button';
            editBtn.className = 'btn btn-sm btn-outline-secondary mr-1';
            editBtn.innerHTML = '<i class="fas fa-edit"></i>';
            editBtn.addEventListener('click', () => adresModalAc(index));
            const deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'btn btn-sm btn-outline-danger';
            deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
            deleteBtn.addEventListener('click', () => {
                if (confirm(adresSilOnay)) adresSil(adres.id);
            });
            actionTd.appendChild(editBtn);
            actionTd.appendChild(deleteBtn);
            tr.appendChild(actionTd);
            tbody.appendChild(tr);
        });
    }

    function antiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    function dosyaSecimYaz(input, hedefId, dosyaAdiInputName) {
        const dosyaAdi = input.files && input.files.length ? input.files[0].name : belgeMesajlari.noFileSelected;
        const hedef = document.getElementById(hedefId);
        if (hedef) hedef.textContent = dosyaAdi;
        const dosyaAdiInput = document.querySelector(`[name="${dosyaAdiInputName}"]`);
        if (dosyaAdiInput && input.files && input.files.length) dosyaAdiInput.value = dosyaAdi;
    }

    function belgePaketiDogrula() {
        const dosya = document.getElementById('belgePaketiDosya');
        if (!dosya || !dosya.files || dosya.files.length === 0) {
            PopupMesajGoster(belgeMesajlari.packageFileRequired, false);
            return false;
        }
        return true;
    }

    function BelgePaketiYukle() {
        if (!belgePaketiDogrula()) return;
        const dosya = document.getElementById('belgePaketiDosya').files[0];
        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('aciklama', degerStr('Basvuru.BelgePaketiAciklama'));
        data.append('belgeBeyani', $('#belgeBeyaniSelect').val() || '');
        $('.belge-grubu-check').each(function () {
            data.append('belgeGruplari', this.value);
            if (this.checked) data.append('seciliBelgeGruplari', this.value);
        });
        data.append('dosya', dosya);
        DosyaAjaxPost('/Basvuru/BelgePaketiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.BelgePaketiDosyaId', 'Basvuru.BelgePaketiDosyaAdi', 'belgePaketiIndirBtn');
        });
    }

    function TaahhutDosyasiYukle() {
        const dosyaInput = document.getElementById('taahhutDosya');
        if (!dosyaInput || !dosyaInput.files || dosyaInput.files.length === 0) {
            PopupMesajGoster(belgeMesajlari.commitmentFileRequired, false);
            return;
        }
        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('aciklama', degerStr('Basvuru.TaahhutAciklama'));
        data.append('dosya', dosyaInput.files[0]);
        DosyaAjaxPost('/Basvuru/TaahhutDosyasiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.TaahhutDosyaId', 'Basvuru.TaahhutDosyaAdi', 'taahhutIndirBtn');
        });
    }

    function DenetimDosyasiYukle() {
        const dosyaInput = document.getElementById('denetimDosya');
        if (!dosyaInput || !dosyaInput.files || dosyaInput.files.length === 0) {
            PopupMesajGoster(belgeMesajlari.auditFileRequired, false);
            return;
        }
        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('dosya', dosyaInput.files[0]);
        DosyaAjaxPost('/Basvuru/DenetimDosyasiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.mali.DenetimDosyaId', 'Basvuru.mali.DenetimDosyaAdi', 'denetimIndirBtn');
            const nesne = sonuc?.nesne || sonuc?.Nesne || {};
            const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            if (dosyaAdi) $('#denetimDosyaSecim').text(dosyaAdi);
        });
    }

    function BasvuruDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess) {
        if (!input || !input.files || input.files.length === 0) {
            PopupMesajGoster('Dosya seçilmelidir.', false);
            return;
        }

        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('formAd', formAd);
        data.append('dosyaNo', dosyaNo);
        data.append('dosya', input.files[0]);
        DosyaAjaxPost('/Basvuru/BasvuruDosyasiYukle', data, function (sonuc) {
            if (!sonuc || !sonuc.basarili) {
                PopupMesajGoster((sonuc && (sonuc.hataStr || sonuc.mesaj)) || belgeMesajlari.uploadFailed, false);
                return;
            }

            const nesne = sonuc.nesne || sonuc.Nesne || {};
            const dosyaId = nesne.dosyaId || nesne.DosyaId || '';
            const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            const nameTarget = document.getElementById(nameTargetId);
            if (nameTarget && dosyaAdi) nameTarget.textContent = dosyaAdi;
            const downloadTarget = document.getElementById(downloadTargetId);
            if (downloadTarget && dosyaId) {
                downloadTarget.href = `/Basvuru/DosyaIndir/${dosyaId}`;
                downloadTarget.classList.remove('d-none');
            }
            if (afterSuccess) afterSuccess(sonuc);
            PopupMesajGoster(sonuc.mesaj || belgeMesajlari.uploadSucceeded, true);
        });
    }

    function OrtaklikDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess) {
        BasvuruDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess);
    }

    function DosyaAjaxPost(url, data, success) {
        $.ajax({
            url: url,
            type: 'POST',
            data: data,
            processData: false,
            contentType: false,
            dataType: 'json',
            headers: { 'RequestVerificationToken': antiForgeryToken() }
        })
            .done(function (result) { if (success) success(result); })
            .fail(function (xhr) {
                console.error(belgeMesajlari.uploadErrorConsole, xhr);
                PopupMesajGoster(belgeMesajlari.uploadFailed, false);
            });
    }

    function belgeYuklemeSonucGoster(sonuc, dosyaIdInputName, dosyaAdiInputName, indirLinkId) {
        if (!sonuc || !sonuc.basarili) {
            PopupMesajGoster((sonuc && (sonuc.hataStr || sonuc.mesaj)) || belgeMesajlari.uploadFailed, false);
            return;
        }
        const nesne = sonuc.nesne || sonuc.Nesne || {};
        const dosyaId = nesne.dosyaId || nesne.DosyaId || '';
        const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
        $(`[name="${dosyaIdInputName}"]`).val(dosyaId);
        if (dosyaAdi) $(`[name="${dosyaAdiInputName}"]`).val(dosyaAdi);
        if (dosyaId && indirLinkId) {
            const indirLink = document.getElementById(indirLinkId);
            if (indirLink) {
                indirLink.href = `/Basvuru/DosyaIndir/${dosyaId}`;
                indirLink.classList.remove('d-none');
            }
        }
        PopupMesajGoster(sonuc.mesaj || belgeMesajlari.uploadSucceeded, true);
    }
</script>


