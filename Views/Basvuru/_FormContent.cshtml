    function DenetimDosyasiYukle() {
        const dosyaInput = document.getElementById('denetimDosya');
        if (!dosyaInput || !dosyaInput.files || dosyaInput.files.length === 0) {
            PopupMesajGoster(belgeMesajlari.auditFileRequired, false);
            return;
        }
        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('dosya', dosyaInput.files[0]);
        DosyaAjaxPost('/Basvuru/DenetimDosyasiYukle', data, function (sonuc) {
            belgeYuklemeSonucGoster(sonuc, 'Basvuru.mali.DenetimDosyaId', 'Basvuru.mali.DenetimDosyaAdi', 'denetimIndirBtn');
            const nesne = sonuc?.nesne || sonuc?.Nesne || {};
            const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            if (dosyaAdi) $('#denetimDosyaSecim').text(dosyaAdi);
        });
    }

    function BasvuruDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess) {
        if (!input || !input.files || input.files.length === 0) {
            PopupMesajGoster('Dosya seçilmelidir.', false);
            return;
        }

        const data = new FormData();
        data.append('basvuruId', BasvuruId());
        data.append('formAd', formAd);
        data.append('dosyaNo', dosyaNo);
        data.append('dosya', input.files[0]);
        DosyaAjaxPost('/Basvuru/BasvuruDosyasiYukle', data, function (sonuc) {
            if (!sonuc || !sonuc.basarili) {
                PopupMesajGoster((sonuc && (sonuc.hataStr || sonuc.mesaj)) || belgeMesajlari.uploadFailed, false);
                return;
            }

            const nesne = sonuc.nesne || sonuc.Nesne || {};
            const dosyaId = nesne.dosyaId || nesne.DosyaId || '';
            const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
            const nameTarget = document.getElementById(nameTargetId);
            if (nameTarget && dosyaAdi) nameTarget.textContent = dosyaAdi;
            const downloadTarget = document.getElementById(downloadTargetId);
            if (downloadTarget && dosyaId) {
                downloadTarget.href = `/Basvuru/DosyaIndir/${dosyaId}`;
                downloadTarget.classList.remove('d-none');
            }
            if (afterSuccess) afterSuccess(sonuc);
            PopupMesajGoster(sonuc.mesaj || belgeMesajlari.uploadSucceeded, true);
        });
    }

    function OrtaklikDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess) {
        BasvuruDosyasiYukle(formAd, dosyaNo, input, nameTargetId, downloadTargetId, afterSuccess);
    }

    function DosyaAjaxPost(url, data, success) {
        $.ajax({
            url: url,
            type: 'POST',
            data: data,
            processData: false,
            contentType: false,
            dataType: 'json',
            headers: { 'RequestVerificationToken': antiForgeryToken() }
        })
            .done(function (result) { if (success) success(result); })
            .fail(function (xhr) {
                console.error(belgeMesajlari.uploadErrorConsole, xhr);
                PopupMesajGoster(belgeMesajlari.uploadFailed, false);
            });
    }

    function belgeYuklemeSonucGoster(sonuc, dosyaIdInputName, dosyaAdiInputName, indirLinkId) {
        if (!sonuc || !sonuc.basarili) {
            PopupMesajGoster((sonuc && (sonuc.hataStr || sonuc.mesaj)) || belgeMesajlari.uploadFailed, false);
            return;
        }
        const nesne = sonuc.nesne || sonuc.Nesne || {};
        const dosyaId = nesne.dosyaId || nesne.DosyaId || '';
        const dosyaAdi = nesne.dosyaAdi || nesne.DosyaAdi || '';
        $(`[name="${dosyaIdInputName}"]`).val(dosyaId);
        if (dosyaAdi) $(`[name="${dosyaAdiInputName}"]`).val(dosyaAdi);
        if (dosyaId && indirLinkId) {
            const indirLink = document.getElementById(indirLinkId);
            if (indirLink) {
                indirLink.href = `/Basvuru/DosyaIndir/${dosyaId}`;
                indirLink.classList.remove('d-none');
            }
        }
        PopupMesajGoster(sonuc.mesaj || belgeMesajlari.uploadSucceeded, true);
    }
</script>


