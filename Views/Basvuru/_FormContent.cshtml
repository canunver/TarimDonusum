@using System.Globalization
@using System.Text.Json
@model TarimDonusum.ViewModels.Basvuru.BasvuruFormViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

@{
    var b = Model.Basvuru;
    bool ro = Model.SaltOkunur;
    bool kilitli = b.Id <= 0 && !Model.DenetciGorunumu;
    int sonBolum = Model.DenetciGorunumu ? 8 : 7;
    string Dec(decimal? v) => v.HasValue ? v.Value.ToString(CultureInfo.InvariantCulture) : "";
    bool CheckedStr(IEnumerable<string> values, string value) => values.Contains(value);
    bool CheckedInt(IEnumerable<int> values, int value) => values.Contains(value);
    bool CheckedDZA(IEnumerable<DegerZinciriAsama> values, int value) => value == 1;
    string T(string key) => L[key].Value;
    string[] Items(string key) => T(key).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    string[] evetHayir = Items("Basvuru.Options.YesNo");    
    
    string basvuruIlAdi = b.basvuruFirma.il?.Ad ?? "";
    if (string.IsNullOrWhiteSpace(basvuruIlAdi) && b.IlId.HasValue)
    {
        basvuruIlAdi = Model.Iller.FirstOrDefault(x => x.Id == b.IlId.Value)?.Ad ?? "";
    }
}

<div class="basvuru-page">
    <div class="basvuru-titlebar">
        <div>
            <h1>@(Model.DenetciGorunumu ? T("Basvuru.Form.AuditTitle") : (b.Id > 0 ? T("Basvuru.Form.EditTitle") : T("Basvuru.Form.NewTitle")))</h1>
            <p>@string.Format(T("Basvuru.Form.ApplicationNo"), b.Id > 0 ? b.Id.ToString() : T("Basvuru.Form.ApplicationNoPending"))</p>
        </div>
    </div>

    <div id="ajaxMesaj"
         class="alert alert-info alert-dismissible floating-message"
         style="display:@(TempData["Mesaj"] != null ? "block" : "none")">
        <span id="ajaxMesajMetin">@TempData["Mesaj"]</span>
        <button type="button" id="ajaxMesajKapat" class="close" aria-label="@T("Basvuru.Common.Close")">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    @if (Model.Hatalar.Count > 0)
    {
        <div class="alert alert-danger">
            @foreach (string hata in Model.Hatalar)
            {
                <div>@hata</div>
            }
        </div>
    }

    @if (kilitli)
    {
        <div class="alert alert-warning">@L["Basvuru.Warning.FirstSectionRequired"]</div>
    }

    <div class="alert alert-info">@L["Basvuru.Flow.Note"]</div>

    <div class="basvuru-stepbar">
        <label for="basvuruStepSelect">@L["Basvuru.Common.Steps"]</label>
        <select id="basvuruStepSelect" class="form-control">
            <option value="1" selected="selected">@L["Basvuru.Step.1"]</option>
            <option value="2" disabled="@(kilitli)">@L["Basvuru.Step.2"]</option>
            <option value="3" disabled="@(kilitli)">@L["Basvuru.Step.3"]</option>
            <option value="4" disabled="@(kilitli)">@L["Basvuru.Step.4"]</option>
            <option value="5" disabled="@(kilitli)">@L["Basvuru.Step.5"]</option>
            <option value="6" disabled="@(kilitli)">@L["Basvuru.Step.6"]</option>
            <option value="7" disabled="@(kilitli)">@L["Basvuru.Step.7"]</option>
            @if (Model.DenetciGorunumu)
            {
                <option value="8">@L["Basvuru.Step.8"]</option>
            }
        </select>
        <button type="button" class="btn btn-outline-secondary nav-prev">@L["Basvuru.Common.Previous"]</button>
        <button type="button" class="btn btn-primary" onclick="PaneliKaydet()">@L["Basvuru.Common.Save"]</button>
        <button type="button" class="btn btn-outline-primary nav-next">@L["Basvuru.Common.Next"]</button>
        <button type="button" class="btn btn-outline-info icon-action" id="stepHelpBtn" title="@T("Basvuru.Common.Help")">?</button>
    </div>
    <input type="hidden" name="Basvuru.Id" value="@b.Id" />
    <input type="hidden" name="Basvuru.FirmaId" value="@b.FirmaId" />
    <div class="basvuru-shell">
        <main class="basvuru-panels">
            <section class="basvuru-panel active" data-panel="1">
                <h2>@L["Basvuru.Section1.Title"]</h2>
                <p>@L["Basvuru.Section1.Description"]</p>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="basvuruDonemi">@L["Basvuru.Field.BasvuruDonemi"]</label>
                        <select id="basvuruDonemi" name="Basvuru.DonemId" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            @foreach (var donem in Model.Donemler)
                            {
                                bool secili = b.DonemId == donem.Id;
                                bool secilebilir = donem.SecilebilirMi();
                                string durum = secilebilir ? T("Basvuru.Donem.Open") : T("Basvuru.Donem.Closed");
                                <option value="@donem.Id" selected="@secili" disabled="@(!secilebilir && !secili)">
                                    @donem.Ad (@durum)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line">
                        <label for="basvuruIl">@L["Basvuru.Field.Il"]</label>
                        <select id="basvuruIl" name="Basvuru.IlId" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            @foreach (var il in Model.Iller)
                            {
                                <option value="@il.Id" selected="@(b.IlId == il.Id)">@il.Kod.ToString("00") - @il.Ad</option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line company-line">
                        <label for="vergiKimlikNo">@L["Basvuru.Field.VergiKimlikNo"]</label>
                        <input id="vergiKimlikNo" name="Basvuru.VergiKimlikNo" value="@b.basvuruFirma.firma.vergiKimlikNo" disabled="@ro" />
                        @if (!ro)
                        {
                            <button type="button" class="btn btn-outline-primary icon-action" id="firmaSorgulaBtn" title="@T("Basvuru.Firma.Query")">?</button>
                            <button type="button" class="btn btn-outline-success icon-action" id="firmaYeniBtn" title="@T("Basvuru.Firma.ModalTitle")">+</button>
                            <button type="button" class="btn btn-outline-secondary icon-action" id="firmaDuzenleBtn" title="@T("Basvuru.Common.Edit")">
                                <i class="fas fa-edit"></i>
                            </button>
                        }
                    </div>

                    <div class="preapp-line">
                        <label for="firmaAdi">@L["Basvuru.Field.FirmaAdi"]</label>
                        <input id="firmaAdi" name="Basvuru.TicaretUnvani" value="@b.basvuruFirma.firma.ticaretUnvani" readonly aria-label="@T("Basvuru.Field.FirmaAdi")" />
                    </div>

                    <div class="preapp-line two-fields">
                        <label for="basvuruKonusu">@L["Basvuru.Field.BasvuruKonusu"]</label>
                        <input id="basvuruKonusu" name="Basvuru.BasvuruKonusu" value="@b.basvuruFirma.BasvuruKonusu" disabled="@ro" />
                        <label for="basvuruTipi">@L["Basvuru.Field.BasvuruTipi"]</label>
                        <select id="basvuruTipi" name="Basvuru.BasvuruSahibiTuru" disabled="@ro">
                            @foreach (TarimDonusum.Models.enumBasvuruSahibiTuru item in Enum.GetValues<TarimDonusum.Models.enumBasvuruSahibiTuru>())
                            {
                                <option value="@((int)item)" selected="@(b.basvuruFirma.BasvuruSahibiTuru == item)">@IsimBul.EnumAdi(item, L)</option>
                            }
                        </select>
                    </div>

                    <div class="preapp-line">
                        <label for="sonIkiYil">@L["Basvuru.Field.SonIkiYildirFaalMi"]</label>
                        <select id="sonIkiYil" name="Basvuru.SonIkiYildirFaalMi" disabled="@ro">
                            <option value="false" selected="@(!b.basvuruFirma.SonIkiYildirFaalMi)">@(evetHayir.Length > 1 ? evetHayir[1] : "Hayır")</option>
                            <option value="true" selected="@(b.basvuruFirma.SonIkiYildirFaalMi)">@(evetHayir.Length > 0 ? evetHayir[0] : "Evet")</option>
                        </select>
                    </div>

                    <h3 class="preapp-subtitle">@L["Basvuru.Section2.PartnershipTitle"]</h3>
                    <div class="preapp-line two-fields">
                        <label for="ozelSektorPayi">@L["Basvuru.Field.OzelSektorPayi"]</label>
                        <input id="ozelSektorPayi" name="Basvuru.OzelSektorPayi" type="number" step="0.01" value="@Dec(b.basvuruFirma.OzelSektorPayi)" disabled="@ro" />
                        <label for="bagliOrtakIsletmeVarMi">@L["Basvuru.Field.BagliOrtakIsletmeVarMi"]</label>
                        <select id="bagliOrtakIsletmeVarMi" name="Basvuru.BagliOrtakIsletmeVarMi" disabled="@ro">
                            <option value="">@L["Basvuru.Common.Select"]</option>
                            <option value="false" selected="@(!b.basvuruFirma.BagliOrtakIsletmeVarMi )">@(evetHayir.Length > 1 ? evetHayir[1] : "Hayır")</option>
                            <option value="true" selected="@(b.basvuruFirma.BagliOrtakIsletmeVarMi )">@(evetHayir.Length > 0 ? evetHayir[0] : "Evet")</option>
                        </select>
                    </div>
                    <div class="preapp-line textarea-line"><label for="bagliOrtakAciklama">@L["Basvuru.Field.BagliOrtakAciklama"]</label>
                        <textarea id="bagliOrtakAciklama" name="Basvuru.BagliOrtakAciklama" disabled="@ro">@b.basvuruFirma.BagliOrtakAciklama</textarea>
                    </div>
                </div>
            </section>
            <section class="basvuru-panel" data-panel="2">
                <h2>@L["Basvuru.Section2.Title"]</h2>
                <h3 class="preapp-subtitle">@L["Basvuru.ContactInformation"]</h3>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="irtibatKisisi">@L["Basvuru.Field.IrtibatKisisi"]</label>
                        <input id="irtibatKisisi" name="Basvuru.irtibat.kisi" value="@b.irtibat.kisi" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatUnvani">@L["Basvuru.Field.IrtibatUnvani"]</label>
                        <input id="irtibatUnvani" name="Basvuru.irtibat.unvan" value="@b.irtibat.unvan" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatTelefon">@L["Basvuru.Field.IrtibatTelefon"]</label>
                        <input id="irtibatTelefon" name="Basvuru.irtibat.telefon" value="@b.irtibat.telefon" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="irtibatEposta">@L["Basvuru.Field.IrtibatEposta"]</label>
                        <input id="irtibatEposta" name="Basvuru.irtibat.ePosta" type="email" value="@b.irtibat.ePosta" disabled="@ro" />
                    </div>
                    <div class="preapp-line textarea-line">
                        <label for="iletisimAdresi">@L["Basvuru.Field.IletisimAdresi"]</label>
                        <textarea id="iletisimAdresi" name="Basvuru.irtibat.adres" disabled="@ro">@b.irtibat.adres</textarea>
                    </div>
                    <div class="preapp-line textarea-line">
                        <label for="yetkiliKisiler">@L["Basvuru.Field.YetkiliKisiler"]</label>
                        <textarea id="yetkiliKisiler" name="Basvuru.irtibat.yetkiliKisiler" disabled="@ro">@b.irtibat.yetkiliKisiler</textarea>
                    </div>
                </div>
            </section>
            <section class="basvuru-panel" data-panel="3">
                <h2>@L["Basvuru.Section3.Title"]</h2>
                <div class="preapp-form">
                    <div class="preapp-line">
                        <label for="yatirimAdi">@L["Basvuru.Field.YatirimAdi"]</label>
                        <input id="yatirimAdi" name="Basvuru.YatirimAdi" value="@b.yatirim.yatirimAdi" disabled="@ro" />
                    </div>
                    <div class="preapp-line">
                        <label for="yatirimTuru">@L["Basvuru.Field.YatirimTuru"]</label>
                        <select id="yatirimTuru" name="Basvuru.yatirim.yatirimTuru" disabled="@ro">
                            @foreach (enumYatirimTuru item in Enum.GetValues<enumYatirimTuru>())
                            {
                                <option value="@((int)item)" selected="@(b.yatirim.yatirimTuru == item)">
                                    @IsimBul.EnumAdi(item, L)
                                </option>
                            }

                        </select>
                    </div>
                    <div class="preapp-line">
                        <label for="degerZinciriSelect">@L["Basvuru.Field.DegerZinciri"]</label>
                        <select id="degerZinciriSelect" name="Basvuru.DegerZinciriId" disabled="@ro">
                        </select>
                    </div>
                </div>
                <h3>@L["Basvuru.Field.DegerZinciriAsamalari"]</h3>
                <div class="table-responsive deger-zinciri-asama-wrap">
                    <table class="table deger-zinciri-asama-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Common.Select"]</th>
                                <th>@L["Basvuru.Field.DegerZinciriAsamasi"]</th>
                                <th>@L["Basvuru.Field.KisaAciklama"]</th>
                            </tr>
                        </thead>
                        <tbody id="degerZinciriAsamaListesi">
                        </tbody>
                    </table>
                </div>
                <h3>@L["Basvuru.Field.HarcamaTurleri"]</h3>
                <div class="check-grid">
                    @foreach (var item in Enum.GetValues<enumHarcamaTuru>())
                    {
                        if ((int)item > 0)
                        {
                            <label><input type="checkbox" name="Basvuru.yatirim.harcamaTurleri" value="@((int)item)" checked="@CheckedInt(b.yatirim.harcamaTurleri, (int)item)" disabled="@ro" /> @IsimBul.EnumAdi(item, L)</label>
                        }
                    }
                </div>
            </section>
            <section class="basvuru-panel" data-panel="4">
                <h2>@L["Basvuru.Section4.Title"]</h2>
                <div class="adres-toolbar">
                    @if (!ro)
                    {
                        <button type="button" class="btn btn-outline-primary" id="adresYeniBtn"><i class="fas fa-plus"></i> @L["Basvuru.Address.New"]</button>
                    }
                </div>
                <div class="table-responsive uygulama-adres-wrap">
                    <table class="table uygulama-adres-table">
                        <thead>
                            <tr>
                                <th>@L["Basvuru.Field.SiraNo"]</th>
                                <th>@L["Basvuru.Field.Il"]</th>
                                <th>@L["Basvuru.Field.Ilce"]</th>
                                <th>@L["Basvuru.Field.TamAdres"]</th>
                                <th>@L["Basvuru.Field.YatirimYeriStatusu"]</th>
                                <th>@L["Basvuru.Field.KiraTahsis"]</th>
                                <th>@L["Basvuru.Field.YapiRuhsatiDurumu"]</th>
                                @if (!ro)
                                {
                                    <th>@L["Basvuru.Common.Actions"]</th>
                                }
                            </tr>
                        </thead>
                        <tbody id="uygulamaAdresListesi"></tbody>
                    </table>
                </div>
            </section>

            <div class="basvuru-footer">
                <div>
                </div>
            </div>
        </main>
    </div>
</div>

@if (!ro)
{
    <div class="modal fade firma-modal" id="firmaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Firma.ModalTitle"]</h5>
                    <button type="button" class="close firma-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <div class="alert alert-info">@L["Basvuru.Firma.ModalInfo"]</div>
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Field.VergiKimlikNo"]<input id="modalVergiKimlikNo" /></label>
                            <label>@L["Basvuru.Field.TicaretUnvani"]<input id="modalTicaretUnvani" /></label>
                            <label>@L["Basvuru.Field.TicaretSicilNo"]<input id="modalTicaretSicilNo" /></label>
                            <label>@L["Basvuru.Field.KurulusTarihi"]<input id="modalKurulusTarihi" type="date" /></label>
                            <label>@L["Basvuru.Field.MersisNo"]<input id="modalMersisNo" /></label>
                            <label>@L["Basvuru.Field.NaceKodu"]<input id="modalNaceKodu" /></label>
                            <label>@L["Basvuru.Field.WebSitesi"]<input id="modalWebSitesi" /></label>
                            <label>@L["Basvuru.Field.Telefon"]<input id="modalTelefon" /></label>
                            <label>@L["Basvuru.Field.KepAdresi"]<input id="modalKepAdresi" /></label>
                            <label>@L["Basvuru.Field.Eposta"]<input id="modalEposta" type="email" /></label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.FaaliyetKonusu"]<textarea id="modalFaaliyetKonusu"></textarea></label>
                        <label class="wide-label">@L["Basvuru.Field.FirmaAdresi"]<textarea id="modalAdres"></textarea></label>
                    </div>
                    <div class="text-danger mt-2" id="firmaModalHata"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary firma-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="firmaKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade firma-modal uygulama-adres-modal" id="uygulamaAdresModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content firma-modal-content">
                <div class="modal-header firma-modal-header">
                    <h5 class="modal-title">@L["Basvuru.Address.ModalTitle"]</h5>
                    <button type="button" class="close uygulama-adres-modal-kapat" data-dismiss="modal" aria-label="@T("Basvuru.Common.Close")">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body firma-modal-body">
                    <input id="adresModalIndex" type="hidden" />
                    <div class="firma-modal-fields">
                        <div class="form-grid">
                            <label>@L["Basvuru.Field.SiraNo"]<input id="adresModalSiraNo" type="number" min="1" step="1" /></label>
                            <label>@L["Basvuru.Field.Il"]<input id="adresModalIl" value="@basvuruIlAdi" readonly /></label>
                            <label>
                                @L["Basvuru.Field.Ilce"]
                                <select id="adresModalIlce">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @foreach (var ilce in Model.Ilceler)
                                    {
                                        <option value="@ilce.Id">@ilce.Ad</option>
                                    }
                                </select>
                            </label>
                            <label>
                                @L["Basvuru.Field.YatirimYeriStatusu"]
                                <select id="adresModalYatirimYeriStatusu">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @foreach(var item in Enum.GetValues<TarimDonusum.Models.enumYatirimYeriDurumu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                            <label>@L["Basvuru.Field.KiraVeyaTahsisSuresi"]<input id="adresModalKiraVeyaTahsisSuresi" type="number" min="0" step="1" /></label>
                            <label>@L["Basvuru.Field.KiraTahsisBitisTarihi"]<input id="adresModalKiraTahsisBitisTarihi" type="date" /></label>
                            <label>
                                @L["Basvuru.Field.YapiRuhsatiDurumu"]
                                <select id="adresModalYapiRuhsatiDurumu">
                                    <option value="">@L["Basvuru.Common.Select"]</option>
                                    @foreach (var item in Enum.GetValues < TarimDonusum.Models.enumYapiRuhsatiDurumu>())
                                    {
                                        <option value="@((int)item)">@TarimDonusum.Models.IsimBul.EnumAdi(item, L)</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <label class="wide-label">@L["Basvuru.Field.TamAdres"]<textarea id="adresModalTamAdres"></textarea></label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary uygulama-adres-modal-kapat" data-dismiss="modal">@L["Basvuru.Common.Cancel"]</button>
                    <button type="button" class="btn btn-primary" id="adresKaydetBtn">@L["Basvuru.Common.Save"]</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    var active=1;
    const adresBosMesaj = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.Empty")));
    const adresSilOnay = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Address.DeleteConfirm")));
    function modalValue(id) {
        return document.getElementById(id)?.value || '';
    }

    var uygulamaAdresModal;
    document.addEventListener('DOMContentLoaded', () => {
        active = 1;
        const lastStep = @sonBolum;
        let locked = @(kilitli ? "true" : "false");
        const lockedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.LockedMessage")));
        const unsavedMessage = @Html.Raw(JsonSerializer.Serialize(T("Basvuru.Js.UnsavedMessage")));
        const stepSelect = document.getElementById('basvuruStepSelect');
        stepSelect?.addEventListener('change', () => show(Number(stepSelect.value)));
        document.querySelectorAll('.nav-prev').forEach(btn => btn.addEventListener('click', () => show(active - 1)));
        document.querySelectorAll('.nav-next').forEach(btn => btn.addEventListener('click', () => show(active + 1)));
        let dirty = false;
        document.getElementById('adresYeniBtn')?.addEventListener('click', () => adresModalAc(-1));

        uygulamaAdresModal = new bootstrap.Modal(
            document.getElementById('uygulamaAdresModal')
        );


        // $.querySelectorAll('input[name], select[name], textarea[name]').forEach(el => {
        //     if (el.type === 'hidden' || el.name === '__RequestVerificationToken')
        //         return;

        //     el.addEventListener('change', () => dirty = true);
        //     el.addEventListener('input', () => dirty = true);
        // });

        function show(step) {
            if (locked && step > 1) {
                alert(lockedMessage);
                return;
            }
            if (step < 1 || step > lastStep) return;
            if (dirty && !confirm(unsavedMessage)) {
                if (stepSelect) stepSelect.value = String(active);
                return;
            }

            active = step;
            dirty = false;
            if (stepSelect) stepSelect.value = String(active);
            document.querySelectorAll('.basvuru-panel').forEach(x => x.classList.toggle('active', x.dataset.panel == step));
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Seçilen Değer Zincirine göre Tabloyu dolduran fonksiyon
        function degerZinciriAsamalariYukle(zincirId) {
            var formId = degerInt('Basvuru.Id');
            const $tbody = $('#degerZinciriAsamaListesi');
            $tbody.empty(); // Temizle

            if (!zincirId) return;

            // formId'yi de parametre olarak gönderiyoruz
            AjaxGet('/Basvuru/DegerZinciriAsamalariListele', { zincirId: zincirId, basvuruId: formId }, function (response) {
                if (response && response.nesne) {
                    const isReadOnly = $('#degerZinciriSelect').is(':disabled') ? 'disabled' : '';

                    $.each(response.nesne, function (index, item) {
                        // C# tarafı checked dediyse işaretliyoruz
                        const checkedAttr = item.secili ? 'checked="checked"' : '';

                        const row = `
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" name="Basvuru.DegerZinciriAsamalari" value="${item.id}" ${checkedAttr} ${isReadOnly} />
                                </td>
                                <td><strong>${item.ad}</strong></td>
                                <td>${item.aciklama ?? ''}</td>
                            </tr>
                        `;
                        $tbody.append(row);
                    });
                } else {
                    $tbody.append('<tr><td colspan="3" class="text-center text-muted">Bu değer zincirine ait aşama bulunamadı.</td></tr>');
                }
            });
        }

        function degerZinciriYukle() {
            var ilId= $("#basvuruIl").val();
            formId = degerInt('Basvuru.Id')

            const $select = $('#degerZinciriSelect');
            $select.html('<option value="">Seçiniz...</option>'); // Temizle
            $('#degerZinciriAsamaListesi').empty(); // Eski aşamaları sil

            if (!ilId) return;

            // formId'yi de parametre olarak gönderiyoruz
            AjaxGet('/Basvuru/DegerZincirleriListele', { ilId: ilId, basvuruId: formId }, function (response) {
                console.log(response);
                if (response && response.nesne) {
                    let aktifZincirId = null;

                    $.each(response.nesne, function (index, item) {
                        // Eğer C# tarafı bu kayıt için true döndüyse 'selected' özniteliğini ekliyoruz
                        const selectedAttr = item.secili ? 'selected="selected"' : '';
                        $select.append(`<option value="${item.id}" ${selectedAttr}>${item.ad}</option>`);
                
                        if (item.secili) {
                            aktifZincirId = item.id;
                        }
                    });

                    // Eğer veritabanından seçili bir zincir geldiyse, onun aşamalarını da otomatik yükle
                    if (aktifZincirId) {
                        degerZinciriAsamalariYukle(aktifZincirId);
                    }
                }
            });
        }

        $('[name="Basvuru.IlId"]').on('change', function () {
            degerZinciriYukle();
        });

        // 2. Değer Zinciri değiştiğinde Aşamaları yükle
        $('#degerZinciriSelect').on('change', function () {
            degerZinciriAsamalariYukle($(this).val());
        });

        document.getElementById('adresKaydetBtn')?.addEventListener('click', async () => {
            const indexText = modalValue('adresModalIndex');
            const mevcutAdres = indexText === '' ? {} : sonUygulamaAdresleri[Number(indexText)];
            const seciliIlceId = Number(modalValue('adresModalIlce') || 0) || null;
            const adres = {
                id: mevcutAdres?.id || 0,
                basvuruId: degerInt('Basvuru.Id'),
                siraNo: Number(modalValue('adresModalSiraNo') || 0) || 1,
                ilceId: seciliIlceId,
                tamAdres: modalValue('adresModalTamAdres'),
                yatirimYeriStatusu: Number(modalValue('adresModalYatirimYeriStatusu') || 0) || null,
                kiraVeyaTahsisSuresi: Number(modalValue('adresModalKiraVeyaTahsisSuresi') || 0) || null,
                kiraTahsisBitisTarihi: modalValue('adresModalKiraTahsisBitisTarihi'),
                yapiRuhsatiDurumu: Number(modalValue('adresModalYapiRuhsatiDurumu') || 0) || null
            };

            adresKaydet(adres);
        });

        degerZinciriYukle();
        UygulamaAdresleriListele();
    });

    function SonucGoster(sonuc)
    {
        if (sonuc.basarili) {
            PopupMesajGoster(sonuc.mesaj, true);
        } else {
            PopupMesajGoster(sonuc.hataStr, false);
        }
    }

    function SonucGosterGizle(sonuc)
    {
        UygulamaAdresleriListele();
        uygulamaAdresModal.hide();
        SonucGoster(sonuc);
    }

    function adresKaydet(adres) {
        AjaxPost('/Basvuru/UygulamaAdresiKaydet', adres, SonucGosterGizle);
    }

    function adresSil(adresId) {
        if (!adresId) return;
        AjaxPost('/Basvuru/UygulamaAdresiSil', {id: adresId}, SonucGosterGizle);
    }

    function FirmaIrtibatKaydet() {
        const model = {
            "BasvuruId": degerInt('Basvuru.Id'),
            "kisi":  degerStr('Basvuru.irtibat.kisi'),
            "unvan": degerStr('Basvuru.irtibat.unvan'),
            "telefon": degerStr('Basvuru.irtibat.telefon'),
            "ePosta": degerStr('Basvuru.irtibat.ePosta'),
            "adres": degerStr('Basvuru.irtibat.adres'),
            "yetkiliKisiler": degerStr('Basvuru.irtibat.yetkiliKisiler'),
        };
        AjaxPost('/Basvuru/KaydetIrtibat', model, SonucGoster);
    }

    function FirmaBasvuruKaydet() {
        const basvuruFirma = {
            "Id": degerInt('Basvuru.Id'),
            "firmaId":  degerInt('Basvuru.FirmaId'),
            "donemId": degerInt('Basvuru.DonemId'),
            "ilId": degerInt('Basvuru.IlId'),
            "BasvuruKonusu": degerStr('Basvuru.BasvuruKonusu'),
            "SonIkiYildirFaalMi": degerBool('Basvuru.SonIkiYildirFaalMi'),
            "BasvuruSahibiTuru": degerInt('Basvuru.BasvuruSahibiTuru'),
            "OzelSektorPayi": degerDec('Basvuru.OzelSektorPayi'),
            "BagliOrtakIsletmeVarMi": degerBool('Basvuru.BagliOrtakIsletmeVarMi'),
            "BagliOrtakAciklama": degerStr('Basvuru.BagliOrtakAciklama')
        };
        AjaxPost('/Basvuru/KaydetFirmaBasvuru', 
            basvuruFirma, 
            SonucGoster
        );
    }

    function YatirimKaydet()
    {
        const yatirim = {
            "basvuruId": degerInt('Basvuru.Id'),
            "yatirimAdi": degerStr('Basvuru.YatirimAdi'),
            "yatirimTuru": degerInt('Basvuru.yatirim.yatirimTuru'),
            "harcamaTurleri": $('input[name="Basvuru.yatirim.harcamaTurleri"]:checked').map(function () { return parseInt(this.value);}).get(),
            "degerZinciriAsamalari":  $('input[name="Basvuru.DegerZinciriAsamalari"]:checked').map(
                function ()  {
                    return {
                        id: parseInt(this.value)
                    };
                }
            ).get()};
        AjaxPost('/Basvuru/KaydetYatirim', 
            yatirim, 
            SonucGoster
        );
    }

    function PaneliKaydet()
    {
        if(active == 1)
            FirmaBasvuruKaydet()
        else if(active == 2)
            FirmaIrtibatKaydet()
        else if(active == 3)
            YatirimKaydet()
        else
            alert(active);
    }
    
    function UygulamaAdresleriListele() {
        const formId = degerInt('Basvuru.Id');
        AjaxGet('/Basvuru/UygulamaAdresiListele', { basvuruId: formId },
            function (response) {
                RenderUygulamaAdresleri(response.nesne);
            }
        );
    }

    function modalSet(id, value) {
        const el = document.getElementById(id);
        if (el) el.value = value || '';
        
        if (el.type === "date" && value) {
            el.value = value.substring(0, 10);
        } 
        else {
            el.value = value || '';
        }
    }

    var sonUygulamaAdresleri;

    function modalOlustur(element) {
        if (!element) return null;
        return {
            show: () => window.jQuery(element).modal('show'),
            hide: () => window.jQuery(element).modal('hide')
        };
    }

    function adresModalAc(index) {
        const adres = index >= 0 ? sonUygulamaAdresleri[index] : {};
        modalSet('adresModalIndex', index >= 0 ? String(index) : '');
        modalSet('adresModalSiraNo', adres.siraNo);
        modalSet('adresModalIl', adres.ilId);
        modalSet('adresModalIlce', adres.ilceId);
        modalSet('adresModalTamAdres', adres.tamAdres);
        modalSet('adresModalYatirimYeriStatusu', adres.yatirimYeriStatusu);
        modalSet('adresModalKiraVeyaTahsisSuresi', adres.kiraVeyaTahsisSuresi);
        modalSet('adresModalKiraTahsisBitisTarihi', adres.kiraTahsisBitisTarihi);
        modalSet('adresModalYapiRuhsatiDurumu', adres.yapiRuhsatiDurumu);
        uygulamaAdresModal.show();
    }

    function RenderUygulamaAdresleri(uygulamaAdresleri) {
        const uygulamaAdresListesi = document.getElementById("uygulamaAdresListesi");
        if (!uygulamaAdresListesi) return;
        uygulamaAdresleri = uygulamaAdresleri || [];
        sonUygulamaAdresleri = uygulamaAdresleri;
        uygulamaAdresListesi.innerHTML = '';

        if (uygulamaAdresleri.length === 0) {
            const tr = document.createElement('tr');
            const td = document.createElement('td');
            td.colSpan = "7"; //at(ro ? "7" : "8");
            td.className = 'text-muted text-center';
            td.textContent = adresBosMesaj;
            tr.appendChild(td);
            uygulamaAdresListesi.appendChild(tr);
            return;
        }

        uygulamaAdresleri.forEach((adres, index) => {
            const tr = document.createElement('tr');
            const alanlar = [
                String(adres.siraNo),
                adres.ilAdi,
                adres.ilceAdi,
                adres.tamAdres,
                "",
                adres.kiraTahsisBitis,
                ""
            ];

            alanlar.forEach((value, alanIndex) => {
                const td = document.createElement('td');
                td.textContent = value || '';
                if (alanIndex === 3) td.className = 'adres-tam-adres';
                tr.appendChild(td);
            });

            const actionTd = document.createElement('td');
            const editBtn = document.createElement('button');
            const deleteBtn = document.createElement('button');

            editBtn.type = 'button';
            editBtn.className = 'btn btn-sm btn-outline-secondary mr-1';
            editBtn.innerHTML = '<i class="fas fa-edit"></i>';
            editBtn.addEventListener('click', () => adresModalAc(index));

            deleteBtn.type = 'button';
            deleteBtn.className = 'btn btn-sm btn-outline-danger';
            deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
            deleteBtn.addEventListener('click', async () => {
                if (!confirm(adresSilOnay)) return;
                adresSil(adres.id);
            });

            actionTd.appendChild(editBtn);
            actionTd.appendChild(deleteBtn);
            tr.appendChild(actionTd);

            uygulamaAdresListesi.appendChild(tr);
        });
    }
</script>
