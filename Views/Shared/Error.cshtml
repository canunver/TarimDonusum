@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="container py-5">
    <div class="alert alert-danger">
        <h1 class="h4">İşlem tamamlanamadı.</h1>
        <p class="mb-0">Beklenmeyen bir hata oluştu. Hata loga yazıldı; lütfen işlemi tekrar deneyin.</p>
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            Hata takip no: <code>@Model.RequestId</code>
        </p>
    }
</div>
