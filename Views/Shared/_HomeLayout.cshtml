@{
    var title = ViewData["Title"] ?? "Başvuru Portalı";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
    <style>
        .home-background {
            background-repeat: no-repeat;
            background-position: center center;
            background-size: 100% auto;
        }
    </style>
</head>

<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <span class="navbar-brand mb-0 h1">
                TKDK Başvuru Portalı
            </span>

            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <span class="nav-link text-muted">
                        Geri Ödemeli Destek Başvuru Sistemi
                    </span>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/Home/Index" class="brand-link">
                <img src="~/img/TKDKLogoBeyaz.png"
                     alt="TKDK"
                     class="brand-image"
                     style="float:none;margin:0;max-height:42px;">

                <div style="display:inline-block;vertical-align:middle;margin-left:8px;">
                    <div style="font-size:16px;font-weight:600;">TKDK</div>
                    <div style="font-size:11px;line-height:12px;">
                        Başvuru Portalı
                    </div>
                </div>
            </a>

            <div class="sidebar">
                <nav class="mt-2">
                    <ul id="homeMenu"
                        class="nav nav-pills nav-sidebar flex-column"
                        data-widget="treeview"
                        data-accordion="false">

                        <li class="nav-item">
                            <a href="/Home/Index" class="nav-link active">
                                <i class="nav-icon fas fa-sign-in-alt"></i>
                                <p>Giriş</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="/Home/YeniKullanici" class="nav-link">
                                <i class="nav-icon fas fa-user-plus"></i>
                                <p>Yeni Kullanıcı</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="/Home/SifremiUnuttum" class="nav-link">
                                <i class="nav-icon fas fa-key"></i>
                                <p>Şifremi Unuttum</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="nav-icon far fa-question-circle"></i>
                                <p>
                                    Sık Sorulan Sorular
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="/Home/SSS?konu=kayit" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Nasıl Kayıt Olurum?</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Home/SSS?konu=sifre" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Şifremi Unuttum</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="/Home/SSS?konu=basvuru" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Nasıl Başvuru Yaparım?</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="nav-icon far fa-file-pdf"></i>
                                <p>
                                    İlgili Dokümanlar
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="/dokumanlar/2027-basvuru-rehberi.pdf" target="_blank" class="nav-link">
                                        <i class="far fa-file-pdf nav-icon"></i>
                                        <p>2027 Başvuru Rehberi</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="/dokumanlar/basvuru-formu.pdf" target="_blank" class="nav-link">
                                        <i class="far fa-file-pdf nav-icon"></i>
                                        <p>Başvuru Formu</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper home-background" style="background-image:url('@TarimDonusum.Controllers.HomeController.RastgeleResim()');">
            <section class="content pt-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <footer class="main-footer text-sm">
            <strong>Tarım ve Kırsal Kalkınmayı Destekleme Kurumu</strong>
            <div class="float-right d-none d-sm-inline">
                v1.0.0 © 2027
            </div>
        </footer>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>