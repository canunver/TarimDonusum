@using System.Globalization
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<TarimDonusum.SharedResource> L
@{
    var title = ViewData["Title"] ?? L["Layout.DefaultTitle"];
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var kullaniciAdSoyad = Context.Session.GetString("KULLANICI_ADSOYAD") ?? "";
}

<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TarimDonusum.styles.css" asp-append-version="true" />
    <style>
        .flag {
            width: 24px;
            height: 18px;
            border: 1px solid #ced4da;
            border-radius: 2px;
        }

        .flag-active {
            width: 24px;
            height: 18px;
            border: 2px solid #007bff;
            border-radius: 2px;
        }

        .basvuru-content {
            background: #f4f6f9;
        }

        .user-chip {
            color: #495057;
            font-weight: 600;
        }
    </style>
</head>

<body class="hold-transition sidebar-mini layout-fixed basvuru-layout">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <span class="navbar-brand mb-0 h1">
                @L["Layout.ApplicationPortal"]
            </span>

            <ul class="navbar-nav ml-auto align-items-center">
                <li class="nav-item mr-2">
                    <a class="nav-link p-1 flag-link"
                       asp-controller="Dil"
                       asp-action="Degistir"
                       asp-route-culture="tr"
                       asp-route-returnUrl="@returnUrl"
                       title="Turkce">
                        <img src="~/img/flags/tr.svg" class="@(culture == "tr" ? "flag-active" : "flag")" />
                    </a>
                </li>

                <li class="nav-item mr-3">
                    <a class="nav-link p-1 flag-link"
                       asp-controller="Dil"
                       asp-action="Degistir"
                       asp-route-culture="en"
                       asp-route-returnUrl="@returnUrl"
                       title="English">
                        <img src="~/img/flags/gb.svg" class="@(culture == "en" ? "flag-active" : "flag")" />
                    </a>
                </li>

                <li class="nav-item">
                    <span class="nav-link user-chip">
                        <i class="far fa-user mr-1"></i>
                        @kullaniciAdSoyad
                    </span>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/Basvuru" class="brand-link">
                <img src="~/img/TKDKLogoBeyaz.png"
                     alt="TKDK"
                     class="brand-image"
                     style="float:none;margin:0;max-height:42px;">

                <div style="display:inline-block;vertical-align:middle;margin-left:8px;">
                    <div style="font-size:16px;font-weight:600;">TKDK</div>
                    <div style="font-size:11px;line-height:12px;">
                        @L["Layout.ApplicationPortal"]
                    </div>
                </div>
            </a>

            <div class="sidebar">
                <nav class="mt-2">
                    <ul id="basvuruMenu"
                        class="nav nav-pills nav-sidebar flex-column"
                        data-widget="treeview"
                        role="menu"
                        data-accordion="false">
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper basvuru-content">
            <section class="content pt-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <footer class="main-footer text-sm basvuru-main-footer">
            <strong>@L["Layout.InstitutionName"]</strong>
            <div class="float-right d-none d-sm-inline">
                v1.0.0 © 2027
            </div>
        </footer>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script type="text/javascript">
        $(function () {
            BasvuruMenuYukle();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
