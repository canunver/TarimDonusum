@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewData["Title"] = "Giriş";
}
<style>
    .login-card {
        background: rgba(255,255,255,.55) !important;
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(4px);
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
    }

        .login-card .card-header {
            background: rgba(0,123,255,.45) !important;
            color: white;
        }

        .login-card .card-body,
        .login-card .card-footer {
            background: rgba(255,255,255,.35) !important;
        }</style>

<div class="row justify-content-center" style="margin-top:140px;">
    <div class="col-md-5">

        <div class="card card-primary login-card">
            <div class="card-header">
                <h3 class="card-title">Sisteme Giriş</h3>
            </div>

            <div class="card-body">
                <div class="form-group">
                    <label>Kullanıcı Kodu</label>
                    <input type="text" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Şifre</label>
                    <input type="password" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Güvenlik Kodu</label>

                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text p-0">
                                <img id="captchaImg"
                                     src="/Captcha/Resim?t=@DateTime.Now.Ticks"
                                     style="height:38px; width:120px; cursor:pointer;"
                                     title="Yenilemek için tıklayın" />
                            </span>
                        </div>

                        <input type="text" name="GuvenlikKodu" class="form-control" autocomplete="off" />

                        <div class="input-group-append">
                            <button type="button"
                                    id="btnCaptchaYenile"
                                    class="btn btn-outline-secondary"
                                    title="Güvenlik kodunu yenile">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-footer">
                <button class="btn btn-primary">
                    <i class="fas fa-sign-in-alt"></i> Giriş
                </button>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function captchaYenile() {
            $("#captchaImg").attr("src", "/Captcha/Resim?t=" + new Date().getTime());
        }

        $("#btnCaptchaYenile").on("click", captchaYenile);

        $("#captchaImg").on("click", captchaYenile);
    </script>
}